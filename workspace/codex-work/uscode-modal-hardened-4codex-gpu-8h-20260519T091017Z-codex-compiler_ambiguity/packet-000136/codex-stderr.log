   641	    def _derive_explicit_adaptive_ambiguity_type(
   642	        self,
   643	        ambiguity: ModalCompilationAmbiguity,
   644	    ) -> Optional[str]:
   645	        """Resolve explicit adaptive ambiguity type from base metadata."""
   646	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   647	        explicit_type = str(metadata.get("explicit_ambiguity_type") or "").strip()
   648	        if explicit_type and explicit_type != "adaptive_family_margin_low":
   649	            return explicit_type
   650	
   651	        predicted_family = str(metadata.get("predicted_family") or "").strip()
   652	        target_family = str(metadata.get("target_family") or "").strip()
   653	        if not predicted_family and ambiguity.candidate_ids:
   654	            predicted_family = str(ambiguity.candidate_ids[0]).strip()
   655	        if not target_family and len(ambiguity.candidate_ids) > 1:
   656	            target_family = str(ambiguity.candidate_ids[1]).strip()
   657	
   658	        policy_pair = str(metadata.get("adaptive_policy_pair") or "").strip()
   659	        if "->" in policy_pair:
   660	            policy_predicted, policy_target = policy_pair.split("->", maxsplit=1)
   661	            if not predicted_family:
   662	                predicted_family = policy_predicted.strip()
   663	            if not target_family:
   664	                target_family = policy_target.strip()
   665	
   666	        is_self_pair = bool(metadata.get("is_self_pair")) or (
   667	            len(ambiguity.candidate_ids) == 1
   668	        )
   669	        if is_self_pair and predicted_family and not target_family:
   670	            target_family = predicted_family
   671	        if not predicted_family or not target_family:
   672	            return None
   673	
   674	        margin_direction = str(metadata.get("adaptive_margin_direction") or "").strip().lower()
   675	        if margin_direction not in {"contested", "outvoted"}:
   676	            family_margin = metadata.get("family_margin_raw", metadata.get("family_margin"))
   677	            try:
   678	                margin_direction = "outvoted" if float(family_margin) <= 0.0 else "contested"
   679	            except (TypeError, ValueError):
   680	                margin_direction = "outvoted"
   681	        return self._adaptive_margin_explicit_type(
   682	            predicted_family,
   683	            target_family,
   684	            margin_direction,
   685	        )

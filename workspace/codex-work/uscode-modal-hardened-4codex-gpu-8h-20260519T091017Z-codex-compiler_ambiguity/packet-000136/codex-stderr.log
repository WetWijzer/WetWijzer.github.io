   648	class ModalRegistry:
   649	    """Lookup table for modal parse profiles."""
   650	
   651	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   652	        self._profiles: Dict[str, ModalParseProfile] = {
   653	            profile.profile_id: profile for profile in profiles
   654	        }
   655	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   656	            profile.family: profile for profile in profiles
   657	        }
   658	
   659	    def get_profile(
   660	        self,
   661	        family: ModalLogicFamily | str,
   662	        system: Optional[ModalSystem | str] = None,
   663	    ) -> ModalParseProfile:
   664	        """Get a profile by family, optionally constrained by system."""
   665	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   666	        if system is None:
   667	            return self._by_family[resolved_family]
   668	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   669	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   670	
   671	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   672	        """Return all profiles in deterministic order."""
   673	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   674	
   675	    def to_dict(self) -> Mapping[str, object]:
   676	        """Return a stable JSON-ready registry mapping."""
   677	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}

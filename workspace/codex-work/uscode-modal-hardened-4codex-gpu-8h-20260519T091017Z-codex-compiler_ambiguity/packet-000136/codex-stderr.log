   680	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   681	    """Return whether a modal family encodes normative legal force."""
   682	    if isinstance(family, ModalLogicFamily):
   683	        resolved = family
   684	    else:
   685	        try:
   686	            resolved = ModalLogicFamily(str(family))
   687	        except ValueError:
   688	            return False
   689	    return resolved in NORMATIVE_MODAL_FAMILIES

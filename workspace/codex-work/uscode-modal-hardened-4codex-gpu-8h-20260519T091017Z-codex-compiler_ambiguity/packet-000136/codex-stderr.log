   579	    @staticmethod
   580	    def _adaptive_explicit_ambiguity_key(
   581	        ambiguity: ModalCompilationAmbiguity,
   582	    ) -> tuple[str, tuple[str, ...], str, str]:
   583	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   584	        return (
   585	            str(ambiguity.ambiguity_type),
   586	            tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   587	            str(metadata.get("adaptive_policy_pair") or ""),
   588	            str(metadata.get("adaptive_predicted_family_source") or ""),
   589	        )

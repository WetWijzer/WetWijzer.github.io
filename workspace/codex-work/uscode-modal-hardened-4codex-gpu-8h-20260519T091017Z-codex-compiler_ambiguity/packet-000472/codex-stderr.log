 14200	def _token_overlap_ratio(left: str, right: str) -> float:
 14201	    left_tokens = {
 14202	        token.lower()
 14203	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", left)
 14204	    }
 14205	    right_tokens = {
 14206	        token.lower()
 14207	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", right)
 14208	    }
 14209	    if not left_tokens:
 14210	        return 1.0 if not right_tokens else 0.0
 14211	    return len(left_tokens & right_tokens) / len(left_tokens)


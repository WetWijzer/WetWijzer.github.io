 11765	def test_autoencoder_introspection_guides_typed_synthesis_hints() -> None:
 11766	    sample = build_us_code_sample(
 11767	        title="5",
 11768	        section="552",
 11769	        text="The agency must provide notice within 30 days.",
 11770	    )
 11771	    autoencoder = AdaptiveModalAutoencoder()
 11772	    todo = type(
 11773	        "Todo",
 11774	        (),
 11775	        {
 11776	            "action": "improve_encoder_decoder_reconstruction",
 11777	            "loss_name": "cosine_loss",
 11778	            "sample_ids": [sample.sample_id],
 11779	            "todo_id": "cos-synthesis",
 11780	        },
 11781	    )()
 11782	    autoencoder.apply_todos([todo], {sample.sample_id: sample}, learning_rate=0.5)
 11783	
 11784	    introspection = autoencoder.introspect_sample(sample).to_dict()

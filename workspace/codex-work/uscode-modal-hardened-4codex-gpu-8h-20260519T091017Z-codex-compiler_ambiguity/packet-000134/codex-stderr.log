    29	def test_deontic_profile_has_expected_operators_and_serial_semantics() -> None:
    30	    profile = DEFAULT_MODAL_REGISTRY.get_profile(ModalLogicFamily.DEONTIC)
    31	    symbols = {operator.symbol for operator in profile.operators}
    32	    cue_terms = {cue for operator in profile.operators for cue in operator.cue_terms}
    33	
    34	    assert profile.system == ModalSystem.D
    35	    assert profile.semantics.serial is True

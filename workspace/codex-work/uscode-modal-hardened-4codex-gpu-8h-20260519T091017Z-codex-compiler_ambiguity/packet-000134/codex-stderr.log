  1559	    @staticmethod
  1560	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1561	        """Return deterministic ambiguity priority from policy margin settings.
  1562	
  1563	        For contested low-margin cases (positive margin below threshold), a
  1564	        smaller gap to the threshold carries higher urgency. For outvoted
  1565	        cases (zero/negative margin), severity increases with outvote depth.
  1566	        """
  1567	        resolved_margin = float(family_margin)
  1568	        resolved_threshold = max(0.0, float(threshold))
  1569	        if resolved_margin > 0.0:
  1570	            return max(0.0, resolved_threshold - resolved_margin)
  1571	        return abs(resolved_margin) + resolved_threshold

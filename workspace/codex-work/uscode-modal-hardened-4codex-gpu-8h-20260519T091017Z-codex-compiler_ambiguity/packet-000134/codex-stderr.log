        text="Within 30 days notice applies.",
        normalized_text="Within 30 days notice applies.",
        tokens=[],
        sentences=[],
        cues=[
            SpaCyModalCueFeature(
                family="temporal",
                system="LTL",
                symbol="F",
                label="eventually",
                cue="within",
                start_char=0,
                end_char=6,
                token_indices=[],

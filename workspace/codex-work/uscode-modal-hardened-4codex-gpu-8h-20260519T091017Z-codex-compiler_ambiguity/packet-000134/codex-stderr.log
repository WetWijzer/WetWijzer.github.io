 12375	def _token_overlap_ratio(left: str, right: str) -> float:
 12376	    left_tokens = {
 12377	        token.lower()
 12378	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", left)
 12379	    }
 12380	    right_tokens = {
 12381	        token.lower()
 12382	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", right)
 12383	    }
 12384	    if not left_tokens:
 12385	        return 1.0 if not right_tokens else 0.0
 12386	    return len(left_tokens & right_tokens) / len(left_tokens)


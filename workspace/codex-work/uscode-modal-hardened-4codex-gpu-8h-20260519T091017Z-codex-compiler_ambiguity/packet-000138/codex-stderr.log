def test_compiler_required_adaptive_ambiguity_pairs_are_covered_by_both_policies() -> None:
    for predicted_family, target_family in (
        COMPILER_REQUIRED_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
    ):

 13355	def _token_overlap_ratio(left: str, right: str) -> float:
 13356	    left_tokens = {
 13357	        token.lower()
 13358	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", left)
 13359	    }
 13360	    right_tokens = {
 13361	        token.lower()
 13362	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", right)
 13363	    }
 13364	    if not left_tokens:
 13365	        return 1.0 if not right_tokens else 0.0
 13366	    return len(left_tokens & right_tokens) / len(left_tokens)


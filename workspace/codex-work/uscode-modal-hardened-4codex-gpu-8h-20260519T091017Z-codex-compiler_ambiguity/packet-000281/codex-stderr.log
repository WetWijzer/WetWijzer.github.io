   694	    def _adaptive_family_ranking_from_logits(
   695	        self,
   696	        encoding: SpaCyLegalEncoding,
   697	    ) -> List[Dict[str, float]]:
   698	        """Build fallback family ranking from deterministic decoder logits."""
   699	        modal_families = [family.value for family in ModalLogicFamily]
   700	        logits = self.decoder.family_logits(
   701	            encoding,
   702	            modal_families=modal_families,
   703	        )
   704	        if not logits:
   705	            return []
   706	        max_logit = max(float(value) for value in logits.values())
   707	        exp_by_family = {
   708	            family: math.exp(float(logit) - max_logit)
   709	            for family, logit in logits.items()
   710	        }
   711	        total = sum(exp_by_family.values())
   712	        if total <= 0.0:
   713	            return []
   714	        ranking: List[Dict[str, float]] = []
   715	        for family in sorted(
   716	            exp_by_family,
   717	            key=lambda key: (-exp_by_family[key], key),
   718	        ):
   719	            share_raw = exp_by_family[family] / total
   720	            ranking.append(
   721	                {
   722	                    "family": family,
   723	                    "count": 0,
   724	                    "logit": round(float(logits[family]), 6),
   725	                    "share_raw": share_raw,
   726	                    "share": round(share_raw, 6),
   727	                    "source": "logit_softmax_fallback",
   728	                }
   729	            )
   730	        return ranking

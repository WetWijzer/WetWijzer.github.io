   695	class ModalRegistry:
   696	    """Lookup table for modal parse profiles."""
   697	
   698	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   699	        self._profiles: Dict[str, ModalParseProfile] = {
   700	            profile.profile_id: profile for profile in profiles
   701	        }
   702	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   703	            profile.family: profile for profile in profiles
   704	        }
   705	
   706	    def get_profile(
   707	        self,
   708	        family: ModalLogicFamily | str,
   709	        system: Optional[ModalSystem | str] = None,
   710	    ) -> ModalParseProfile:
   711	        """Get a profile by family, optionally constrained by system."""
   712	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   713	        if system is None:
   714	            return self._by_family[resolved_family]
   715	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   716	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   717	
   718	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   719	        """Return all profiles in deterministic order."""
   720	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   721	
   722	    def to_dict(self) -> Mapping[str, object]:
   723	        """Return a stable JSON-ready registry mapping."""
   724	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   725	
   726	
   727	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   728	    """Return whether a modal family encodes normative legal force."""
   729	    if isinstance(family, ModalLogicFamily):
   730	        resolved = family
   731	    else:
   732	        try:
   733	            resolved = ModalLogicFamily(str(family))
   734	        except ValueError:
   735	            return False
   736	    return resolved in NORMATIVE_MODAL_FAMILIES
   737	
   738	
   739	def supports_signal_free_adaptive_ambiguity_pair(
   740	    predicted_family: ModalLogicFamily | str,
   741	    target_family: ModalLogicFamily | str,
   742	) -> bool:
   743	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   744	    resolved_target_family = _resolve_modal_family_name(target_family)
   745	    return (
   746	        resolved_target_family in signal_free_adaptive_ambiguity_targets(
   747	            predicted_family
   748	        )
   749	        or resolved_target_family in compiler_required_adaptive_ambiguity_targets(
   750	            predicted_family
   751	        )
   752	    )
   753	
   754	
   755	def signal_free_adaptive_ambiguity_targets(
   756	    predicted_family: ModalLogicFamily | str,
   757	) -> Tuple[str, ...]:
   758	    """Return ordered adaptive-ambiguity targets requiring signal-free handling."""
   759	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   760	    return tuple(
   761	        target_family
   762	        for source_family, target_family in SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   763	        if source_family == resolved_predicted_family
   764	    )
   765	
   766	

   830	def _resolve_modal_family_name(family: ModalLogicFamily | str) -> str:
   831	    if isinstance(family, ModalLogicFamily):
   832	        return family.value
   833	    try:
   834	        return ModalLogicFamily(str(family)).value
   835	    except ValueError:
   836	        return str(family).strip().lower()

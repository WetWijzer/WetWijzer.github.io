   581	    @staticmethod
   582	    def _adaptive_explicit_ambiguity_key(
   583	        ambiguity: ModalCompilationAmbiguity,
   584	    ) -> tuple[str, tuple[str, ...], str, str]:
   585	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   586	        return (
   587	            str(ambiguity.ambiguity_type),
   588	            tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   589	            str(metadata.get("adaptive_policy_pair") or ""),
   590	            str(metadata.get("adaptive_predicted_family_source") or ""),
   591	        )
   592	
   593	    def _ensure_explicit_adaptive_ambiguities(
   594	        self,
   595	        ambiguities: Sequence[ModalCompilationAmbiguity],
   596	    ) -> List[ModalCompilationAmbiguity]:
   597	        """Backfill explicit adaptive ambiguity variants from base low-margin records."""
   598	        resolved_ambiguities = list(ambiguities)
   599	        existing_explicit_keys = {
   600	            self._adaptive_explicit_ambiguity_key(ambiguity)
   601	            for ambiguity in resolved_ambiguities
   602	            if ambiguity.ambiguity_type.startswith("adaptive_")
   603	            and ambiguity.ambiguity_type != "adaptive_family_margin_low"
   604	        }
   605	        for ambiguity in list(resolved_ambiguities):
   606	            if ambiguity.ambiguity_type != "adaptive_family_margin_low":
   607	                continue
   608	            metadata = (
   609	                ambiguity.metadata
   610	                if isinstance(ambiguity.metadata, dict)
   611	                else {}
   612	            )
   613	            explicit_type = self._derive_explicit_adaptive_ambiguity_type(ambiguity)
   614	            if not explicit_type:
   615	                continue
   616	            explicit_key = (
   617	                explicit_type,
   618	                tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   619	                str(metadata.get("adaptive_policy_pair") or ""),
   620	                str(metadata.get("adaptive_predicted_family_source") or ""),
   621	            )
   622	            if explicit_key in existing_explicit_keys:
   623	                continue
   624	            explicit_message = (
   625	                "Explicit adaptive low-margin ambiguity for the predicted modal "
   626	                "family against close competing families."
   627	                if bool(metadata.get("is_self_pair"))
   628	                else (
   629	                    "Explicit adaptive modal-family conflict between the predicted "
   630	                    "family and a competing legal family."
   631	                )
   632	            )
   633	            resolved_ambiguities.append(
   634	                ModalCompilationAmbiguity(
   635	                    ambiguity_type=explicit_type,
   636	                    message=explicit_message,
   637	                    candidate_ids=list(ambiguity.candidate_ids),
   638	                    severity=ambiguity.severity,
   639	                    metadata={
   640	                        **metadata,
   641	                        "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
   642	                    },
   643	                )
   644	            )
   645	            existing_explicit_keys.add(explicit_key)
   646	        return resolved_ambiguities
   647	
   648	    def _derive_explicit_adaptive_ambiguity_type(
   649	        self,
   650	        ambiguity: ModalCompilationAmbiguity,
   651	    ) -> Optional[str]:
   652	        """Resolve explicit adaptive ambiguity type from base metadata."""
   653	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   654	        explicit_type = str(metadata.get("explicit_ambiguity_type") or "").strip()
   655	        if explicit_type and explicit_type != "adaptive_family_margin_low":
   656	            return explicit_type
   657	
   658	        predicted_family = str(metadata.get("predicted_family") or "").strip()
   659	        target_family = str(metadata.get("target_family") or "").strip()
   660	        if not predicted_family and ambiguity.candidate_ids:
   661	            predicted_family = str(ambiguity.candidate_ids[0]).strip()
   662	        if not target_family and len(ambiguity.candidate_ids) > 1:
   663	            target_family = str(ambiguity.candidate_ids[1]).strip()
   664	
   665	        policy_pair = str(metadata.get("adaptive_policy_pair") or "").strip()
   666	        if "->" in policy_pair:
   667	            policy_predicted, policy_target = policy_pair.split("->", maxsplit=1)
   668	            if not predicted_family:
   669	                predicted_family = policy_predicted.strip()
   670	            if not target_family:
   671	                target_family = policy_target.strip()
   672	
   673	        is_self_pair = bool(metadata.get("is_self_pair")) or (
   674	            len(ambiguity.candidate_ids) == 1
   675	        )
   676	        if is_self_pair and predicted_family and not target_family:
   677	            target_family = predicted_family
   678	        if not predicted_family or not target_family:
   679	            return None
   680	
   681	        margin_direction = str(metadata.get("adaptive_margin_direction") or "").strip().lower()
   682	        if margin_direction not in {"contested", "outvoted"}:
   683	            family_margin = metadata.get("family_margin_raw", metadata.get("family_margin"))
   684	            try:
   685	                margin_direction = "outvoted" if float(family_margin) <= 0.0 else "contested"
   686	            except (TypeError, ValueError):
   687	                margin_direction = "outvoted"
   688	        return self._adaptive_margin_explicit_type(
   689	            predicted_family,
   690	            target_family,
   691	            margin_direction,
   692	        )

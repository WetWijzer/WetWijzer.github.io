   288	def _ordered_unique_adaptive_ambiguity_family_pairs(
   289	    pairs: Iterable[Tuple[str, str]],
   290	) -> Tuple[Tuple[str, str], ...]:
   291	    """Return a stable pair table with duplicates removed and order preserved."""
   292	    unique_pairs: list[Tuple[str, str]] = []
   293	    seen_pairs: set[Tuple[str, str]] = set()
   294	    for pair in pairs:
   295	        if pair in seen_pairs:
   296	            continue
   297	        seen_pairs.add(pair)
   298	        unique_pairs.append(pair)
   299	    return tuple(unique_pairs)

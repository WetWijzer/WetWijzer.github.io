   787	        if source_family == resolved_predicted_family
   788	    )
   789	
   790	
   791	def is_compiler_required_adaptive_ambiguity_pair(
   792	    predicted_family: ModalLogicFamily | str,
   793	    target_family: ModalLogicFamily | str,
   794	) -> bool:
   795	    """Return whether a pair is in the compiler-required ambiguity policy bundle."""
   796	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   797	    resolved_target_family = _resolve_modal_family_name(target_family)
   798	    return (
   799	        resolved_predicted_family,
   800	        resolved_target_family,
   801	    ) in COMPILER_REQUIRED_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   802	
   803	
   804	def is_priority_signal_free_adaptive_ambiguity_pair(
   805	    predicted_family: ModalLogicFamily | str,
   806	    target_family: ModalLogicFamily | str,
   807	) -> bool:
   808	    """Return whether a pair is part of the highest-priority adaptive ambiguity policy."""
   809	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   810	    resolved_target_family = _resolve_modal_family_name(target_family)
   811	    return (
   812	        resolved_predicted_family,
   813	        resolved_target_family,
   814	    ) in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS

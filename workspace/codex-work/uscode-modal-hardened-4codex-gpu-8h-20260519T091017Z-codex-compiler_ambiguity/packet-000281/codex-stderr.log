   771	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   772	    return tuple(
   773	        target_family
   774	        for source_family, target_family in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   775	        if source_family == resolved_predicted_family

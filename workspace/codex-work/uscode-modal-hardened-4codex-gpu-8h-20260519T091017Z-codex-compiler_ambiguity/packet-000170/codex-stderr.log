        assert is_priority_signal_free_adaptive_ambiguity_pair(
            predicted_family,
            target_family,
        )


def test_signal_free_support_falls_back_to_compiler_required_policy_pairs(
    monkeypatch,
) -> None:
    trimmed_signal_free_pairs = tuple(

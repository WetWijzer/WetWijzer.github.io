@dataclass(frozen=True)
class ModalCompilationAmbiguity:
    """A compiler-detected ambiguity requiring review or advisor help."""

    ambiguity_type: str
    message: str
    candidate_ids: List[str] = field(default_factory=list)
    severity: str = "review"

        "alethic",
        "frame",
    )
    assert supports_signal_free_adaptive_ambiguity_pair(
        "alethic",
        "temporal",
    )
    assert supports_signal_free_adaptive_ambiguity_pair(
        "deontic",
        "conditional_normative",

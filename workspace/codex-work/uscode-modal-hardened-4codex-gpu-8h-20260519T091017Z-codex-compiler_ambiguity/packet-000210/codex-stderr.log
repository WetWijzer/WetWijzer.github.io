def _lookahead_tokens(
    tokens: Sequence[SpaCyTokenFeature],
    end_char: int,
    *,
    limit: int,
) -> List[SpaCyTokenFeature]:
    lookahead: List[SpaCyTokenFeature] = []
    for token in tokens:
        if token.start_char >= end_char:
            lookahead.append(token)
            if len(lookahead) >= limit:

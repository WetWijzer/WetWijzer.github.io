    )
    assert adaptive_frame.severity == "requires_rule"
    assert any(
        ambiguity.ambiguity_type == "adaptive_deontic_frame_outvoted_margin_low"
        and ambiguity.metadata["family_margin"] == 0.0
        for ambiguity in ambiguities
    )



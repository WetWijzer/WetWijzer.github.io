def run(pred,target,target_share,margin):
    # predicted_share from margin target-pred format
    predicted_share=target_share-margin
    cues=[SpaCyModalCueFeature(family=pred,system='FRAME_BM25' if pred=='frame' else 'LTL',symbol='Frame' if pred=='frame' else 'F',label='x',cue='x',start_char=0,end_char=1,token_indices=[])]
    enc=SpaCyLegalEncoding(document_id='d',text='x',normalized_text='x',tokens=[],sentences=[],cues=cues)

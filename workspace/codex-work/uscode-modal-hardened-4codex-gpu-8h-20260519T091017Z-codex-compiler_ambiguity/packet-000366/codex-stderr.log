from pathlib import Path
import re
text=Path('ipfs_datasets_py/optimizers/logic_theorem_optimizer/modal_registry.py').read_text()

def parse(name):
    m=re.search(rf\"{name}: Tuple\\[Tuple\\[str, str\\], \\.\\.\\.\\] = \\((.*?)\\n\\)\\n\",text,re.S)
    if not m:
        print('no',name);return []
    block=m.group(1)
    pairs=[]
    current=[]
    for line in block.splitlines():
        line=line.strip()
        if 'ModalLogicFamily.' in line and '.value' in line:
            fam=line.split('ModalLogicFamily.',1)[1].split('.value',1)[0].strip()
            current.append(fam.lower())
            if len(current)==2:
                pairs.append(tuple(current)); current=[]
    return pairs

names=['COMPILER_REQUIRED_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS','COMPILER_AMBIGUITY_POLICY_FAMILY_PAIRS','SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS','PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS']
sets={n:set(parse(n)) for n in names}
for n,v in sets.items():
    print(n,len(v))
print('signal-only-not-priority',sorted(sets['SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS']-sets['PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS']))
print('compiler-ambiguity-missing-from-todo-union maybe', sorted({('frame','conditional_normative'),('frame','temporal'),('hybrid','frame'),('deontic','temporal'),('frame','deontic')}-sets['COMPILER_AMBIGUITY_POLICY_FAMILY_PAIRS']))

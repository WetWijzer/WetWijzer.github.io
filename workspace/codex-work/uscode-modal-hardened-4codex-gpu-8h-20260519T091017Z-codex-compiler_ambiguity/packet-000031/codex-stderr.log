+                ),
+            ),
+        ],
+    )
+    ambiguities = compiler._adaptive_family_margin_ambiguities(
+        encoding,
+        modal_ir=modal_ir,
+        ranking=[
+            {"family": "conditional_normative", "count": 1, "share": 0.5},
+            {"family": "deontic", "count": 1, "share": 0.5},

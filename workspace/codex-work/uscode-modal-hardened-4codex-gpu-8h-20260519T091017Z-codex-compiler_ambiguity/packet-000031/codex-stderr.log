                ),
                ModalLogicFamily.DYNAMIC.value: bool(
                    signals.get("has_dynamic_scope")
                    or signals.get("has_dynamic_cue")
                ),
            }
        else:
            target_signal_by_family = {}
        return target_signal_by_family


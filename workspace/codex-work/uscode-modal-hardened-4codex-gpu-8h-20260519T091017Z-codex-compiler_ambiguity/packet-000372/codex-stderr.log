import re
from pathlib import Path
path=Path('ipfs_datasets_py/optimizers/logic_theorem_optimizer/modal_registry.py')
text=path.read_text()

def extract(const):
    # locate const assignment block parentheses balanced
    start=text.index(const)
    start=text.index('(',start)
    depth=0
    i=start
    while i < len(text):
        c=text[i]
        if c=='(':
            depth+=1
        elif c==')':
            depth-=1
            if depth==0:
                end=i+1
                break
        i+=1
    block=text[start:end]
    pairs=re.findall(r\"ModalLogicFamily\\.([A-Z_]+)\\.value\\s*,\\s*\\n\\s*ModalLogicFamily\\.([A-Z_]+)\\.value\",block)
    return {(a.lower(),b.lower()) for a,b in pairs}

policy=extract('COMPILER_AMBIGUITY_POLICY_FAMILY_PAIRS')
req=extract('COMPILER_REQUIRED_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS')
sf=extract('SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS')
missing=sorted(policy-(req|sf))
print('policy',len(policy),'req',len(req),'sf',len(sf))
print('missing',missing)

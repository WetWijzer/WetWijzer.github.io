                    label=str(scenario["predicted_label"]),
                    cue="evidence",
                    start_char=0,
                    end_char=8,
                    token_indices=[],
                )
            ],
        )
        modal_ir = ModalIRDocument(
            document_id=str(scenario["doc_id"]),
            source="us_code",
            normalized_text=encoding.normalized_text,
            formulas=[

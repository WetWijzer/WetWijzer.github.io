  1589	    def _has_frame_bm25_support(
  1590	        self,
  1591	        frame_selections: Sequence[FrameSelection],
  1592	    ) -> bool:
  1593	        if not frame_selections:
  1594	            return False
  1595	        return any(
  1596	            bool(selection.matched_terms) and float(selection.score) > 0.0
  1597	            for selection in frame_selections
  1598	        )
  1599	
  1600	    def _adaptive_margin_explicit_type(
  1601	        self,
  1602	        predicted_family: str,
  1603	        target_family: str,
  1604	        margin_direction: str,
  1605	    ) -> str:
  1606	        return "_".join(
  1607	            (
  1608	                "adaptive",
  1609	                predicted_family,
  1610	                target_family,
  1611	                margin_direction,
  1612	                "margin_low",
  1613	            )
  1614	        )
  1615	
  1616	    def _adaptive_margin_direction(
  1617	        self,
  1618	        *,
  1619	        family_margin: float,
  1620	        predicted_family: str,
  1621	        target_family: str,
  1622	        is_priority_policy_pair: bool,
  1623	        is_compiler_required_policy_pair: bool,
  1624	        epsilon: float = 1e-12,
  1625	    ) -> str:
  1626	        """Classify adaptive low-margin conflicts as contested vs. outvoted."""
  1627	        resolved_margin = float(family_margin)
  1628	        resolved_epsilon = max(0.0, float(epsilon))
  1629	        if (
  1630	            abs(resolved_margin) <= resolved_epsilon
  1631	            and prefers_contested_zero_margin_adaptive_ambiguity_pair(
  1632	                predicted_family,
  1633	                target_family,
  1634	            )
  1635	        ):
  1636	            return "contested"
  1637	        if resolved_margin < -resolved_epsilon:
  1638	            return "outvoted"
  1639	        if resolved_margin <= resolved_epsilon and (
  1640	            is_priority_policy_pair
  1641	            or is_compiler_required_policy_pair
  1642	        ):
  1643	            return "outvoted"
  1644	        return "contested"
  1645	
  1646	    @staticmethod
  1647	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1648	        """Return deterministic ambiguity priority from policy margin settings.
  1649	
  1650	        For contested low-margin cases (positive margin below threshold), a
  1651	        smaller gap to the threshold carries higher urgency. For outvoted
  1652	        cases (zero/negative margin), severity increases with outvote depth.
  1653	        """
  1654	        resolved_margin = float(family_margin)
  1655	        resolved_threshold = max(0.0, float(threshold))
  1656	        if resolved_margin > 0.0:
  1657	            return max(0.0, resolved_threshold - resolved_margin)
  1658	        return abs(resolved_margin) + resolved_threshold
  1659	
  1660	    @staticmethod
  1661	    def _adaptive_margin_within_threshold(
  1662	        *,
  1663	        family_margin: float,
  1664	        threshold: float,
  1665	        epsilon: float = 1e-12,
  1666	    ) -> bool:
  1667	        """Return whether the margin is at or below threshold with float tolerance."""
  1668	        resolved_margin = float(family_margin)
  1669	        resolved_threshold = float(threshold)
  1670	        resolved_epsilon = max(0.0, float(epsilon))
  1671	        return resolved_margin <= (resolved_threshold + resolved_epsilon)
  1672	
  1673	    def _supports_signal_free_adaptive_pair(
  1674	        self,
  1675	        predicted_family: str,
  1676	        target_family: str,
  1677	    ) -> bool:
  1678	        """Return whether this pair must surface adaptive ambiguity without lexical support."""
  1679	        return supports_signal_free_adaptive_ambiguity_pair(
  1680	            predicted_family,
  1681	            target_family,
  1682	        )
  1683	
  1684	    def _temporal_target_family_ambiguities(
  1685	        self,
  1686	        encoding: SpaCyLegalEncoding,
  1687	        *,
  1688	        ranking: Sequence[Dict[str, Any]],
  1689	        family_shares: Dict[str, float],
  1690	    ) -> List[ModalCompilationAmbiguity]:
  1691	        if not ranking:
  1692	            return []
  1693	        top_family = str(ranking[0]["family"])
  1694	        if top_family != ModalLogicFamily.TEMPORAL.value:
  1695	            return []
  1696	        temporal_share = self._ranking_share(ranking[0])
  1697	        signals = modal_ambiguity_signals(encoding)
  1698	        target_specs = (
  1699	            (
  1700	                ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
  1701	                bool(signals.get("has_condition_or_exception_scope")),
  1702	                "temporal_conditional_normative_family_outvoted",
  1703	                (
  1704	                    "Conditional or exception scope markers are present, but temporal cues "
  1705	                    "outvote conditional-normative family evidence."
  1706	                ),
  1707	            ),
  1708	            (
  1709	                ModalLogicFamily.FRAME.value,
  1710	                bool(signals.get("has_frame_context") or signals.get("has_frame_cue")),
  1711	                "temporal_frame_family_outvoted",
  1712	                (
  1713	                    "Frame-context markers are present, but temporal cues outvote frame-family "
  1714	                    "evidence."
  1715	                ),
  1716	            ),
  1717	        )
  1718	        ambiguities: List[ModalCompilationAmbiguity] = []
  1719	        for target_family, has_signal, ambiguity_type, message in target_specs:
  1720	            target_share = float(family_shares.get(target_family, 0.0))
  1721	            family_margin = target_share - temporal_share
  1722	            if not has_signal and target_share <= 0.0:
  1723	                continue
  1724	            if family_margin >= self.config.modal_temporal_target_family_outvote_margin:
  1725	                continue
  1726	            ambiguities.append(
  1727	                ModalCompilationAmbiguity(
  1728	                    ambiguity_type=ambiguity_type,
  1729	                    message=message,
  1730	                    candidate_ids=[ModalLogicFamily.TEMPORAL.value, target_family],
  1731	                    severity="requires_rule",
  1732	                    metadata={
  1733	                        "family_margin": round(family_margin, 6),
  1734	                        "family_ranking": list(ranking),
  1735	                        "lexical_signals": dict(sorted(signals.items())),
  1736	                        "outvote_margin_threshold": self.config.modal_temporal_target_family_outvote_margin,
  1737	                        "predicted_family": ModalLogicFamily.TEMPORAL.value,
  1738	                        "target_family": target_family,
  1739	                        "target_share": round(target_share, 6),
  1740	                        "temporal_share": round(temporal_share, 6),
  1741	                    },
  1742	                )
  1743	            )
  1744	        return ambiguities
  1745	
  1746	    def _temporal_scope_target_family_ambiguities(
  1747	        self,
  1748	        encoding: SpaCyLegalEncoding,
  1749	        *,
  1750	        ranking: Sequence[Dict[str, Any]],
  1751	        family_shares: Dict[str, float],
  1752	    ) -> List[ModalCompilationAmbiguity]:

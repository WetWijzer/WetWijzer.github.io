   351	def _ordered_unique_adaptive_ambiguity_family_pairs(
   352	    pairs: Iterable[Tuple[str, str]],
   353	) -> Tuple[Tuple[str, str], ...]:
   354	    """Return a stable pair table with duplicates removed and order preserved."""
   355	    unique_pairs: list[Tuple[str, str]] = []
   356	    seen_pairs: set[Tuple[str, str]] = set()
   357	    for pair in pairs:
   358	        if pair in seen_pairs:
   359	            continue
   360	        seen_pairs.add(pair)
   361	        unique_pairs.append(pair)
   362	    return tuple(unique_pairs)

  1974	    def _temporal_deontic_scope_family_ambiguities(
  1975	        self,
  1976	        encoding: SpaCyLegalEncoding,
  1977	        *,
  1978	        ranking: Sequence[Dict[str, Any]],
  1979	        family_shares: Dict[str, float],
  1980	    ) -> List[ModalCompilationAmbiguity]:
  1981	        if not ranking:
  1982	            return []
  1983	        predicted_family = str(ranking[0]["family"])
  1984	        if predicted_family not in {
  1985	            ModalLogicFamily.TEMPORAL.value,
  1986	            ModalLogicFamily.DEONTIC.value,
  1987	        }:
  1988	            return []
  1989	        predicted_share = self._ranking_share(ranking[0])
  1990	        target_family = (
  1991	            ModalLogicFamily.DEONTIC.value
  1992	            if predicted_family == ModalLogicFamily.TEMPORAL.value
  1993	            else ModalLogicFamily.TEMPORAL.value
  1994	        )
  1995	        target_share = float(family_shares.get(target_family, 0.0))
  1996	        signals = modal_ambiguity_signals(encoding)
  1997	        has_target_scope = bool(
  1998	            signals.get("has_deontic_scope")
  1999	            or signals.get("has_deontic_cue")
  2000	            if target_family == ModalLogicFamily.DEONTIC.value
  2001	            else signals.get("has_temporal_scope")
  2002	        )
  2003	        if not has_target_scope and target_share <= 0.0:
  2004	            return []
  2005	        family_margin = target_share - predicted_share
  2006	        outvote_margin_threshold = (
  2007	            self.config.modal_deontic_target_family_outvote_margin
  2008	            if target_family == ModalLogicFamily.DEONTIC.value
  2009	            else self.config.modal_temporal_target_family_outvote_margin
  2010	        )
  2011	        if family_margin >= outvote_margin_threshold:
  2012	            return []
  2013	        return [
  2014	            ModalCompilationAmbiguity(
  2015	                ambiguity_type="temporal_deontic_scope_family_outvoted",
  2016	                message=(
  2017	                    "Temporal-scope and deontic-force evidence compete; the top modal family "
  2018	                    "outvotes the opposite family and requires review."
  2019	                ),
  2020	                candidate_ids=[predicted_family, target_family],
  2021	                severity="requires_rule",
  2022	                metadata={
  2023	                    "family_margin": round(family_margin, 6),
  2024	                    "family_ranking": list(ranking),
  2025	                    "lexical_signals": dict(sorted(signals.items())),

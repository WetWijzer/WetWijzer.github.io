  1512	            compiled_primary_family,
  1513	            compiled_primary_family,
  1514	        )
  1515	        base_metadata = {
  1516	            "adaptive_family_margin_threshold": threshold,
  1517	            "adaptive_margin_direction": margin_direction,
  1518	            "adaptive_margin_abs": abs(family_margin),
  1519	            "adaptive_priority": adaptive_priority,
  1520	            "priority": adaptive_priority,
  1521	            "adaptive_predicted_family_source": "compiled_primary_family",
  1522	            "adaptive_policy_pair": f"{compiled_primary_family}->{compiled_primary_family}",
  1523	            "adaptive_runner_up_policy_pair": (
  1524	                f"{compiled_primary_family}->{runner_up_family}"
  1525	            ),
  1526	            "explicit_ambiguity_type": explicit_type,
  1527	            "family_margin_raw": family_margin,
  1528	            "family_margin": family_margin_display,
  1529	            "family_ranking": list(ranking),
  1530	            "compiled_modal_families": sorted(compiled_modal_families),
  1531	            "has_target_signal_evidence": has_target_signal_evidence,
  1532	            "signal_free_pair_policy_applied": (
  1533	                not has_target_signal_evidence
  1534	            ),
  1535	            "has_compiled_target_family_formula": has_compiled_target_family_formula,
  1536	            "has_frame_bm25_support": has_frame_bm25_support,
  1537	            "lexical_signals": dict(sorted(signals.items())),
  1538	            "is_compiler_required_policy_pair": is_compiler_required_policy_pair,
  1539	            "runner_up_is_compiler_required_policy_pair": (
  1540	                runner_up_is_compiler_required_policy_pair
  1541	            ),
  1542	            "is_priority_policy_pair": is_priority_policy_pair,
  1543	            "runner_up_is_priority_policy_pair": runner_up_is_priority_policy_pair,
  1544	            "is_compiler_ambiguity_bundle_pair": is_compiler_ambiguity_bundle_pair,
  1545	            "ambiguity_policy_bundle": (
  1546	                "compiler_ambiguity"
  1547	                if is_compiler_ambiguity_bundle_pair
  1548	                else None
  1549	            ),
  1550	            "predicted_family": compiled_primary_family,
  1551	            "predicted_margin_to_runner_up_raw": family_margin,
  1552	            "predicted_margin_to_runner_up": family_margin_display,
  1553	            "runner_up_family": runner_up_family,
  1554	            "runner_up_share_raw": runner_up_share,
  1555	            "runner_up_share": runner_up_share_display,
  1556	            "predicted_share_raw": primary_share,
  1557	            "predicted_share": primary_share_display,
  1558	            "target_family": compiled_primary_family,
  1559	            "target_share_raw": primary_share,
  1560	            "target_share": primary_share_display,
  1561	            "is_self_pair": True,
  1562	        }
  1563	        return [
  1564	            ModalCompilationAmbiguity(
  1565	                ambiguity_type="adaptive_family_margin_low",
  1566	                message=(
  1567	                    "A predicted modal family has a low lead over competing legal "
  1568	                    "families; family selection is ambiguous."
  1569	                ),
  1570	                candidate_ids=[compiled_primary_family],
  1571	                severity="requires_rule" if requires_rule else "review",
  1572	                metadata=dict(base_metadata),
  1573	            ),
  1574	            ModalCompilationAmbiguity(
  1575	                ambiguity_type=explicit_type,
  1576	                message=(
  1577	                    "Explicit adaptive low-margin ambiguity for the predicted modal "
  1578	                    "family against close competing families."
  1579	                ),
  1580	                candidate_ids=[compiled_primary_family],
  1581	                severity="requires_rule" if requires_rule else "review",
  1582	                metadata={
  1583	                    **base_metadata,
  1584	                    "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
  1585	                },
  1586	            ),
  1587	        ]

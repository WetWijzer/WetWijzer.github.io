   561	                    "symbol": operator.symbol,
   562	                }
   563	                for operator in self.operators
   564	            ],
   565	            "profile_id": self.profile_id,
   566	            "semantics": self.semantics.to_dict(),
   567	            "system": self.system.value,
   568	        }

def test_modal_compiler_emits_explicit_ambiguity_for_todo_evidence_margin_pairs(
    monkeypatch,
) -> None:
    compiler = DeterministicModalCompiler(
        ModalCompilerConfig(
            parser_backend="regex",
            frame_score_margin=0.0,
            modal_adaptive_family_margin=0.15,

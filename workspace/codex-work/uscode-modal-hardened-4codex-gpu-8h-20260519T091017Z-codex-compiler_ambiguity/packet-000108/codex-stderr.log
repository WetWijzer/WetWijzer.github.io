class ModalSystem(Enum):
    """Common modal systems and legal-parser profiles."""

    K = "K"
    T = "T"
    D = "D"
    K4 = "K4"
    S4 = "S4"
    S5 = "S5"
    KD = "KD"
    KD45 = "KD45"
    LTL = "LTL"
    CTL = "CTL"
    PDL = "PDL"
    STIT = "STIT"
    FRAME_BM25 = "FRAME_BM25"
    HYBRID = "HYBRID"



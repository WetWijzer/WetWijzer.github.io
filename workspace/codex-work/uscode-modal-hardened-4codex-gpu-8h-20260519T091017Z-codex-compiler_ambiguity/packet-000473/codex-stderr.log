def _op(
    symbol: str,
    aliases: Iterable[str],
    cue_terms: Iterable[str],
    systems: Iterable[ModalSystem],
) -> ModalOperatorSpec:
    return ModalOperatorSpec(
        symbol=symbol,
        aliases=tuple(aliases),
        cue_terms=tuple(cue_terms),
        allowed_systems=tuple(systems),
    )



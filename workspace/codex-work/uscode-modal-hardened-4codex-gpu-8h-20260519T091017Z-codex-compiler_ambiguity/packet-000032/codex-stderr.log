    """Modal logic families planned for deterministic legal parsing."""

    ALETHIC = "alethic"
    DEONTIC = "deontic"
    TEMPORAL = "temporal"
    EPISTEMIC = "epistemic"
    DOXASTIC = "doxastic"
    DYNAMIC = "dynamic"
    CONDITIONAL_NORMATIVE = "conditional_normative"
    FRAME = "frame"
    HYBRID = "hybrid"



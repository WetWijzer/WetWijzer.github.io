            adaptive_priority = self._adaptive_margin_priority(
                family_margin=family_margin,
                threshold=threshold,
            )
            base_metadata = {
                "adaptive_family_margin_threshold": threshold,
                "adaptive_margin_direction": margin_direction,
                "adaptive_margin_abs": abs(family_margin),

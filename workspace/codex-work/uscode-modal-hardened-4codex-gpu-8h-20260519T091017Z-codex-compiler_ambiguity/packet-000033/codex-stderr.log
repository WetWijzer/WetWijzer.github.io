   796	                predicted_family=predicted_family,
   797	                target_signal_by_family=target_signal_by_family,
   798	            )
   799	        ambiguities: List[ModalCompilationAmbiguity] = []
   800	        for target_family in ordered_target_families:
   801	            has_signal = bool(target_signal_by_family.get(target_family, False))
   802	            is_self_pair = target_family == predicted_family
   803	            runner_up_is_priority_policy_pair = bool(
   804	                is_self_pair
   805	                and runner_up_family is not None
   806	                and is_priority_signal_free_adaptive_ambiguity_pair(
   807	                    predicted_family,
   808	                    runner_up_family,
   809	                )
   810	            )
   811	            runner_up_is_compiler_required_policy_pair = bool(
   812	                is_self_pair
   813	                and runner_up_family is not None
   814	                and is_compiler_required_adaptive_ambiguity_pair(
   815	                    predicted_family,
   816	                    runner_up_family,
   817	                )
   818	            )
   819	            if is_self_pair and (
   820	                predicted_margin_to_runner_up is None
   821	                or predicted_margin_to_runner_up > threshold
   822	            ):
   823	                continue
   824	            target_share = float(family_shares.get(target_family, 0.0))
   825	            has_compiled_target_family_formula = target_family in compiled_modal_families
   826	            has_target_signal_evidence = bool(
   827	                has_signal
   828	                or target_share > 0.0
   829	                or has_compiled_target_family_formula
   830	            )
   831	            supports_signal_free_pair_policy = self._supports_signal_free_adaptive_pair(
   832	                predicted_family,
   833	                target_family,
   834	            )
   835	            is_priority_policy_pair = is_priority_signal_free_adaptive_ambiguity_pair(
   836	                predicted_family,
   837	                target_family,
   838	            ) or runner_up_is_priority_policy_pair
   839	            is_compiler_required_policy_pair = (
   840	                is_compiler_required_adaptive_ambiguity_pair(
   841	                    predicted_family,
   842	                    target_family,
   843	                )
   844	                or runner_up_is_compiler_required_policy_pair
   845	            )
   846	            if (
   847	                not has_target_signal_evidence
   848	                and not supports_signal_free_pair_policy
   849	            ):
   850	                continue
   851	            family_margin = (
   852	                predicted_margin_to_runner_up
   853	                if is_self_pair and predicted_margin_to_runner_up is not None
   854	                else target_share - predicted_share
   855	            )
   856	            if family_margin > threshold:
   857	                continue
   858	            margin_direction = "outvoted" if (
   859	                family_margin < 0.0
   860	                or (
   861	                    family_margin <= 0.0
   862	                    and (
   863	                        is_priority_policy_pair
   864	                        or is_compiler_required_policy_pair
   865	                    )
   866	                )
   867	            ) else "contested"
   868	            requires_rule = margin_direction == "outvoted"
   869	            explicit_type = self._adaptive_margin_explicit_type(

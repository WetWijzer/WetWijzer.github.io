   900	                "adaptive_policy_pair": f"{predicted_family}->{target_family}",
   901	                "explicit_ambiguity_type": explicit_type,
   902	                "family_margin_raw": family_margin,
   903	                "family_margin": family_margin_display,
   904	                "family_ranking": list(ranking),
   905	                "compiled_modal_families": sorted(compiled_modal_families),
   906	                "has_target_signal_evidence": has_target_signal_evidence,
   907	                "signal_free_pair_policy_applied": (

   707	    def _adaptive_family_ranking_from_logits(
   708	        self,
   709	        encoding: SpaCyLegalEncoding,
   710	    ) -> List[Dict[str, float]]:
   711	        """Build fallback family ranking from deterministic decoder logits."""
   712	        modal_families = [family.value for family in ModalLogicFamily]
   713	        logits = self.decoder.family_logits(
   714	            encoding,
   715	            modal_families=modal_families,
   716	        )
   717	        if not logits:
   718	            return []
   719	        max_logit = max(float(value) for value in logits.values())
   720	        exp_by_family = {
   721	            family: math.exp(float(logit) - max_logit)
   722	            for family, logit in logits.items()
   723	        }
   724	        total = sum(exp_by_family.values())
   725	        if total <= 0.0:
   726	            return []
   727	        ranking: List[Dict[str, float]] = []
   728	        for family in sorted(
   729	            exp_by_family,
   730	            key=lambda key: (-exp_by_family[key], key),
   731	        ):
   732	            share_raw = exp_by_family[family] / total
   733	            ranking.append(
   734	                {
   735	                    "family": family,
   736	                    "count": 0,
   737	                    "logit": round(float(logits[family]), 6),
   738	                    "share_raw": share_raw,
   739	                    "share": round(share_raw, 6),
   740	                    "source": "logit_softmax_fallback",
   741	                }
   742	            )
   743	        return ranking

   940	                "target_share": target_share_display,
   941	                "is_self_pair": is_self_pair,
   942	            }
   943	            base_message = (
   944	                "A predicted modal family has a low lead over competing legal "
   945	                "families; family selection is ambiguous."
   946	                if is_self_pair
   947	                else (
   948	                    "A dominant modal family outvotes another legal modal family "
   949	                    "despite competing scope/context evidence; family selection is "
   950	                    "ambiguous."
   951	                )
   952	            )
   953	            explicit_message = (
   954	                "Explicit adaptive low-margin ambiguity for the predicted modal "
   955	                "family against close competing families."
   956	                if is_self_pair
   957	                else (
   958	                    "Explicit adaptive modal-family conflict between the predicted "
   959	                    "family and a competing legal family."
   960	                )
   961	            )
   962	            ambiguities.append(
   963	                ModalCompilationAmbiguity(
   964	                    ambiguity_type="adaptive_family_margin_low",
   965	                    message=base_message,
   966	                    candidate_ids=candidate_ids,
   967	                    severity="requires_rule" if requires_rule else "review",
   968	                    metadata=dict(base_metadata),
   969	                )
   970	            )
   971	            ambiguities.append(
   972	                ModalCompilationAmbiguity(
   973	                    ambiguity_type=explicit_type,
   974	                    message=explicit_message,
   975	                    candidate_ids=candidate_ids,
   976	                    severity="requires_rule" if requires_rule else "review",
   977	                    metadata={
   978	                        **base_metadata,
   979	                        "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
   980	                    },
   981	                )
   982	            )
   983	        if (
   984	            compiled_primary_family is not None
   985	            and compiled_primary_family != predicted_family
   986	        ):
   987	            compiled_primary_targets: List[str] = [predicted_family]
   988	            if self._supports_signal_free_adaptive_pair(
   989	                compiled_primary_family,
   990	                compiled_primary_family,
   991	            ):
   992	                compiled_primary_targets.append(compiled_primary_family)
   993	            compiled_primary_signal_targets = self._adaptive_target_signal_by_family(
   994	                compiled_primary_family,
   995	                signals=signals,
   996	                has_frame_scope=has_frame_scope,
   997	            )
   998	            for target_family in compiled_primary_signal_targets:
   999	                if (
  1000	                    target_family != compiled_primary_family

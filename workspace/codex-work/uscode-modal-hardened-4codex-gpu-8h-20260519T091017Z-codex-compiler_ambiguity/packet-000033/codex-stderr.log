   918	                "is_priority_policy_pair": is_priority_policy_pair,
   919	                "runner_up_is_priority_policy_pair": runner_up_is_priority_policy_pair,
   920	                "predicted_family": predicted_family,
   921	                "predicted_margin_to_runner_up_raw": predicted_margin_to_runner_up,
   922	                "predicted_margin_to_runner_up": (
   923	                    round(predicted_margin_to_runner_up, 6)
   924	                    if predicted_margin_to_runner_up is not None
   925	                    else None
   926	                ),
   927	                "runner_up_family": runner_up_family,

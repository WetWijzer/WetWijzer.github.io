  1053	    @staticmethod
  1054	    def _ordered_adaptive_target_families(
  1055	        *,
  1056	        predicted_family: str,
  1057	        target_signal_by_family: Mapping[str, bool],
  1058	    ) -> List[str]:
  1059	        ordered_targets: List[str] = []
  1060	        seen_targets: set[str] = set()
  1061	        for target_family in priority_signal_free_adaptive_ambiguity_targets(
  1062	            predicted_family
  1063	        ):
  1064	            if target_family not in seen_targets:
  1065	                ordered_targets.append(target_family)
  1066	                seen_targets.add(target_family)
  1067	        for target_family in target_signal_by_family:
  1068	            if target_family not in seen_targets:
  1069	                ordered_targets.append(target_family)
  1070	                seen_targets.add(target_family)
  1071	        return ordered_targets

   201	def _ordered_unique_adaptive_ambiguity_family_pairs(
   202	    pairs: Iterable[Tuple[str, str]],
   203	) -> Tuple[Tuple[str, str], ...]:
   204	    """Return a stable pair table with duplicates removed and order preserved."""
   205	    unique_pairs: list[Tuple[str, str]] = []
   206	    seen_pairs: set[Tuple[str, str]] = set()
   207	    for pair in pairs:
   208	        if pair in seen_pairs:
   209	            continue
   210	        seen_pairs.add(pair)
   211	        unique_pairs.append(pair)
   212	    return tuple(unique_pairs)

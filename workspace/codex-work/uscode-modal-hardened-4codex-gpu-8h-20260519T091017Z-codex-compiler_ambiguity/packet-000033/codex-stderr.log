   745	    def _adaptive_family_margin_ambiguities(
   746	        self,
   747	        encoding: SpaCyLegalEncoding,
   748	        *,
   749	        modal_ir: ModalIRDocument,
   750	        ranking: Sequence[Dict[str, Any]],
   751	        family_shares: Dict[str, float],
   752	        frame_selections: Sequence[FrameSelection] = (),
   753	        predicted_family_source: str = "ranked_modal_families",
   754	    ) -> List[ModalCompilationAmbiguity]:
   755	        """Surface explicit ambiguities when strong legal families compete."""
   756	        if not ranking:
   757	            return []
   758	        predicted_family = str(ranking[0]["family"])
   759	        predicted_share = self._ranking_share(ranking[0])
   760	        runner_up_family: Optional[str] = None
   761	        runner_up_share = 0.0
   762	        predicted_margin_to_runner_up: Optional[float] = None
   763	        if len(ranking) > 1:
   764	            runner_up_family = str(ranking[1]["family"])
   765	            runner_up_share = self._ranking_share(ranking[1])
   766	            predicted_margin_to_runner_up = predicted_share - runner_up_share
   767	        signals = modal_ambiguity_signals(encoding)
   768	        threshold = float(self.config.modal_adaptive_family_margin)
   769	        has_frame_bm25_support = self._has_frame_bm25_support(frame_selections)
   770	        compiled_modal_families = {
   771	            str(formula.operator.family) for formula in modal_ir.formulas
   772	        }
   773	        compiled_primary_family = (
   774	            str(modal_ir.formulas[0].operator.family)
   775	            if modal_ir.formulas
   776	            else None
   777	        )
   778	        has_frame_scope = bool(
   779	            signals.get("has_frame_context")

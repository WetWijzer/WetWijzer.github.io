   592	class ModalRegistry:
   593	    """Lookup table for modal parse profiles."""
   594	
   595	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   596	        self._profiles: Dict[str, ModalParseProfile] = {
   597	            profile.profile_id: profile for profile in profiles
   598	        }
   599	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   600	            profile.family: profile for profile in profiles
   601	        }
   602	
   603	    def get_profile(
   604	        self,
   605	        family: ModalLogicFamily | str,
   606	        system: Optional[ModalSystem | str] = None,
   607	    ) -> ModalParseProfile:
   608	        """Get a profile by family, optionally constrained by system."""
   609	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   610	        if system is None:
   611	            return self._by_family[resolved_family]
   612	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   613	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   614	
   615	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   616	        """Return all profiles in deterministic order."""
   617	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   618	
   619	    def to_dict(self) -> Mapping[str, object]:
   620	        """Return a stable JSON-ready registry mapping."""
   621	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   622	
   623	
   624	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   625	    """Return whether a modal family encodes normative legal force."""
   626	    if isinstance(family, ModalLogicFamily):
   627	        resolved = family
   628	    else:
   629	        try:
   630	            resolved = ModalLogicFamily(str(family))
   631	        except ValueError:
   632	            return False
   633	    return resolved in NORMATIVE_MODAL_FAMILIES
   634	
   635	
   636	def supports_signal_free_adaptive_ambiguity_pair(
   637	    predicted_family: ModalLogicFamily | str,
   638	    target_family: ModalLogicFamily | str,
   639	) -> bool:
   640	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   641	    resolved_target_family = _resolve_modal_family_name(target_family)
   642	    return resolved_target_family in signal_free_adaptive_ambiguity_targets(
   643	        predicted_family
   644	    )
   645	
   646	
   647	def signal_free_adaptive_ambiguity_targets(
   648	    predicted_family: ModalLogicFamily | str,

  1193	    def _compiled_primary_family_adaptive_pair_ambiguities(
  1194	        self,
  1195	        *,
  1196	        compiled_primary_family: str,
  1197	        competing_family: str,
  1198	        ranking: Sequence[Dict[str, Any]],
  1199	        family_shares: Dict[str, float],
  1200	        threshold: float,
  1201	        signals: Mapping[str, bool],
  1202	        has_frame_scope: bool,
  1203	        has_frame_bm25_support: bool,
  1204	        compiled_modal_families: Sequence[str],
  1205	    ) -> List[ModalCompilationAmbiguity]:
  1206	        supports_signal_free_pair_policy = self._supports_signal_free_adaptive_pair(
  1207	            compiled_primary_family,
  1208	            competing_family,
  1209	        )
  1210	        is_self_pair = compiled_primary_family == competing_family
  1211	        primary_share = float(family_shares.get(compiled_primary_family, 0.0))
  1212	        competing_share = float(family_shares.get(competing_family, 0.0))
  1213	        runner_up_family: Optional[str] = competing_family
  1214	        runner_up_share: Optional[float] = competing_share
  1215	        if is_self_pair:
  1216	            runner_up_family = None
  1217	            runner_up_share = None
  1218	            for candidate in ranking:
  1219	                candidate_family = str(candidate.get("family", ""))
  1220	                if candidate_family == compiled_primary_family:
  1221	                    continue

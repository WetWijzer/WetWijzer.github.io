            "family_margin": -0.241161539133,
            "adaptive_priority": 0.391161539133,
            "expected_explicit_type": "adaptive_temporal_deontic_outvoted_margin_low",
            "expected_severity": "requires_rule",
            "is_self_pair": False,
        },
        {

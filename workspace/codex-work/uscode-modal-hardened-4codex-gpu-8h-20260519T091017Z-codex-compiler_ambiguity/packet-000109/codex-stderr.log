        },
    )

    assert ordered_targets == [
        "conditional_normative",
        "deontic",
        "epistemic",
        "temporal",
        "frame",
    ]


def test_modal_compiler_includes_priority_adaptive_targets_even_when_signal_map_is_sparse() -> None:

   206	def _coarse_uscode_heading_noise_text(section: str, heading: str) -> str:
   207	    noise_tokens = " ".join(chr(ord("a") + (index % 26)) for index in range(160))
   208	    return (
   209	        "U S C title archive register digest taxonomy index chapter crosswalk "
   210	        f"sec {section} {heading} "
   211	        f"{noise_tokens}"
   212	    )

   250	def test_spacy_encoder_ignores_calendar_month_may_as_permission_cue() -> None:
   251	    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
   252	    encoding = encoder.encode(
   253	        "The Secretary shall make the payment after May 13, 2002, and a producer may request review.",
   254	        document_id="sample-may-date-literal",
   255	    )
   256	
   257	    may_cues = [cue for cue in encoding.cues if cue.cue.lower() == "may"]
   258	
   259	    assert may_cues
   260	    assert len(may_cues) == 1
   261	    assert may_cues[0].family == "deontic"
   262	    assert any(cue.family == "temporal" and cue.cue.lower() == "after" for cue in encoding.cues)
   263	

   265	def test_spacy_encoder_treats_non_deadline_by_as_non_temporal_cue() -> None:
   266	    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
   267	    encoding = encoder.encode(
   268	        "The Secretary shall provide notice by the Comptroller.",
   269	        document_id="sample-by-non-temporal",

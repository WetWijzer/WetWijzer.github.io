            family_margin = (
                predicted_margin_to_runner_up
                if is_self_pair and predicted_margin_to_runner_up is not None
                else target_share - predicted_share
            )
            if family_margin > threshold:
                continue
            margin_direction = "outvoted" if (
                family_margin < 0.0

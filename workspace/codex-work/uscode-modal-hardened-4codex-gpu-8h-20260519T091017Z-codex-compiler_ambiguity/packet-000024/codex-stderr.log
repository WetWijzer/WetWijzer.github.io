   234	def test_spacy_compiler_extracts_condition_and_exception_slots() -> None:
   235	    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
   236	    encoding = encoder.encode(
   237	        "If the application is complete, the agency must issue written notice unless waived.",
   238	        document_id="sample-condition-exception",
   239	    )
   240	
   241	    modal_ir = SpaCyModalIRCompiler().compile(encoding)
   242	    deontic_formula = next(
   243	        formula for formula in modal_ir.formulas if formula.operator.family == "deontic"
   244	    )
   245	
   246	    assert "if the application is complete" in deontic_formula.conditions
   247	    assert "unless waived" in deontic_formula.exceptions
   248	

    )
    assert (
        adaptive_frame.metadata["lexical_signals"]["has_statutory_scope_reference"]
        is True
    )


def test_modal_codec_caps_repeated_generic_frame_cues_against_deontic_scope() -> None:
    compiler = DeterministicModalCompiler(

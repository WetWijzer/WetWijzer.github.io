   862	def _resolve_modal_family_name(family: ModalLogicFamily | str) -> str:
   863	    if isinstance(family, ModalLogicFamily):
   864	        return family.value
   865	    try:
   866	        return ModalLogicFamily(str(family)).value
   867	    except ValueError:
   868	        return str(family).strip().lower()

   746	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   747	    """Return whether a modal family encodes normative legal force."""
   748	    if isinstance(family, ModalLogicFamily):
   749	        resolved = family
   750	    else:
   751	        try:
   752	            resolved = ModalLogicFamily(str(family))
   753	        except ValueError:
   754	            return False
   755	    return resolved in NORMATIVE_MODAL_FAMILIES

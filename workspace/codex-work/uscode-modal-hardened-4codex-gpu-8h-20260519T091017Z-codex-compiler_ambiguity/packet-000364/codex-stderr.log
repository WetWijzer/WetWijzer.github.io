   714	class ModalRegistry:
   715	    """Lookup table for modal parse profiles."""
   716	
   717	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   718	        self._profiles: Dict[str, ModalParseProfile] = {
   719	            profile.profile_id: profile for profile in profiles
   720	        }
   721	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   722	            profile.family: profile for profile in profiles
   723	        }
   724	
   725	    def get_profile(
   726	        self,
   727	        family: ModalLogicFamily | str,
   728	        system: Optional[ModalSystem | str] = None,
   729	    ) -> ModalParseProfile:
   730	        """Get a profile by family, optionally constrained by system."""
   731	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   732	        if system is None:
   733	            return self._by_family[resolved_family]
   734	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   735	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   736	
   737	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   738	        """Return all profiles in deterministic order."""
   739	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   740	
   741	    def to_dict(self) -> Mapping[str, object]:
   742	        """Return a stable JSON-ready registry mapping."""
   743	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}

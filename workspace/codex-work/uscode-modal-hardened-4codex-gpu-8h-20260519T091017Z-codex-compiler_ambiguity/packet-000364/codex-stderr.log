   506	    def to_dict(self) -> Dict[str, object]:
   507	        """Return a stable JSON-ready mapping."""
   508	        return {
   509	            "description": self.description,
   510	            "family": self.family.value,
   511	            "operators": [
   512	                {
   513	                    "aliases": list(operator.aliases),
   514	                    "allowed_systems": [system.value for system in operator.allowed_systems],
   515	                    "arity": operator.arity,
   516	                    "cue_terms": list(operator.cue_terms),
   517	                    "symbol": operator.symbol,
   518	                }
   519	                for operator in self.operators
   520	            ],
   521	            "profile_id": self.profile_id,
   522	            "semantics": self.semantics.to_dict(),
   523	            "system": self.system.value,
   524	        }

 11402	def _token_overlap_ratio(left: str, right: str) -> float:
 11403	    left_tokens = {
 11404	        token.lower()
 11405	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", left)
 11406	    }
 11407	    right_tokens = {
 11408	        token.lower()
 11409	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", right)
 11410	    }
 11411	    if not left_tokens:
 11412	        return 1.0 if not right_tokens else 0.0
 11413	    return len(left_tokens & right_tokens) / len(left_tokens)


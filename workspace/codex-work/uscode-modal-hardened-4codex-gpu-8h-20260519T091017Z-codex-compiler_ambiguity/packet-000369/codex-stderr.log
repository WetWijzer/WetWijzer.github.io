   462	        if len(ranking) < 2:
   463	            return self._ensure_explicit_adaptive_ambiguities(ambiguities)
   464	
   465	        top, runner_up = ranking[0], ranking[1]
   466	        share_margin = self._ranking_share(top) - self._ranking_share(runner_up)
   467	        if share_margin <= self.config.modal_family_share_margin:
   468	            ambiguities.append(
   469	                ModalCompilationAmbiguity(
   470	                    ambiguity_type="close_modal_family_shares",
   471	                    message="Top modal families are close enough that legal family selection is ambiguous.",
   472	                    candidate_ids=[str(top["family"]), str(runner_up["family"])],
   473	                    metadata={
   474	                        "family_margin": round(share_margin, 6),
   475	                        "family_ranking": ranking,
   476	                        "share_margin": round(share_margin, 6),
   477	                        "top_family": str(top["family"]),
   478	                        "runner_up_family": str(runner_up["family"]),
   479	                    },
   480	                )
   481	            )
   482	
   483	        has_frame_formula = any(
   484	            str(formula.operator.family) == ModalLogicFamily.FRAME.value
   485	            for formula in modal_ir.formulas
   486	        )
   487	        if has_frame_formula:
   488	            frame_share = family_shares.get(ModalLogicFamily.FRAME.value, 0.0)
   489	            best_non_frame = max(
   490	                (
   491	                    candidate
   492	                    for candidate in ranking
   493	                    if str(candidate["family"]) != ModalLogicFamily.FRAME.value
   494	                ),
   495	                key=lambda candidate: (
   496	                    self._ranking_share(candidate),
   497	                    str(candidate["family"]),
   498	                ),
   499	                default=None,
   500	            )
   501	            if best_non_frame is not None:
   502	                competing_family = str(best_non_frame["family"])
   503	                competing_share = self._ranking_share(best_non_frame)
   504	                frame_margin = frame_share - competing_share
   505	                if frame_margin < self.config.modal_primary_family_outvote_margin:
   506	                    ambiguities.append(
   507	                        ModalCompilationAmbiguity(
   508	                            ambiguity_type="frame_modal_family_outvoted",
   509	                            message=(
   510	                                "Cue evidence favors a non-frame modal family over the compiled "
   511	                                "frame interpretation."
   512	                            ),
   513	                            candidate_ids=[ModalLogicFamily.FRAME.value, competing_family],
   514	                            severity="requires_rule",
   515	                            metadata={
   516	                                "competing_family": competing_family,
   517	                                "competing_share": round(competing_share, 6),
   518	                                "family_margin": round(frame_margin, 6),
   519	                                "family_ranking": ranking,
   520	                                "frame_share": round(frame_share, 6),
   521	                                "outvote_margin_threshold": self.config.modal_primary_family_outvote_margin,
   522	                            },
   523	                        )
   524	                    )
   525	                if frame_margin <= self.config.modal_primary_family_margin:
   526	                    ambiguities.append(
   527	                        ModalCompilationAmbiguity(
   528	                            ambiguity_type="low_frame_modal_family_margin",
   529	                            message=(
   530	                                "Frame-family evidence is weak relative to competing modal cues; "
   531	                                "family interpretation requires review."
   532	                            ),
   533	                            candidate_ids=[ModalLogicFamily.FRAME.value, competing_family],
   534	                            metadata={
   535	                                "competing_family": competing_family,
   536	                                "competing_share": round(competing_share, 6),
   537	                                "family_margin": round(frame_margin, 6),
   538	                                "family_ranking": ranking,
   539	                                "frame_share": round(frame_share, 6),
   540	                                "primary_family_margin_threshold": self.config.modal_primary_family_margin,
   541	                            },
   542	                        )
   543	                    )
   544	
   545	        strong_contenders = [
   546	            candidate
   547	            for candidate in ranking
   548	            if self._ranking_share(candidate)
   549	            >= self.config.modal_family_secondary_share_floor
   550	        ]
   551	        contender_families = {
   552	            str(candidate["family"]) for candidate in strong_contenders
   553	        }
   554	        has_temporal = ModalLogicFamily.TEMPORAL.value in contender_families
   555	        has_normative = any(
   556	            is_normative_modal_family(str(candidate["family"]))
   557	            for candidate in strong_contenders
   558	        )
   559	        runner_share = self._ranking_share(runner_up)
   560	        if (
   561	            has_temporal
   562	            and has_normative
   563	            and len(contender_families) > 1
   564	        ):
   565	            ambiguities.append(
   566	                ModalCompilationAmbiguity(
   567	                    ambiguity_type="temporal_normative_overlap",
   568	                    message=(
   569	                        "Temporal scope and normative force both have strong cue evidence; "
   570	                        "family interpretation requires review."
   571	                    ),
   572	                    candidate_ids=sorted(contender_families),
   573	                    metadata={
   574	                        "family_ranking": ranking,
   575	                        "runner_up_share": round(runner_share, 6),
   576	                        "secondary_share_floor": self.config.modal_family_secondary_share_floor,
   577	                    },
   578	                )
   579	            )
   580	        return self._ensure_explicit_adaptive_ambiguities(ambiguities)
   581	
   582	    @staticmethod
   583	    def _adaptive_explicit_ambiguity_key(
   584	        ambiguity: ModalCompilationAmbiguity,
   585	    ) -> tuple[str, tuple[str, ...], str, str]:
   586	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   587	        return (
   588	            str(ambiguity.ambiguity_type),
   589	            tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   590	            str(metadata.get("adaptive_policy_pair") or ""),
   591	            str(metadata.get("adaptive_predicted_family_source") or ""),
   592	        )
   593	
   594	    def _ensure_explicit_adaptive_ambiguities(
   595	        self,
   596	        ambiguities: Sequence[ModalCompilationAmbiguity],
   597	    ) -> List[ModalCompilationAmbiguity]:
   598	        """Backfill explicit adaptive ambiguity variants from base low-margin records."""
   599	        resolved_ambiguities = list(ambiguities)
   600	        existing_explicit_keys = {
   601	            self._adaptive_explicit_ambiguity_key(ambiguity)
   602	            for ambiguity in resolved_ambiguities
   603	            if ambiguity.ambiguity_type.startswith("adaptive_")
   604	            and ambiguity.ambiguity_type != "adaptive_family_margin_low"
   605	        }
   606	        for ambiguity in list(resolved_ambiguities):
   607	            if ambiguity.ambiguity_type != "adaptive_family_margin_low":
   608	                continue
   609	            metadata = (
   610	                ambiguity.metadata
   611	                if isinstance(ambiguity.metadata, dict)
   612	                else {}
   613	            )
   614	            explicit_type = self._derive_explicit_adaptive_ambiguity_type(ambiguity)
   615	            if not explicit_type:
   616	                continue
   617	            explicit_key = (
   618	                explicit_type,
   619	                tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   620	                str(metadata.get("adaptive_policy_pair") or ""),
   621	                str(metadata.get("adaptive_predicted_family_source") or ""),
   622	            )
   623	            if explicit_key in existing_explicit_keys:
   624	                continue
   625	            explicit_message = (
   626	                "Explicit adaptive low-margin ambiguity for the predicted modal "
   627	                "family against close competing families."
   628	                if bool(metadata.get("is_self_pair"))
   629	                else (
   630	                    "Explicit adaptive modal-family conflict between the predicted "
   631	                    "family and a competing legal family."
   632	                )
   633	            )
   634	            resolved_ambiguities.append(
   635	                ModalCompilationAmbiguity(
   636	                    ambiguity_type=explicit_type,
   637	                    message=explicit_message,
   638	                    candidate_ids=list(ambiguity.candidate_ids),
   639	                    severity=ambiguity.severity,
   640	                    metadata={
   641	                        **metadata,
   642	                        "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
   643	                    },
   644	                )
   645	            )
   646	            existing_explicit_keys.add(explicit_key)
   647	        return resolved_ambiguities
   648	
   649	    def _derive_explicit_adaptive_ambiguity_type(
   650	        self,
   651	        ambiguity: ModalCompilationAmbiguity,
   652	    ) -> Optional[str]:
   653	        """Resolve explicit adaptive ambiguity type from base metadata."""
   654	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   655	        explicit_type = str(metadata.get("explicit_ambiguity_type") or "").strip()
   656	        if explicit_type and explicit_type != "adaptive_family_margin_low":
   657	            return explicit_type
   658	
   659	        predicted_family = str(metadata.get("predicted_family") or "").strip()
   660	        target_family = str(metadata.get("target_family") or "").strip()
   661	        if not predicted_family and ambiguity.candidate_ids:
   662	            predicted_family = str(ambiguity.candidate_ids[0]).strip()
   663	        if not target_family and len(ambiguity.candidate_ids) > 1:
   664	            target_family = str(ambiguity.candidate_ids[1]).strip()
   665	
   666	        policy_pair = str(metadata.get("adaptive_policy_pair") or "").strip()
   667	        if "->" in policy_pair:
   668	            policy_predicted, policy_target = policy_pair.split("->", maxsplit=1)
   669	            if not predicted_family:
   670	                predicted_family = policy_predicted.strip()
   671	            if not target_family:
   672	                target_family = policy_target.strip()
   673	
   674	        is_self_pair = bool(metadata.get("is_self_pair")) or (
   675	            len(ambiguity.candidate_ids) == 1
   676	        )
   677	        if is_self_pair and predicted_family and not target_family:
   678	            target_family = predicted_family
   679	        if not predicted_family or not target_family:
   680	            return None
   681	
   682	        margin_direction = str(metadata.get("adaptive_margin_direction") or "").strip().lower()
   683	        if margin_direction not in {"contested", "outvoted"}:
   684	            family_margin = metadata.get("family_margin_raw", metadata.get("family_margin"))
   685	            try:
   686	                margin_direction = "outvoted" if float(family_margin) <= 0.0 else "contested"
   687	            except (TypeError, ValueError):
   688	                margin_direction = "outvoted"
   689	        return self._adaptive_margin_explicit_type(
   690	            predicted_family,
   691	            target_family,
   692	            margin_direction,
   693	        )
   694	
   695	    def _adaptive_family_ranking_from_logits(
   696	        self,
   697	        encoding: SpaCyLegalEncoding,
   698	    ) -> List[Dict[str, float]]:
   699	        """Build fallback family ranking from deterministic decoder logits."""
   700	        modal_families = [family.value for family in ModalLogicFamily]
   701	        logits = self.decoder.family_logits(
   702	            encoding,
   703	            modal_families=modal_families,
   704	        )
   705	        if not logits:
   706	            return []
   707	        max_logit = max(float(value) for value in logits.values())
   708	        exp_by_family = {
   709	            family: math.exp(float(logit) - max_logit)
   710	            for family, logit in logits.items()
   711	        }
   712	        total = sum(exp_by_family.values())
   713	        if total <= 0.0:
   714	            return []
   715	        ranking: List[Dict[str, float]] = []
   716	        for family in sorted(
   717	            exp_by_family,
   718	            key=lambda key: (-exp_by_family[key], key),
   719	        ):
   720	            share_raw = exp_by_family[family] / total
   721	            ranking.append(
   722	                {
   723	                    "family": family,
   724	                    "count": 0,
   725	                    "logit": round(float(logits[family]), 6),
   726	                    "share_raw": share_raw,
   727	                    "share": round(share_raw, 6),
   728	                    "source": "logit_softmax_fallback",
   729	                }
   730	            )
   731	        return ranking
   732	
   733	    def _adaptive_family_margin_ambiguities(
   734	        self,
   735	        encoding: SpaCyLegalEncoding,
   736	        *,
   737	        modal_ir: ModalIRDocument,
   738	        ranking: Sequence[Dict[str, Any]],
   739	        family_shares: Dict[str, float],
   740	        frame_selections: Sequence[FrameSelection] = (),
   741	        predicted_family_source: str = "ranked_modal_families",
   742	    ) -> List[ModalCompilationAmbiguity]:
   743	        """Surface explicit ambiguities when strong legal families compete."""
   744	        if not ranking:
   745	            return []
   746	        predicted_family = str(ranking[0]["family"])
   747	        predicted_share = self._ranking_share(ranking[0])
   748	        runner_up_family: Optional[str] = None
   749	        runner_up_share = 0.0
   750	        predicted_margin_to_runner_up: Optional[float] = None
   751	        if len(ranking) > 1:
   752	            runner_up_family = str(ranking[1]["family"])
   753	            runner_up_share = self._ranking_share(ranking[1])
   754	            predicted_margin_to_runner_up = predicted_share - runner_up_share
   755	        signals = modal_ambiguity_signals(encoding)
   756	        threshold = float(self.config.modal_adaptive_family_margin)
   757	        has_frame_bm25_support = self._has_frame_bm25_support(frame_selections)
   758	        compiled_modal_families = {
   759	            str(formula.operator.family) for formula in modal_ir.formulas
   760	        }
   761	        compiled_primary_family = (
   762	            str(modal_ir.formulas[0].operator.family)
   763	            if modal_ir.formulas
   764	            else None
   765	        )
   766	        has_frame_scope = bool(
   767	            signals.get("has_frame_context")
   768	            or signals.get("has_frame_cue")
   769	            or signals.get("has_statutory_scope_reference")
   770	            or has_frame_bm25_support
   771	        )
   772	        target_signal_by_family = self._adaptive_target_signal_by_family(
   773	            predicted_family,
   774	            signals=signals,
   775	            has_frame_scope=has_frame_scope,
   776	        )
   777	        for policy_target_family in compiler_required_adaptive_ambiguity_targets(
   778	            predicted_family
   779	        ):
   780	            target_signal_by_family.setdefault(policy_target_family, False)
   781	        for policy_target_family in signal_free_adaptive_ambiguity_targets(
   782	            predicted_family
   783	        ):
   784	            target_signal_by_family.setdefault(policy_target_family, False)
   785	        ordered_target_families: List[str] = []
   786	        if target_signal_by_family:
   787	            ordered_target_families = self._ordered_adaptive_target_families(
   788	                predicted_family=predicted_family,
   789	                target_signal_by_family=target_signal_by_family,
   790	            )
   791	        ambiguities: List[ModalCompilationAmbiguity] = []
   792	        for target_family in ordered_target_families:
   793	            has_signal = bool(target_signal_by_family.get(target_family, False))
   794	            is_self_pair = target_family == predicted_family
   795	            runner_up_is_priority_policy_pair = bool(
   796	                is_self_pair
   797	                and runner_up_family is not None
   798	                and is_priority_signal_free_adaptive_ambiguity_pair(
   799	                    predicted_family,
   800	                    runner_up_family,
   801	                )
   802	            )
   803	            runner_up_is_compiler_required_policy_pair = bool(
   804	                is_self_pair
   805	                and runner_up_family is not None
   806	                and is_compiler_required_adaptive_ambiguity_pair(
   807	                    predicted_family,
   808	                    runner_up_family,
   809	                )
   810	            )
   811	            if is_self_pair and (
   812	                predicted_margin_to_runner_up is None
   813	                or not self._adaptive_margin_within_threshold(
   814	                    family_margin=predicted_margin_to_runner_up,
   815	                    threshold=threshold,
   816	                )
   817	            ):
   818	                continue
   819	            target_share = float(family_shares.get(target_family, 0.0))
   820	            has_compiled_target_family_formula = target_family in compiled_modal_families
   821	            has_target_signal_evidence = bool(
   822	                has_signal
   823	                or target_share > 0.0
   824	                or has_compiled_target_family_formula
   825	            )
   826	            supports_signal_free_pair_policy = self._supports_signal_free_adaptive_pair(
   827	                predicted_family,
   828	                target_family,
   829	            )
   830	            is_priority_policy_pair = is_priority_signal_free_adaptive_ambiguity_pair(
   831	                predicted_family,
   832	                target_family,
   833	            ) or runner_up_is_priority_policy_pair
   834	            is_compiler_required_policy_pair = (
   835	                is_compiler_required_adaptive_ambiguity_pair(
   836	                    predicted_family,
   837	                    target_family,
   838	                )
   839	                or runner_up_is_compiler_required_policy_pair
   840	            )
   841	            if (
   842	                not has_target_signal_evidence
   843	                and not supports_signal_free_pair_policy
   844	            ):
   845	                continue
   846	            family_margin = (
   847	                predicted_margin_to_runner_up
   848	                if is_self_pair and predicted_margin_to_runner_up is not None
   849	                else target_share - predicted_share
   850	            )
   851	            if not self._adaptive_margin_within_threshold(
   852	                family_margin=family_margin,
   853	                threshold=threshold,
   854	            ):
   855	                continue
   856	            margin_direction = self._adaptive_margin_direction(
   857	                family_margin=family_margin,
   858	                predicted_family=predicted_family,
   859	                target_family=target_family,
   860	                is_priority_policy_pair=is_priority_policy_pair,
   861	                is_compiler_required_policy_pair=is_compiler_required_policy_pair,
   862	            )
   863	            requires_rule = margin_direction == "outvoted"
   864	            explicit_type = self._adaptive_margin_explicit_type(
   865	                predicted_family,
   866	                target_family,
   867	                margin_direction,
   868	            )
   869	            predicted_share_display = round(predicted_share, 6)
   870	            target_share_display = round(target_share, 6)
   871	            family_margin_display = (
   872	                round(family_margin, 6)
   873	                if is_self_pair
   874	                else round(
   875	                    target_share_display - predicted_share_display,
   876	                    6,
   877	                )
   878	            )
   879	            candidate_ids = (
   880	                [predicted_family]
   881	                if is_self_pair
   882	                else [predicted_family, target_family]
   883	            )
   884	            is_compiler_ambiguity_bundle_pair = is_compiler_ambiguity_policy_pair(
   885	                predicted_family,
   886	                target_family,
   887	            )
   888	            adaptive_priority = self._adaptive_margin_priority(
   889	                family_margin=family_margin,
   890	                threshold=threshold,
   891	            )
   892	            base_metadata = {
   893	                "adaptive_family_margin_threshold": threshold,
   894	                "adaptive_margin_direction": margin_direction,
   895	                "adaptive_margin_abs": abs(family_margin),
   896	                "adaptive_priority": adaptive_priority,
   897	                "priority": adaptive_priority,
   898	                "adaptive_predicted_family_source": predicted_family_source,
   899	                "adaptive_policy_pair": f"{predicted_family}->{target_family}",
   900	                "explicit_ambiguity_type": explicit_type,
   901	                "family_margin_raw": family_margin,
   902	                "family_margin": family_margin_display,
   903	                "family_ranking": list(ranking),
   904	                "compiled_modal_families": sorted(compiled_modal_families),
   905	                "has_target_signal_evidence": has_target_signal_evidence,
   906	                "signal_free_pair_policy_applied": (
   907	                    not has_target_signal_evidence
   908	                    and supports_signal_free_pair_policy
   909	                ),
   910	                "has_compiled_target_family_formula": has_compiled_target_family_formula,
   911	                "has_frame_bm25_support": has_frame_bm25_support,
   912	                "lexical_signals": dict(sorted(signals.items())),
   913	                "is_compiler_required_policy_pair": is_compiler_required_policy_pair,
   914	                "runner_up_is_compiler_required_policy_pair": (
   915	                    runner_up_is_compiler_required_policy_pair
   916	                ),
   917	                "is_priority_policy_pair": is_priority_policy_pair,
   918	                "runner_up_is_priority_policy_pair": runner_up_is_priority_policy_pair,
   919	                "is_compiler_ambiguity_bundle_pair": is_compiler_ambiguity_bundle_pair,
   920	                "ambiguity_policy_bundle": (
   921	                    "compiler_ambiguity"
   922	                    if is_compiler_ambiguity_bundle_pair
   923	                    else None
   924	                ),
   925	                "predicted_family": predicted_family,
   926	                "predicted_margin_to_runner_up_raw": predicted_margin_to_runner_up,
   927	                "predicted_margin_to_runner_up": (
   928	                    round(predicted_margin_to_runner_up, 6)
   929	                    if predicted_margin_to_runner_up is not None
   930	                    else None
   931	                ),
   932	                "runner_up_family": runner_up_family,
   933	                "runner_up_share_raw": (
   934	                    runner_up_share if runner_up_family is not None else None
   935	                ),
   936	                "runner_up_share": (
   937	                    round(runner_up_share, 6)
   938	                    if runner_up_family is not None
   939	                    else None
   940	                ),
   941	                "predicted_share_raw": predicted_share,
   942	                "predicted_share": predicted_share_display,
   943	                "target_family": target_family,
   944	                "target_share_raw": target_share,
   945	                "target_share": target_share_display,
   946	                "is_self_pair": is_self_pair,
   947	            }
   948	            base_message = (
   949	                "A predicted modal family has a low lead over competing legal "
   950	                "families; family selection is ambiguous."
   951	                if is_self_pair
   952	                else (
   953	                    "A dominant modal family outvotes another legal modal family "
   954	                    "despite competing scope/context evidence; family selection is "
   955	                    "ambiguous."
   956	                )
   957	            )
   958	            explicit_message = (
   959	                "Explicit adaptive low-margin ambiguity for the predicted modal "
   960	                "family against close competing families."
   961	                if is_self_pair
   962	                else (
   963	                    "Explicit adaptive modal-family conflict between the predicted "
   964	                    "family and a competing legal family."
   965	                )
   966	            )
   967	            ambiguities.append(
   968	                ModalCompilationAmbiguity(
   969	                    ambiguity_type="adaptive_family_margin_low",
   970	                    message=base_message,
   971	                    candidate_ids=candidate_ids,
   972	                    severity="requires_rule" if requires_rule else "review",
   973	                    metadata=dict(base_metadata),
   974	                )
   975	            )
   976	            ambiguities.append(
   977	                ModalCompilationAmbiguity(
   978	                    ambiguity_type=explicit_type,
   979	                    message=explicit_message,
   980	                    candidate_ids=candidate_ids,
   981	                    severity="requires_rule" if requires_rule else "review",
   982	                    metadata={
   983	                        **base_metadata,
   984	                        "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
   985	                    },
   986	                )
   987	            )
   988	        if (
   989	            compiled_primary_family is not None
   990	            and compiled_primary_family != predicted_family
   991	        ):
   992	            compiled_primary_targets: List[str] = [predicted_family]
   993	            compiled_primary_signal_targets = self._adaptive_target_signal_by_family(
   994	                compiled_primary_family,
   995	                signals=signals,
   996	                has_frame_scope=has_frame_scope,
   997	            )
   998	            for target_family in compiled_primary_signal_targets:

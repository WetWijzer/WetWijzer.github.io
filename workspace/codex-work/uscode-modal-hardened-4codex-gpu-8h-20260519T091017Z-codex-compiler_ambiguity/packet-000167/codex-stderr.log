  1120	        return True
  1121	    lookahead = _lookahead_tokens(tokens, end_char, limit=4)
  1122	    for token in lookahead:
  1123	        normalized = token.normalized().lower()
  1124	        if normalized in _TEMPORAL_SCOPE_TOKENS:
  1125	            return True
  1126	        if normalized in _TEMPORAL_BY_CONTEXT_TOKENS:
  1127	            return True
  1128	        if normalized in _MONTH_NAME_TOKENS:
  1129	            return True
  1130	        if re.fullmatch(r"\d{1,4}", token.text):
  1131	            return True
  1132	    if not lookahead:
  1133	        return False
  1134	    first = lookahead[0].normalized().lower()
  1135	    second = lookahead[1].normalized().lower() if len(lookahead) > 1 else ""
  1136	    if (
  1137	        first in _NON_TEMPORAL_WITHIN_PREFIX_TOKENS
  1138	        and second in _NON_TEMPORAL_WITHIN_CONTEXT_TOKENS
  1139	    ):
  1140	        return False
  1141	    if first in _NON_TEMPORAL_WITHIN_CONTEXT_TOKENS:
  1142	        return False
  1143	    if _NON_TEMPORAL_WITHIN_PHRASE_RE.match(trailing):
  1144	        return False
  1145	    return False

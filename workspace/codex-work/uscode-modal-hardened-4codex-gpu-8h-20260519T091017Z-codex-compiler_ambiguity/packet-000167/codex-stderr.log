  1179	def ranked_modal_families(encoding: SpaCyLegalEncoding) -> List[Dict[str, float]]:
  1180	    """Rank modal families by deterministic cue count and normalized share."""
  1181	    counts = encoding.modal_family_counts()
  1182	    weighted_counts = _weighted_modal_family_counts(encoding)
  1183	    total = sum(float(value) for value in weighted_counts.values())
  1184	    if total <= 0:
  1185	        return []
  1186	    ranking: List[Dict[str, float]] = []
  1187	    for family in sorted(
  1188	        weighted_counts,
  1189	        key=lambda item: (
  1190	            -float(weighted_counts.get(item, 0.0)),
  1191	            item,
  1192	        ),
  1193	    ):
  1194	        share_raw = float(weighted_counts.get(family, 0.0)) / float(total)
  1195	        ranking.append(
  1196	            {
  1197	                "family": family,
  1198	                "count": int(counts.get(family, 0)),
  1199	                "share_raw": share_raw,
  1200	                "share": round(share_raw, 6),
  1201	            }
  1202	        )
  1203	    return ranking

   437	@dataclass(frozen=True)
   438	class ModalParseProfile:
   439	    """Registry entry for one modal parsing profile."""
   440	
   441	    family: ModalLogicFamily
   442	    system: ModalSystem
   443	    operators: Tuple[ModalOperatorSpec, ...]
   444	    semantics: ModalSemanticsSpec = field(default_factory=ModalSemanticsSpec)
   445	    description: str = ""
   446	
   447	    @property
   448	    def profile_id(self) -> str:
   449	        """Stable profile identifier."""
   450	        return f"{self.family.value}:{self.system.value}"
   451	
   452	    def to_dict(self) -> Dict[str, object]:
   453	        """Return a stable JSON-ready mapping."""
   454	        return {
   455	            "description": self.description,
   456	            "family": self.family.value,
   457	            "operators": [
   458	                {
   459	                    "aliases": list(operator.aliases),
   460	                    "allowed_systems": [system.value for system in operator.allowed_systems],
   461	                    "arity": operator.arity,
   462	                    "cue_terms": list(operator.cue_terms),
   463	                    "symbol": operator.symbol,
   464	                }
   465	                for operator in self.operators
   466	            ],
   467	            "profile_id": self.profile_id,
   468	            "semantics": self.semantics.to_dict(),
   469	            "system": self.system.value,
   470	        }

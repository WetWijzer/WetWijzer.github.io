  1164	def _lookahead_tokens(
  1165	    tokens: Sequence[SpaCyTokenFeature],
  1166	    end_char: int,
  1167	    *,
  1168	    limit: int,
  1169	) -> List[SpaCyTokenFeature]:
  1170	    lookahead: List[SpaCyTokenFeature] = []
  1171	    for token in tokens:
  1172	        if token.start_char >= end_char:
  1173	            lookahead.append(token)
  1174	            if len(lookahead) >= limit:
  1175	                break
  1176	    return lookahead

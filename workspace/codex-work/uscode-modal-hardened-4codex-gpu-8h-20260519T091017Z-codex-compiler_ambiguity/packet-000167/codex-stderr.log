   656	class ModalRegistry:
   657	    """Lookup table for modal parse profiles."""
   658	
   659	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   660	        self._profiles: Dict[str, ModalParseProfile] = {
   661	            profile.profile_id: profile for profile in profiles
   662	        }
   663	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   664	            profile.family: profile for profile in profiles
   665	        }
   666	
   667	    def get_profile(
   668	        self,
   669	        family: ModalLogicFamily | str,
   670	        system: Optional[ModalSystem | str] = None,
   671	    ) -> ModalParseProfile:
   672	        """Get a profile by family, optionally constrained by system."""
   673	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   674	        if system is None:
   675	            return self._by_family[resolved_family]
   676	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   677	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   678	
   679	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   680	        """Return all profiles in deterministic order."""
   681	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   682	
   683	    def to_dict(self) -> Mapping[str, object]:
   684	        """Return a stable JSON-ready registry mapping."""
   685	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   686	
   687	
   688	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   689	    """Return whether a modal family encodes normative legal force."""
   690	    if isinstance(family, ModalLogicFamily):
   691	        resolved = family
   692	    else:
   693	        try:
   694	            resolved = ModalLogicFamily(str(family))
   695	        except ValueError:
   696	            return False
   697	    return resolved in NORMATIVE_MODAL_FAMILIES
   698	
   699	
   700	def supports_signal_free_adaptive_ambiguity_pair(
   701	    predicted_family: ModalLogicFamily | str,
   702	    target_family: ModalLogicFamily | str,
   703	) -> bool:
   704	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   705	    resolved_target_family = _resolve_modal_family_name(target_family)
   706	    return (
   707	        resolved_target_family in signal_free_adaptive_ambiguity_targets(
   708	            predicted_family
   709	        )
   710	        or resolved_target_family in compiler_required_adaptive_ambiguity_targets(
   711	            predicted_family
   712	        )
   713	    )
   714	
   715	
   716	def signal_free_adaptive_ambiguity_targets(
   717	    predicted_family: ModalLogicFamily | str,
   718	) -> Tuple[str, ...]:
   719	    """Return ordered adaptive-ambiguity targets requiring signal-free handling."""
   720	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   721	    return tuple(
   722	        target_family
   723	        for source_family, target_family in SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   724	        if source_family == resolved_predicted_family
   725	    )
   726	
   727	
   728	def priority_signal_free_adaptive_ambiguity_targets(
   729	    predicted_family: ModalLogicFamily | str,
   730	) -> Tuple[str, ...]:
   731	    """Return ordered high-priority adaptive-ambiguity targets."""
   732	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   733	    return tuple(
   734	        target_family
   735	        for source_family, target_family in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   736	        if source_family == resolved_predicted_family
   737	    )
   738	
   739	
   740	def compiler_required_adaptive_ambiguity_targets(
   741	    predicted_family: ModalLogicFamily | str,
   742	) -> Tuple[str, ...]:
   743	    """Return ordered compiler-required adaptive ambiguity targets."""
   744	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   745	    return tuple(
   746	        target_family
   747	        for source_family, target_family in COMPILER_REQUIRED_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   748	        if source_family == resolved_predicted_family
   749	    )
   750	
   751	
   752	def is_compiler_required_adaptive_ambiguity_pair(
   753	    predicted_family: ModalLogicFamily | str,
   754	    target_family: ModalLogicFamily | str,
   755	) -> bool:
   756	    """Return whether a pair is in the compiler-required ambiguity policy bundle."""
   757	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   758	    resolved_target_family = _resolve_modal_family_name(target_family)
   759	    return (
   760	        resolved_predicted_family,
   761	        resolved_target_family,
   762	    ) in COMPILER_REQUIRED_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   763	
   764	
   765	def is_priority_signal_free_adaptive_ambiguity_pair(
   766	    predicted_family: ModalLogicFamily | str,
   767	    target_family: ModalLogicFamily | str,
   768	) -> bool:
   769	    """Return whether a pair is part of the highest-priority adaptive ambiguity policy."""
   770	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   771	    resolved_target_family = _resolve_modal_family_name(target_family)
   772	    return (
   773	        resolved_predicted_family,
   774	        resolved_target_family,
   775	    ) in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   776	
   777	
   778	def _resolve_modal_family_name(family: ModalLogicFamily | str) -> str:
   779	    if isinstance(family, ModalLogicFamily):
   780	        return family.value
   781	    try:
   782	        return ModalLogicFamily(str(family)).value
   783	    except ValueError:
   784	        return str(family).strip().lower()

  1103	def _feature_hash(feature: str, dimensions: int) -> tuple[int, float]:
  1104	    digest = hashlib.sha256(feature.encode("utf-8")).digest()
  1105	    slot = int.from_bytes(digest[:4], "big") % dimensions
  1106	    sign = 1.0 if digest[4] % 2 == 0 else -1.0
  1107	    magnitude = 0.5 + (digest[5] / 255.0)
  1108	    return slot, sign * magnitude

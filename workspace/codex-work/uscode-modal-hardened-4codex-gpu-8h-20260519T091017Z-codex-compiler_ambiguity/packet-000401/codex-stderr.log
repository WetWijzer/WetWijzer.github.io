            str(ambiguity.ambiguity_type),
            tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
            str(metadata.get("adaptive_policy_pair") or ""),
            str(metadata.get("adaptive_predicted_family_source") or ""),
        )


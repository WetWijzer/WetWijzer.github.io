   591	    def _ensure_explicit_adaptive_ambiguities(
   592	        self,
   593	        ambiguities: Sequence[ModalCompilationAmbiguity],
   594	    ) -> List[ModalCompilationAmbiguity]:
   595	        """Backfill explicit adaptive ambiguity variants from base low-margin records."""
   596	        resolved_ambiguities = list(ambiguities)
   597	        existing_explicit_keys = {
   598	            self._adaptive_explicit_ambiguity_key(ambiguity)
   599	            for ambiguity in resolved_ambiguities
   600	            if ambiguity.ambiguity_type.startswith("adaptive_")
   601	            and ambiguity.ambiguity_type != "adaptive_family_margin_low"
   602	        }
   603	        for ambiguity in list(resolved_ambiguities):
   604	            if ambiguity.ambiguity_type != "adaptive_family_margin_low":
   605	                continue
   606	            explicit_type = self._derive_explicit_adaptive_ambiguity_type(ambiguity)
   607	            if not explicit_type:
   608	                continue
   609	            explicit_key = (
   610	                explicit_type,
   611	                tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   612	                str(ambiguity.metadata.get("adaptive_policy_pair") or ""),
   613	                str(ambiguity.metadata.get("adaptive_predicted_family_source") or ""),
   614	            )
   615	            if explicit_key in existing_explicit_keys:
   616	                continue
   617	            explicit_message = (
   618	                "Explicit adaptive low-margin ambiguity for the predicted modal "
   619	                "family against close competing families."
   620	                if bool(ambiguity.metadata.get("is_self_pair"))
   621	                else (
   622	                    "Explicit adaptive modal-family conflict between the predicted "
   623	                    "family and a competing legal family."
   624	                )
   625	            )
   626	            resolved_ambiguities.append(
   627	                ModalCompilationAmbiguity(
   628	                    ambiguity_type=explicit_type,
   629	                    message=explicit_message,
   630	                    candidate_ids=list(ambiguity.candidate_ids),
   631	                    severity=ambiguity.severity,
   632	                    metadata={
   633	                        **ambiguity.metadata,
   634	                        "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
   635	                    },
   636	                )
   637	            )
   638	            existing_explicit_keys.add(explicit_key)
   639	        return resolved_ambiguities

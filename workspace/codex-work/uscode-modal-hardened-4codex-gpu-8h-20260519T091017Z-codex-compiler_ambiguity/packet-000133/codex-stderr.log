   687	    def _adaptive_family_ranking_from_logits(
   688	        self,
   689	        encoding: SpaCyLegalEncoding,
   690	    ) -> List[Dict[str, float]]:
   691	        """Build fallback family ranking from deterministic decoder logits."""
   692	        modal_families = [family.value for family in ModalLogicFamily]
   693	        logits = self.decoder.family_logits(
   694	            encoding,
   695	            modal_families=modal_families,
   696	        )
   697	        if not logits:
   698	            return []
   699	        max_logit = max(float(value) for value in logits.values())
   700	        exp_by_family = {
   701	            family: math.exp(float(logit) - max_logit)
   702	            for family, logit in logits.items()
   703	        }
   704	        total = sum(exp_by_family.values())
   705	        if total <= 0.0:
   706	            return []
   707	        ranking: List[Dict[str, float]] = []
   708	        for family in sorted(
   709	            exp_by_family,
   710	            key=lambda key: (-exp_by_family[key], key),
   711	        ):
   712	            share_raw = exp_by_family[family] / total
   713	            ranking.append(
   714	                {
   715	                    "family": family,
   716	                    "count": 0,
   717	                    "logit": round(float(logits[family]), 6),
   718	                    "share_raw": share_raw,
   719	                    "share": round(share_raw, 6),
   720	                    "source": "logit_softmax_fallback",
   721	                }
   722	            )
   723	        return ranking

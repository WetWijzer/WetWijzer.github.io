+def test_compiler_emits_explicit_compiler_required_pairs_for_autoencoder_margins(
+    predicted_family: str,
+    target_family: str,
+    expected_margin: float,
+    expected_priority: float,
+) -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    predicted_share = abs(float(expected_margin))
+    runner_up_family = (
+        ModalLogicFamily.EPISTEMIC.value
+        if ModalLogicFamily.EPISTEMIC.value not in {predicted_family, target_family}
+        else ModalLogicFamily.DYNAMIC.value
+    )
+    runner_up_share = max(0.0, predicted_share - 0.05)
+
+    def _mock_adaptive_family_ranking_from_logits(_encoding):
+        return [
+            {
+                "family": predicted_family,
+                "count": 0,
+                "logit": 1.6,
+                "share_raw": predicted_share,
+                "share": predicted_share,
+                "source": "logit_softmax_fallback",
+            },
+            {
+                "family": runner_up_family,
+                "count": 0,
+                "logit": 1.2,
+                "share_raw": runner_up_share,
+                "share": runner_up_share,
+                "source": "logit_softmax_fallback",
+            },
+        ]
+
+    compiler._adaptive_family_ranking_from_logits = _mock_adaptive_family_ranking_from_logits  # type: ignore[method-assign]
+
+    result = compiler.compile(
+        "The Secretary shall act.",
+        document_id=f"compiler-ambiguity-autoencoder-{predicted_family}-{target_family}",
+    )
+
+    explicit_matches = [
+        ambiguity
+        for ambiguity in result.ambiguities
+        if ambiguity.ambiguity_type.startswith("adaptive_")
+        and ambiguity.ambiguity_type != "adaptive_family_margin_low"
+        and ambiguity.metadata.get("adaptive_predicted_family_source")
+        == "adaptive_logits"
+        and ambiguity.metadata.get("predicted_family") == predicted_family
+        and ambiguity.metadata.get("target_family") == target_family
+    ]
+    assert explicit_matches
+
+    explicit_ambiguity = explicit_matches[0]
+    assert explicit_ambiguity.severity == "requires_rule"
+    assert explicit_ambiguity.metadata.get("adaptive_policy_pair") == (
+        f"{predicted_family}->{target_family}"
+    )
+    assert explicit_ambiguity.metadata.get("is_compiler_required_policy_pair") is True
+    assert explicit_ambiguity.metadata.get("family_margin_raw") == pytest.approx(
+        expected_margin
+    )
+    assert explicit_ambiguity.metadata.get("family_margin") == pytest.approx(
+        round(expected_margin, 6)
+    )
+    assert explicit_ambiguity.metadata.get("priority") == pytest.approx(
+        expected_priority
+    )
+

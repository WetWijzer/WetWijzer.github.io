+            -0.991738583671,
+            1.141738583671,
+        ),
+        (
+            ModalLogicFamily.DEONTIC.value,
+            ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
+            -0.165277862425,
+            0.315277862425,
+        ),
+        (
+            ModalLogicFamily.FRAME.value,
+            ModalLogicFamily.DEONTIC.value,
+            -0.997156465148,
+            1.147156465148,
+        ),
+        (
+            ModalLogicFamily.DEONTIC.value,
+            ModalLogicFamily.TEMPORAL.value,
+            -0.527232618908,
+            0.677232618908,
+        ),
+        (

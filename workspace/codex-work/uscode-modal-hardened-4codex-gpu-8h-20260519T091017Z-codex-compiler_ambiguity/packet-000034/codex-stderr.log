   611	    def _ensure_explicit_adaptive_ambiguities(
   612	        self,
   613	        ambiguities: Sequence[ModalCompilationAmbiguity],
   614	    ) -> List[ModalCompilationAmbiguity]:
   615	        """Backfill explicit adaptive ambiguity variants from base low-margin records."""
   616	        resolved_ambiguities = list(ambiguities)
   617	        existing_explicit_keys = {
   618	            self._adaptive_explicit_ambiguity_key(ambiguity)
   619	            for ambiguity in resolved_ambiguities
   620	            if ambiguity.ambiguity_type.startswith("adaptive_")
   621	            and ambiguity.ambiguity_type != "adaptive_family_margin_low"
   622	        }
   623	        for ambiguity in list(resolved_ambiguities):
   624	            if ambiguity.ambiguity_type != "adaptive_family_margin_low":
   625	                continue
   626	            explicit_type = self._derive_explicit_adaptive_ambiguity_type(ambiguity)
   627	            if not explicit_type:
   628	                continue
   629	            explicit_key = (
   630	                explicit_type,
   631	                tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   632	                str(ambiguity.metadata.get("adaptive_policy_pair") or ""),
   633	                str(ambiguity.metadata.get("adaptive_predicted_family_source") or ""),
   634	            )
   635	            if explicit_key in existing_explicit_keys:
   636	                continue
   637	            explicit_message = (
   638	                "Explicit adaptive low-margin ambiguity for the predicted modal "
   639	                "family against close competing families."
   640	                if bool(ambiguity.metadata.get("is_self_pair"))
   641	                else (
   642	                    "Explicit adaptive modal-family conflict between the predicted "
   643	                    "family and a competing legal family."
   644	                )
   645	            )
   646	            resolved_ambiguities.append(
   647	                ModalCompilationAmbiguity(
   648	                    ambiguity_type=explicit_type,
   649	                    message=explicit_message,
   650	                    candidate_ids=list(ambiguity.candidate_ids),
   651	                    severity=ambiguity.severity,
   652	                    metadata={
   653	                        **ambiguity.metadata,
   654	                        "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
   655	                    },
   656	                )
   657	            )
   658	            existing_explicit_keys.add(explicit_key)
   659	        return resolved_ambiguities

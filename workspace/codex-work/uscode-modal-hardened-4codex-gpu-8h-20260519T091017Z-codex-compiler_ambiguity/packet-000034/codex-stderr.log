   661	    def _derive_explicit_adaptive_ambiguity_type(
   662	        self,
   663	        ambiguity: ModalCompilationAmbiguity,
   664	    ) -> Optional[str]:
   665	        """Resolve explicit adaptive ambiguity type from base metadata."""
   666	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   667	        explicit_type = str(metadata.get("explicit_ambiguity_type") or "").strip()
   668	        if explicit_type and explicit_type != "adaptive_family_margin_low":
   669	            return explicit_type
   670	
   671	        predicted_family = str(metadata.get("predicted_family") or "").strip()
   672	        target_family = str(metadata.get("target_family") or "").strip()
   673	        if not predicted_family and ambiguity.candidate_ids:
   674	            predicted_family = str(ambiguity.candidate_ids[0]).strip()
   675	        if not target_family and len(ambiguity.candidate_ids) > 1:
   676	            target_family = str(ambiguity.candidate_ids[1]).strip()
   677	
   678	        policy_pair = str(metadata.get("adaptive_policy_pair") or "").strip()
   679	        if "->" in policy_pair:
   680	            policy_predicted, policy_target = policy_pair.split("->", maxsplit=1)
   681	            if not predicted_family:
   682	                predicted_family = policy_predicted.strip()
   683	            if not target_family:
   684	                target_family = policy_target.strip()
   685	
   686	        is_self_pair = bool(metadata.get("is_self_pair")) or (
   687	            len(ambiguity.candidate_ids) == 1
   688	        )
   689	        if is_self_pair and predicted_family and not target_family:
   690	            target_family = predicted_family
   691	        if not predicted_family or not target_family:
   692	            return None
   693	
   694	        margin_direction = str(metadata.get("adaptive_margin_direction") or "").strip().lower()
   695	        if margin_direction not in {"contested", "outvoted"}:
   696	            family_margin = metadata.get("family_margin_raw", metadata.get("family_margin"))
   697	            try:
   698	                margin_direction = "outvoted" if float(family_margin) <= 0.0 else "contested"
   699	            except (TypeError, ValueError):
   700	                margin_direction = "outvoted"
   701	        return self._adaptive_margin_explicit_type(
   702	            predicted_family,
   703	            target_family,
   704	            margin_direction,
   705	        )

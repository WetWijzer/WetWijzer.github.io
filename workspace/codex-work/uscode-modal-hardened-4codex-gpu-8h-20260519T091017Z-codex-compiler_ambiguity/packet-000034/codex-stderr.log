  1580	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1581	        """Return deterministic ambiguity priority from policy margin settings.
  1582	
  1583	        For contested low-margin cases (positive margin below threshold), a
  1584	        smaller gap to the threshold carries higher urgency. For outvoted
  1585	        cases (zero/negative margin), severity increases with outvote depth.
  1586	        """

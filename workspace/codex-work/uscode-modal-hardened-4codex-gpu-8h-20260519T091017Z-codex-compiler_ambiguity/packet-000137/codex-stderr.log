1555:    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
1556:        """Return deterministic ambiguity priority from policy margin settings.
1558:        For contested low-margin cases (positive margin below threshold), a
1559:        smaller gap to the threshold carries higher urgency. For outvoted
1560:        cases (zero/negative margin), severity increases with outvote depth.
1562:        resolved_margin = float(family_margin)
1564:        if resolved_margin > 0.0:
1565:            return max(0.0, resolved_threshold - resolved_margin)
1566:        return abs(resolved_margin) + resolved_threshold

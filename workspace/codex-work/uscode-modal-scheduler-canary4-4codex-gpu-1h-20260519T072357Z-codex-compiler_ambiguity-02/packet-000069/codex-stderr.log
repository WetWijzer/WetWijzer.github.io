    def _alethic_scope_target_family_ambiguities(
        self,
        encoding: SpaCyLegalEncoding,
        *,
        ranking: Sequence[Dict[str, Any]],
        family_shares: Dict[str, float],
    ) -> List[ModalCompilationAmbiguity]:
        if not ranking:

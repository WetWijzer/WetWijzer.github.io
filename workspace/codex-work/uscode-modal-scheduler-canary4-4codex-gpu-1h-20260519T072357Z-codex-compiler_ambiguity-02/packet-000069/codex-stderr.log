+                tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
+                str(ambiguity.metadata.get("adaptive_policy_pair") or ""),
+                str(ambiguity.metadata.get("adaptive_predicted_family_source") or ""),

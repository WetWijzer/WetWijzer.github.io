    def _top_family_margin(
        self,
        ranking: Sequence[Dict[str, Any]],
    ) -> Optional[float]:
        """Return top-to-runner-up margin for a ranking sequence."""
        if len(ranking) < 2:
            return None
        return self._ranking_share(ranking[0]) - self._ranking_share(ranking[1])


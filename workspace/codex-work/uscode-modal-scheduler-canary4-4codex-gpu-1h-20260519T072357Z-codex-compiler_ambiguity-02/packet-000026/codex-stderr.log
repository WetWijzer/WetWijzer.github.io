   882	    @staticmethod
   883	    def _ordered_adaptive_target_families(
   884	        *,
   885	        predicted_family: str,
   886	        target_signal_by_family: Mapping[str, bool],
   887	    ) -> List[str]:
   888	        ordered_targets: List[str] = []
   889	        seen_targets: set[str] = set()
   890	        for target_family in priority_signal_free_adaptive_ambiguity_targets(
   891	            predicted_family
   892	        ):
   893	            if (
   894	                target_family in target_signal_by_family
   895	                and target_family not in seen_targets
   896	            ):

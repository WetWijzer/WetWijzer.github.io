   467	    def evaluate(self, samples: Iterable[LegalSample]) -> AutoencoderEvaluation:
   468	        """Evaluate deterministic reconstruction and modal-family losses."""
   469	        sample_list = list(samples)
   470	        if not sample_list:
   471	            return AutoencoderEvaluation(
   472	                sample_count=0,
   473	                embedding_cosine_similarity=0.0,
   474	                cosine_loss=0.0,
   475	                reconstruction_loss=0.0,
   476	                cross_entropy_loss=0.0,
   477	                frame_ranking_loss=0.0,
   478	                symbolic_validity_penalty=0.0,
   479	                decoded_embeddings={},
   480	            )
   481	
   482	        cosine_scores: List[float] = []
   483	        cosine_losses: List[float] = []
   484	        reconstruction_losses: List[float] = []
   485	        ce_losses: List[float] = []
   486	        frame_losses: List[float] = []
   487	        symbolic_penalties: List[float] = []
   488	        decoded_embeddings: Dict[str, List[float]] = {}
   489	
   490	        for sample in sample_list:
   491	            decoded = self.decode(self.encode(sample))
   492	            decoded_embeddings[sample.sample_id] = decoded
   493	            cosine_scores.append(cosine_similarity(sample.embedding_vector, decoded))
   494	            cosine_losses.append(cosine_loss(sample.embedding_vector, decoded))
   495	            reconstruction_losses.append(mse_loss(sample.embedding_vector, decoded))
   496	            ce_losses.append(
   497	                cross_entropy_distribution_loss(
   498	                    self._family_distribution(sample),
   499	                    _observed_family_distribution(sample),
   500	                )
   501	            )
   502	            frame_losses.append(frame_ranking_loss(sample))
   503	            symbolic_penalties.append(symbolic_validity_penalty(sample))
   504	
   505	        return AutoencoderEvaluation(
   506	            sample_count=len(sample_list),
   507	            embedding_cosine_similarity=_mean(cosine_scores),
   508	            cosine_loss=_mean(cosine_losses),
   509	            reconstruction_loss=_mean(reconstruction_losses),
   510	            cross_entropy_loss=_mean(ce_losses),
   511	            frame_ranking_loss=_mean(frame_losses),
   512	            symbolic_validity_penalty=_mean(symbolic_penalties),
   513	            decoded_embeddings=decoded_embeddings,
   514	        )
   515	
   516	    def encode(self, sample: LegalSample) -> Dict[str, object]:
   517	        """Encode sample into a deterministic intermediate representation."""
   518	        return {
   519	            "embedding": list(sample.embedding_vector),
   520	            "families": self._family_distribution(sample),
   521	            "sample_id": sample.sample_id,
   522	            "selected_frame": sample.selected_frame,
   523	        }
   524	
   525	    def decode(self, encoded: Mapping[str, object]) -> List[float]:
   526	        """Decode intermediate representation back to an embedding vector."""
   527	        return [float(value) for value in encoded.get("embedding", [])]  # type: ignore[arg-type]
   528	
   529	    def _target_family(self, sample: LegalSample) -> str:
   530	        return _target_family(sample)
   531	
   532	    def _family_distribution(self, sample: LegalSample) -> Dict[str, float]:
   533	        return _observed_family_distribution(sample)

   473	class ModalRegistry:
   474	    """Lookup table for modal parse profiles."""
   475	
   476	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   477	        self._profiles: Dict[str, ModalParseProfile] = {
   478	            profile.profile_id: profile for profile in profiles
   479	        }
   480	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   481	            profile.family: profile for profile in profiles
   482	        }
   483	
   484	    def get_profile(
   485	        self,
   486	        family: ModalLogicFamily | str,
   487	        system: Optional[ModalSystem | str] = None,
   488	    ) -> ModalParseProfile:
   489	        """Get a profile by family, optionally constrained by system."""
   490	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   491	        if system is None:
   492	            return self._by_family[resolved_family]
   493	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   494	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   495	
   496	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   497	        """Return all profiles in deterministic order."""
   498	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   499	
   500	    def to_dict(self) -> Mapping[str, object]:
   501	        """Return a stable JSON-ready registry mapping."""
   502	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   503	
   504	
   505	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   506	    """Return whether a modal family encodes normative legal force."""
   507	    if isinstance(family, ModalLogicFamily):
   508	        resolved = family
   509	    else:
   510	        try:
   511	            resolved = ModalLogicFamily(str(family))
   512	        except ValueError:
   513	            return False
   514	    return resolved in NORMATIVE_MODAL_FAMILIES
   515	
   516	
   517	def supports_signal_free_adaptive_ambiguity_pair(
   518	    predicted_family: ModalLogicFamily | str,
   519	    target_family: ModalLogicFamily | str,
   520	) -> bool:
   521	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   522	    resolved_target_family = _resolve_modal_family_name(target_family)
   523	    return resolved_target_family in signal_free_adaptive_ambiguity_targets(
   524	        predicted_family
   525	    )
   526	
   527	
   528	def signal_free_adaptive_ambiguity_targets(
   529	    predicted_family: ModalLogicFamily | str,
   530	) -> Tuple[str, ...]:
   531	    """Return ordered adaptive-ambiguity targets requiring signal-free handling."""
   532	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   533	    return tuple(
   534	        target_family
   535	        for source_family, target_family in SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   536	        if source_family == resolved_predicted_family
   537	    )
   538	
   539	
   540	def priority_signal_free_adaptive_ambiguity_targets(
   541	    predicted_family: ModalLogicFamily | str,
   542	) -> Tuple[str, ...]:
   543	    """Return ordered high-priority adaptive-ambiguity targets."""
   544	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   545	    return tuple(
   546	        target_family
   547	        for source_family, target_family in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   548	        if source_family == resolved_predicted_family
   549	    )
   550	
   551	
   552	def is_priority_signal_free_adaptive_ambiguity_pair(
   553	    predicted_family: ModalLogicFamily | str,
   554	    target_family: ModalLogicFamily | str,
   555	) -> bool:
   556	    """Return whether a pair is part of the highest-priority adaptive ambiguity policy."""
   557	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   558	    resolved_target_family = _resolve_modal_family_name(target_family)
   559	    return (
   560	        resolved_predicted_family,
   561	        resolved_target_family,
   562	    ) in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   563	
   564	
   565	def _resolve_modal_family_name(family: ModalLogicFamily | str) -> str:
   566	    if isinstance(family, ModalLogicFamily):
   567	        return family.value
   568	    try:
   569	        return ModalLogicFamily(str(family)).value
   570	    except ValueError:
   571	        return str(family).strip().lower()
   572	

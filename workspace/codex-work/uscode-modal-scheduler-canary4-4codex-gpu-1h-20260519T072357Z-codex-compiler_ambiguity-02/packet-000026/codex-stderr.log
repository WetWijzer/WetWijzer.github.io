   146	def _hint(
   147	    sample_id: str,
   148	    *,
   149	    action: str,
   150	    target_component: str,
   151	    rationale: str,
   152	    priority: float,
   153	    evidence: Mapping[str, Any],
   154	) -> ModalProgramSynthesisHint:
   155	    evidence_dict = dict(evidence)
   156	    evidence_dict.setdefault("sample_id", sample_id)
   157	    payload = {
   158	        "action": action,
   159	        "evidence": evidence_dict,
   160	        "sample_id": sample_id,
   161	        "target_component": target_component,
   162	    }
   163	    digest = hashlib.sha256(
   164	        json.dumps(payload, ensure_ascii=True, sort_keys=True).encode("utf-8")
   165	    ).hexdigest()[:16]
   166	    return ModalProgramSynthesisHint(
   167	        hint_id=f"modal-synthesis-{digest}",
   168	        action=action,
   169	        target_component=target_component,
   170	        rationale=rationale,
   171	        priority=round(max(0.0, float(priority)), 12),
   172	        evidence=evidence_dict,
   173	    )
   174	

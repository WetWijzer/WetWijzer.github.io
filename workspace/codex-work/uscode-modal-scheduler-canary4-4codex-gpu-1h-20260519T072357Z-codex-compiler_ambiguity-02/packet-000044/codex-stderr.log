   596	    def _adaptive_family_ranking_from_logits(
   597	        self,
   598	        encoding: SpaCyLegalEncoding,
   599	    ) -> List[Dict[str, float]]:
   600	        """Build fallback family ranking from deterministic decoder logits."""
   601	        modal_families = [family.value for family in ModalLogicFamily]
   602	        logits = self.decoder.family_logits(
   603	            encoding,
   604	            modal_families=modal_families,
   605	        )
   606	        if not logits:
   607	            return []
   608	        max_logit = max(float(value) for value in logits.values())
   609	        exp_by_family = {
   610	            family: math.exp(float(logit) - max_logit)
   611	            for family, logit in logits.items()
   612	        }
   613	        total = sum(exp_by_family.values())
   614	        if total <= 0.0:
   615	            return []
   616	        ranking: List[Dict[str, float]] = []
   617	        for family in sorted(
   618	            exp_by_family,
   619	            key=lambda key: (-exp_by_family[key], key),
   620	        ):
   621	            share_raw = exp_by_family[family] / total
   622	            ranking.append(
   623	                {
   624	                    "family": family,
   625	                    "count": 0,
   626	                    "logit": round(float(logits[family]), 6),
   627	                    "share_raw": share_raw,
   628	                    "share": round(share_raw, 6),
   629	                    "source": "logit_softmax_fallback",
   630	                }
   631	            )
   632	        return ranking

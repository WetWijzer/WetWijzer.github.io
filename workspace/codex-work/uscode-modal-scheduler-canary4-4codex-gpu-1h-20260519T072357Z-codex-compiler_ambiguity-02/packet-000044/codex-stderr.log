   890	    @staticmethod
   891	    def _ordered_adaptive_target_families(
   892	        *,
   893	        predicted_family: str,
   894	        target_signal_by_family: Mapping[str, bool],
   895	    ) -> List[str]:
   896	        ordered_targets: List[str] = []
   897	        seen_targets: set[str] = set()
   898	        for target_family in priority_signal_free_adaptive_ambiguity_targets(
   899	            predicted_family
   900	        ):
   901	            if (
   902	                target_family in target_signal_by_family
   903	                and target_family not in seen_targets
   904	            ):
   905	                ordered_targets.append(target_family)
   906	                seen_targets.add(target_family)
   907	        for target_family in target_signal_by_family:
   908	            if target_family not in seen_targets:
   909	                ordered_targets.append(target_family)
   910	                seen_targets.add(target_family)
   911	        return ordered_targets

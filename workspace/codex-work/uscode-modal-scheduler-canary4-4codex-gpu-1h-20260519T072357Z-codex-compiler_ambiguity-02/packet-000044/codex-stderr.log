   580	                ModalCompilationAmbiguity(
   581	                    ambiguity_type="temporal_normative_overlap",
   582	                    message=(
   583	                        "Temporal scope and normative force both have strong cue evidence; "
   584	                        "family interpretation requires review."
   585	                    ),
   586	                    candidate_ids=sorted(contender_families),
   587	                    metadata={

   284	    def _family_ambiguities(
   285	        self,
   286	        encoding: SpaCyLegalEncoding,
   287	        *,
   288	        modal_ir: ModalIRDocument,
   289	        frame_selections: Sequence[FrameSelection] = (),
   290	    ) -> List[ModalCompilationAmbiguity]:
   291	        ranking = ranked_modal_families(encoding)
   292	        if not ranking:
   293	            if not encoding.normalized_text:
   294	                return []
   295	            adaptive_ranking = self._adaptive_family_ranking_from_logits(encoding)
   296	            if not adaptive_ranking:
   297	                return []
   298	            adaptive_family_shares = {
   299	                str(candidate["family"]): self._ranking_share(candidate)
   300	                for candidate in adaptive_ranking
   301	            }
   302	            return self._adaptive_family_margin_ambiguities(
   303	                encoding,
   304	                modal_ir=modal_ir,
   305	                ranking=adaptive_ranking,
   306	                family_shares=adaptive_family_shares,
   307	                frame_selections=frame_selections,
   308	                predicted_family_source="adaptive_logits_fallback",
   309	            )
   310	
   311	        ambiguities: List[ModalCompilationAmbiguity] = []
   312	        family_shares = {
   313	            str(candidate["family"]): self._ranking_share(candidate)
   314	            for candidate in ranking
   315	        }
   316	        if modal_ir.formulas:

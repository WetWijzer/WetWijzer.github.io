  1157	    @staticmethod
  1158	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1159	        """Return deterministic ambiguity priority from policy margin settings.
  1160	
  1161	        For contested low-margin cases (positive margin below threshold), a
  1162	        smaller gap to the threshold carries higher urgency. For outvoted
  1163	        cases (zero/negative margin), severity increases with outvote depth.
  1164	        """
  1165	        resolved_margin = float(family_margin)
  1166	        resolved_threshold = max(0.0, float(threshold))
  1167	        if resolved_margin > 0.0:
  1168	            return max(0.0, resolved_threshold - resolved_margin)
  1169	        return abs(resolved_margin) + resolved_threshold

   533	                                "family_ranking": ranking,
   534	                                "frame_share": round(frame_share, 6),
   535	                                "outvote_margin_threshold": self.config.modal_primary_family_outvote_margin,
   536	                            },
   537	                        )
   538	                    )
   539	                if frame_margin <= self.config.modal_primary_family_margin:
   540	                    ambiguities.append(
   541	                        ModalCompilationAmbiguity(
   542	                            ambiguity_type="low_frame_modal_family_margin",
   543	                            message=(
   544	                                "Frame-family evidence is weak relative to competing modal cues; "
   545	                                "family interpretation requires review."
   546	                            ),
   547	                            candidate_ids=[ModalLogicFamily.FRAME.value, competing_family],
   548	                            metadata={
   549	                                "competing_family": competing_family,
   550	                                "competing_share": round(competing_share, 6),
   551	                                "family_margin": round(frame_margin, 6),
   552	                                "family_ranking": ranking,
   553	                                "frame_share": round(frame_share, 6),
   554	                                "primary_family_margin_threshold": self.config.modal_primary_family_margin,
   555	                            },
   556	                        )
   557	                    )
   558	
   559	        strong_contenders = [
   560	            candidate

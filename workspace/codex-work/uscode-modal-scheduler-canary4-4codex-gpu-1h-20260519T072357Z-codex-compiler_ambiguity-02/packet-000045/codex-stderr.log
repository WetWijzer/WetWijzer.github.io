   108	class DeterministicModalCompiler:
   109	    """Compile legal text into modal IR with explainable frame selection."""
   110	
   111	    def __init__(
   112	        self,
   113	        config: Optional[ModalCompilerConfig] = None,
   114	        *,
   115	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
   116	        frame_selector: Optional[BM25FrameSelector] = None,
   117	    ) -> None:
   118	        self.config = config or ModalCompilerConfig()
   119	        self.registry = registry
   120	        self.parser = LegalModalParser(registry=registry)
   121	        self.encoder = SpaCyLegalEncoder(
   122	            model_name=self.config.spacy_model_name,
   123	            registry=registry,
   124	        )
   125	        self.decoder = SpaCyModalDecoder()
   126	        self.ir_compiler = SpaCyModalIRCompiler()
   127	        self.frame_selector = frame_selector or BM25FrameSelector(DEFAULT_LEGAL_FRAME_FIXTURE)
   128	
   129	    def compile(
   130	        self,
   131	        text: str,
   132	        *,
   133	        document_id: Optional[str] = None,
   134	        citation: Optional[str] = None,
   135	        source: str = "legal_text",
   136	    ) -> ModalCompilationResult:
   137	        """Compile text into modal IR using deterministic rules only."""
   138	        normalized_text = self.parser.normalize_text(text)
   139	        backend = self.config.parser_backend.lower().strip()
   140	        encoding: Optional[SpaCyLegalEncoding] = self.encoder.encode(
   141	            text,
   142	            document_id=document_id,
   143	            citation=citation,
   144	            source=source,
   145	        )
   146	        if backend in {"regex", "legal", "legal_modal_parser", "deontic", "deontic:d"}:
   147	            modal_ir = self.parser.parse(
   148	                text,
   149	                document_id=document_id or encoding.document_id,
   150	                citation=citation,
   151	                source=source,
   152	            )
   153	            parser_name = "legal_modal_parser_v1"
   154	        else:
   155	            modal_ir = self.ir_compiler.compile(encoding)
   156	            parser_name = "spacy_modal_codec_v1"
   157	
   158	        frame_selections = self.frame_selector.rank(
   159	            normalized_text,
   160	            top_k=self.config.top_k_frames,
   161	            domain=self.config.frame_domain,
   162	        )
   163	        frame_candidates = [selection.to_dict() for selection in frame_selections]
   164	        selected_frame = str(frame_candidates[0]["frame_id"]) if frame_candidates else None
   165	        ambiguities = [
   166	            *self._formula_ambiguities(modal_ir),
   167	            *self._family_ambiguities(
   168	                encoding,
   169	                modal_ir=modal_ir,
   170	                frame_selections=frame_selections,
   171	            ),
   172	            *self._frame_ambiguities(frame_selections),
   173	        ]
   174	        if normalized_text and not modal_ir.formulas:
   175	            ambiguities.append(
   176	                ModalCompilationAmbiguity(
   177	                    ambiguity_type="missing_modal_formula",
   178	                    message="No deterministic modal formula was produced for non-empty text.",
   179	                    severity="requires_rule",
   180	                )
   181	            )
   182	
   183	        modal_ir = self._attach_metadata(
   184	            modal_ir,
   185	            frame_selections,
   186	            parser_name=parser_name,
   187	            selected_frame=selected_frame,
   188	            ambiguity_count=len(ambiguities),
   189	            encoding=encoding,
   190	        )
   191	        return ModalCompilationResult(
   192	            modal_ir=modal_ir,
   193	            parser_name=parser_name,
   194	            normalized_text=normalized_text,
   195	            frame_candidates=frame_candidates,
   196	            selected_frame=selected_frame,
   197	            ambiguities=ambiguities,
   198	            encoding=encoding,
   199	            metadata={
   200	                "ambiguity_count": len(ambiguities),
   201	                "deterministic_compiler": "modal_compiler_v1",
   202	                "frame_selector": "bm25_v1",
   203	                "llm_call_count": 0,
   204	                "parser_backend": self.config.parser_backend,
   205	            },
   206	        )
   207	
   208	    def _attach_metadata(
   209	        self,
   210	        modal_ir: ModalIRDocument,
   211	        frame_selections: Sequence[FrameSelection],
   212	        *,
   213	        parser_name: str,
   214	        selected_frame: Optional[str],
   215	        ambiguity_count: int,
   216	        encoding: SpaCyLegalEncoding,
   217	    ) -> ModalIRDocument:
   218	        frame_candidates = [
   219	            ModalIRFrame(
   220	                frame_id=selection.frame.frame_id,
   221	                score=selection.score,
   222	                matched_terms=list(selection.matched_terms),
   223	                explanation=selection.explanation,
   224	            )
   225	            for selection in frame_selections
   226	        ]
   227	        metadata = {
   228	            **modal_ir.metadata,
   229	            "ambiguity_count": ambiguity_count,
   230	            "deterministic_compiler": "modal_compiler_v1",
   231	            "deterministic_parser": parser_name,
   232	            "frame_selector": "bm25_v1",
   233	            "llm_call_count": 0,
   234	            "modal_family_counts": encoding.modal_family_counts(),
   235	            "selected_frame": selected_frame,
   236	        }
   237	        return replace(modal_ir, frame_candidates=frame_candidates, metadata=metadata)
   238	
   239	    def _formula_ambiguities(
   240	        self,
   241	        modal_ir: ModalIRDocument,
   242	    ) -> List[ModalCompilationAmbiguity]:
   243	        by_span: Dict[tuple[int, int], List[str]] = {}
   244	        for formula in modal_ir.formulas:
   245	            span = (formula.provenance.start_char, formula.provenance.end_char)
   246	            candidate = (
   247	                f"{formula.formula_id}:{formula.operator.family}:"
   248	                f"{formula.operator.system}:{formula.operator.symbol}"
   249	            )
   250	            by_span.setdefault(span, []).append(candidate)
   251	
   252	        ambiguities: List[ModalCompilationAmbiguity] = []
   253	        for span, candidates in sorted(by_span.items()):
   254	            families = {candidate.split(":")[1] for candidate in candidates}
   255	            if len(candidates) > 1 and len(families) > 1:
   256	                ambiguities.append(
   257	                    ModalCompilationAmbiguity(
   258	                        ambiguity_type="multi_family_same_span",
   259	                        message="Multiple modal families were compiled from the same text span.",
   260	                        candidate_ids=sorted(candidates),
   261	                        metadata={"span": list(span)},
   262	                    )
   263	                )
   264	        return ambiguities
   265	
   266	    @staticmethod
   267	    def _ranking_share(candidate: Dict[str, Any]) -> float:
   268	        """Return share value, preferring unrounded values when present."""
   269	        raw_share = candidate.get("share_raw", candidate.get("share", 0.0))
   270	        try:
   271	            return float(raw_share)
   272	        except (TypeError, ValueError):
   273	            return 0.0
   274	
   275	    def _top_family_margin(
   276	        self,
   277	        ranking: Sequence[Dict[str, Any]],
   278	    ) -> Optional[float]:
   279	        """Return top-to-runner-up margin for a ranking sequence."""
   280	        if len(ranking) < 2:
   281	            return None
   282	        return self._ranking_share(ranking[0]) - self._ranking_share(ranking[1])

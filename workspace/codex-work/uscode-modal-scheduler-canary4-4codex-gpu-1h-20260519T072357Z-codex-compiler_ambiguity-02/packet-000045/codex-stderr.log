   596	    def _adaptive_family_ranking_from_logits(
   597	        self,
   598	        encoding: SpaCyLegalEncoding,
   599	    ) -> List[Dict[str, float]]:
   600	        """Build fallback family ranking from deterministic decoder logits."""
   601	        modal_families = [family.value for family in ModalLogicFamily]
   602	        logits = self.decoder.family_logits(
   603	            encoding,
   604	            modal_families=modal_families,
   605	        )
   606	        if not logits:
   607	            return []
   608	        max_logit = max(float(value) for value in logits.values())

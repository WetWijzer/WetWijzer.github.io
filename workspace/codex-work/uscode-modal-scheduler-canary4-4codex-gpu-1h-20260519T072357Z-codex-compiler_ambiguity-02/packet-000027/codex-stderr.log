            return []
        max_logit = max(float(value) for value in logits.values())
        exp_by_family = {
            family: math.exp(float(logit) - max_logit)
            for family, logit in logits.items()
        }
        total = sum(exp_by_family.values())
        if total <= 0.0:
            return []

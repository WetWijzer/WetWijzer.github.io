                "adaptive",
                predicted_family,
                target_family,
                margin_direction,
                "margin_low",
            )
        )

    @staticmethod
    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
        """Return deterministic ambiguity priority from policy margin settings."""
        return abs(float(family_margin)) + max(0.0, float(threshold))


        by_span: Dict[tuple[int, int], List[str]] = {}
        for formula in modal_ir.formulas:
            span = (formula.provenance.start_char, formula.provenance.end_char)
            candidate = (
                f"{formula.formula_id}:{formula.operator.family}:"

+def test_spacy_codec_backfills_deontic_share_for_conditional_statutory_scope_without_deontic_cues() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="11",
+        section="547",
+        text=(
+            "Notwithstanding subsection (b), prohibition on denial of access applies "
+            "under this section."
+        ),
+    )
+
+    ranking = ranked_modal_families(codec.encode_sample(sample))
+    shares = {str(item["family"]): float(item["share"]) for item in ranking}
+
+    assert ranking[0]["family"] == "conditional_normative"
+    assert shares["deontic"] > 0.0
+    assert shares["deontic"] < shares["conditional_normative"]
+

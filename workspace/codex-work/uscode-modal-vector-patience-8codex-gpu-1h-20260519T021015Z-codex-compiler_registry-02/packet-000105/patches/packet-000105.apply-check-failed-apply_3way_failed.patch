+def test_spacy_codec_strengthens_temporal_backfill_for_generic_frame_calendar_scope() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="42",
+        section="321d",
+        text=(
+            "This authority applies for the period beginning on January 1, 2030 "
+            "and ending on December 31, 2030."
+        ),
+    )
+    ranking = ranked_modal_families(codec.encode_sample(sample))
+    temporal_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "temporal"
+    )
+    frame_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "frame"
+    )
+
+    assert frame_share > temporal_share
+    assert temporal_share >= 0.35
+
+

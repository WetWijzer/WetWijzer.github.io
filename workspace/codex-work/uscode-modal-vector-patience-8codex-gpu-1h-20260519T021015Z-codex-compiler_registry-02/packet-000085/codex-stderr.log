   457	class ModalRegistry:
   458	    """Lookup table for modal parse profiles."""
   459	
   460	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   461	        self._profiles: Dict[str, ModalParseProfile] = {
   462	            profile.profile_id: profile for profile in profiles
   463	        }
   464	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   465	            profile.family: profile for profile in profiles
   466	        }
   467	
   468	    def get_profile(
   469	        self,
   470	        family: ModalLogicFamily | str,
   471	        system: Optional[ModalSystem | str] = None,
   472	    ) -> ModalParseProfile:
   473	        """Get a profile by family, optionally constrained by system."""
   474	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   475	        if system is None:
   476	            return self._by_family[resolved_family]
   477	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   478	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   479	
   480	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   481	        """Return all profiles in deterministic order."""
   482	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   483	
   484	    def to_dict(self) -> Mapping[str, object]:
   485	        """Return a stable JSON-ready registry mapping."""
   486	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   487	
   488	
   489	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   490	    """Return whether a modal family encodes normative legal force."""
   491	    if isinstance(family, ModalLogicFamily):
   492	        resolved = family
   493	    else:
   494	        try:
   495	            resolved = ModalLogicFamily(str(family))
   496	        except ValueError:
   497	            return False
   498	    return resolved in NORMATIVE_MODAL_FAMILIES
   499	
   500	
   501	def supports_signal_free_adaptive_ambiguity_pair(
   502	    predicted_family: ModalLogicFamily | str,
   503	    target_family: ModalLogicFamily | str,
   504	) -> bool:
   505	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   506	    resolved_target_family = _resolve_modal_family_name(target_family)
   507	    return resolved_target_family in signal_free_adaptive_ambiguity_targets(
   508	        predicted_family
   509	    )
   510	
   511	
   512	def signal_free_adaptive_ambiguity_targets(
   513	    predicted_family: ModalLogicFamily | str,
   514	) -> Tuple[str, ...]:
   515	    """Return ordered adaptive-ambiguity targets requiring signal-free handling."""
   516	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   517	    return tuple(
   518	        target_family
   519	        for source_family, target_family in SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   520	        if source_family == resolved_predicted_family
   521	    )
   522	
   523	
   524	def is_priority_signal_free_adaptive_ambiguity_pair(
   525	    predicted_family: ModalLogicFamily | str,
   526	    target_family: ModalLogicFamily | str,
   527	) -> bool:
   528	    """Return whether a pair is part of the highest-priority adaptive ambiguity policy."""
   529	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   530	    resolved_target_family = _resolve_modal_family_name(target_family)
   531	    return (
   532	        resolved_predicted_family,
   533	        resolved_target_family,
   534	    ) in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   535	
   536	
   537	def _resolve_modal_family_name(family: ModalLogicFamily | str) -> str:
   538	    if isinstance(family, ModalLogicFamily):
   539	        return family.value
   540	    try:
   541	        return ModalLogicFamily(str(family)).value
   542	    except ValueError:
   543	        return str(family).strip().lower()

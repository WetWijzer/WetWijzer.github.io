  1154	def _overlap_aware_modal_family_counts(
  1155	    encoding: SpaCyLegalEncoding,
  1156	) -> Dict[str, float]:
  1157	    """Count family cues while collapsing nested same-family cue spans."""
  1158	    spans_by_family: Dict[str, List[tuple[int, int]]] = {}
  1159	    for cue in encoding.cues:
  1160	        start = int(cue.start_char)
  1161	        end = int(cue.end_char)
  1162	        if start < 0 or end <= start:
  1163	            continue
  1164	        spans_by_family.setdefault(cue.family, []).append((start, end))
  1165	
  1166	    counts: Dict[str, float] = {}
  1167	    for family, spans in spans_by_family.items():
  1168	        if not spans:
  1169	            continue
  1170	        unique_spans = sorted(set(spans))
  1171	        effective_spans: List[tuple[int, int]] = []
  1172	        for start, end in unique_spans:
  1173	            span_len = end - start
  1174	            covered_by_larger_span = False
  1175	            for other_start, other_end in unique_spans:
  1176	                if other_start == start and other_end == end:
  1177	                    continue
  1178	                other_len = other_end - other_start
  1179	                if (
  1180	                    other_start <= start
  1181	                    and other_end >= end
  1182	                    and other_len > span_len
  1183	                ):
  1184	                    covered_by_larger_span = True
  1185	                    break
  1186	            if not covered_by_larger_span:
  1187	                effective_spans.append((start, end))
  1188	        counts[family] = float(len(effective_spans))
  1189	    return counts

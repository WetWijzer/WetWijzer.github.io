  1351	        or bool(signals.get("has_temporal_within_scope"))
  1352	    ):
  1353	        temporal_bonus += 0.3
  1354	    if temporal_bonus > 0.0:
  1355	        boosts[ModalLogicFamily.TEMPORAL.value] = temporal_bonus
  1356	    dynamic_bonus = 0.0
  1357	    if bool(signals.get("has_dynamic_scope_phrase")):

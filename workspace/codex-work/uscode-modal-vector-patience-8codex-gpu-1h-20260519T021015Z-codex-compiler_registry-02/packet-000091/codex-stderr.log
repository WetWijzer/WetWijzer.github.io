   788	        return SpaCyModalCueFeature(
   789	            family=profile.family.value,
   790	            system=profile.system.value,
   791	            symbol=operator.symbol,
   792	            label=operator.aliases[0] if operator.aliases else operator.symbol,
   793	            cue=cue,
   794	            start_char=start_char,
   795	            end_char=end_char,
   796	            token_indices=list(token_indices),
   797	        )

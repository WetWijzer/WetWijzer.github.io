   882	class SpaCyModalDecoder:
   883	    """Decode spaCy/IR features into deterministic embedding-like vectors."""
   884	
   885	    def decode_embedding(self, encoding: SpaCyLegalEncoding, *, dimensions: int = 8) -> List[float]:
   886	        if dimensions < 1:
   887	            raise ValueError("dimensions must be >= 1")
   888	        vector = [0.0 for _ in range(dimensions)]
   889	        for feature in self._feature_stream(encoding):
   890	            slot, value = _feature_hash(feature, dimensions)
   891	            vector[slot] += value
   892	        norm = math.sqrt(sum(value * value for value in vector))
   893	        if norm == 0.0:
   894	            return vector
   895	        return [round(value / norm, 6) for value in vector]

    87	
    88	def build_us_code_sample(
    89	    *,
    90	    title: str,
    91	    section: str,
    92	    text: str,
    93	    citation: Optional[str] = None,
    94	    embedding_model: str = "mock:stable-sha256",
    95	    embedding_vector: Optional[Sequence[float]] = None,
    96	    parser: Optional[LegalModalParser] = None,
    97	    frame_selector: Optional[BM25FrameSelector] = None,
    98	    top_k_frames: int = 3,
    99	) -> LegalSample:
   100	    """Build a deterministic U.S. Code-style sample."""
   101	    resolved_citation = citation or f"{title} U.S.C. {section}"
   102	    resolved_parser = parser or LegalModalParser()
   103	    normalized_text = resolved_parser.normalize_text(text)
   104	    sample_id = _sample_id(title, section, normalized_text)
   105	    modal_ir = resolved_parser.parse(
   106	        text,
   107	        document_id=sample_id,
   108	        source="us_code",
   109	        citation=resolved_citation,
   110	    )
   111	    selector = frame_selector or BM25FrameSelector(DEFAULT_LEGAL_FRAME_FIXTURE)
   112	    frames = [selection.to_dict() for selection in selector.rank(normalized_text, top_k=top_k_frames)]
   113	    selected_frame = str(frames[0]["frame_id"]) if frames else None
   114	    sample = LegalSample(
   115	        sample_id=sample_id,
   116	        source="us_code",
   117	        title=title,
   118	        section=section,
   119	        citation=resolved_citation,
   120	        text=text,
   121	        normalized_text=normalized_text,
   122	        embedding_model=embedding_model,
   123	        embedding_vector=list(embedding_vector) if embedding_vector is not None else stable_mock_embedding(normalized_text),
   124	        modal_ir=modal_ir,
   125	        frame_candidates=frames,
   126	        selected_frame=selected_frame,
   127	        parser_trace={
   128	            "deterministic_parser": "legal_modal_parser_v1",
   129	            "frame_selector": "bm25_v1",
   130	            "top_k_frames": top_k_frames,
   131	        },
   132	    )
   133	    sample.validate()
   134	    return sample
   135	
   136	
   137	def _sample_id(title: str, section: str, normalized_text: str) -> str:
   138	    digest = hashlib.sha256(f"{title}:{section}:{normalized_text}".encode("utf-8")).hexdigest()[:16]
   139	    return f"us-code-{title}-{section}-{digest}"
   140	

   540	class SpaCyLegalEncoder:
   541	    """Encode legal text using spaCy tokens plus deterministic modal cues."""
   542	
   543	    def __init__(
   544	        self,
   545	        *,
   546	        model_name: str = "en_core_web_sm",
   547	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
   548	    ) -> None:
   549	        self.model_name = model_name
   550	        self.registry = registry
   551	        self.nlp, self.used_fallback_model = self._load_nlp(model_name)
   552	
   553	    def encode(
   554	        self,
   555	        text: str,
   556	        *,
   557	        document_id: Optional[str] = None,
   558	        citation: Optional[str] = None,
   559	        source: str = "legal_text",
   560	    ) -> SpaCyLegalEncoding:
   561	        normalized = _normalize(text)
   562	        resolved_document_id = document_id or _document_id(normalized)
   563	        doc = self.nlp(normalized)
   564	        tokens = [
   565	            SpaCyTokenFeature(
   566	                text=token.text,
   567	                lemma=(token.lemma_ or token.lower_).lower(),
   568	                lower=token.lower_,
   569	                pos=token.pos_,
   570	                dep=token.dep_,
   571	                start_char=token.idx,
   572	                end_char=token.idx + len(token.text),
   573	                is_stop=bool(token.is_stop),
   574	                is_alpha=bool(token.is_alpha),
   575	            )
   576	            for token in doc
   577	        ]
   578	        sentences = [
   579	            SpaCySentenceFeature(
   580	                text=sent.text,
   581	                start_char=sent.start_char,
   582	                end_char=sent.end_char,
   583	            )
   584	            for sent in doc.sents
   585	        ]
   586	        if not sentences and normalized:
   587	            sentences = [SpaCySentenceFeature(text=normalized, start_char=0, end_char=len(normalized))]
   588	        return SpaCyLegalEncoding(
   589	            document_id=resolved_document_id,
   590	            text=text,
   591	            normalized_text=normalized,
   592	            tokens=tokens,
   593	            sentences=sentences,
   594	            cues=self._extract_cues(normalized, tokens),
   595	            citation=citation,
   596	            source=source,
   597	            model_name=self.model_name,
   598	            used_fallback_model=self.used_fallback_model,
   599	        )

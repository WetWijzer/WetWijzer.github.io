  1011	def _feature_hash(feature: str, dimensions: int) -> tuple[int, float]:
  1012	    digest = hashlib.sha256(feature.encode("utf-8")).digest()
  1013	    slot = int.from_bytes(digest[:4], "big") % dimensions
  1014	    sign = 1.0 if digest[4] % 2 == 0 else -1.0
  1015	    magnitude = 0.5 + (digest[5] / 255.0)
  1016	    return slot, sign * magnitude

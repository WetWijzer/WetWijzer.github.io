   671	    def _is_calendar_month_may_cue(
   672	        self,
   673	        *,
   674	        normalized_text: str,
   675	        cue: str,
   676	        start_char: int,
   677	        end_char: int,
   678	    ) -> bool:
   679	        """Treat `May 13, 2002` date literals as temporal context, not deontic permission."""
   680	        if cue.lower() != "may":
   681	            return False
   682	        if start_char > 0 and normalized_text[start_char - 1].isalnum():
   683	            return False
   684	        trailing = normalized_text[end_char:]
   685	        return bool(re.match(r"^\s+\d{1,2}(?:,\s*|\s+)\d{4}\b", trailing))
   686	
   687	    def _is_temporal_deadline_by_cue(
   688	        self,
   689	        *,
   690	        normalized_text: str,
   691	        tokens: Sequence[SpaCyTokenFeature],
   692	        start_char: int,
   693	        end_char: int,
   694	    ) -> bool:
   695	        """Treat temporal `by` as a deadline cue only when local context is time-like."""
   696	        trailing = normalized_text[end_char : end_char + 64]
   697	        if _TEMPORAL_BY_PHRASE_RE.match(trailing):
   698	            return True
   699	        if _CALENDAR_DATE_RE.search(trailing):
   700	            return True
   701	        lookahead: List[SpaCyTokenFeature] = []
   702	        for token in tokens:
   703	            if token.start_char >= end_char:
   704	                lookahead.append(token)
   705	                if len(lookahead) >= 4:
   706	                    break
   707	        for token in lookahead:
   708	            normalized = token.normalized().lower()
   709	            if normalized in _TEMPORAL_SCOPE_TOKENS:
   710	                return True
   711	            if normalized in _TEMPORAL_BY_CONTEXT_TOKENS:
   712	                return True
   713	            if normalized in _MONTH_NAME_TOKENS:
   714	                return True
   715	            if re.fullmatch(r"\d{1,4}", token.text):
   716	                return True
   717	        return False
   718	
   719	    def _is_temporal_duration_within_cue(
   720	        self,
   721	        *,
   722	        normalized_text: str,
   723	        tokens: Sequence[SpaCyTokenFeature],
   724	        start_char: int,
   725	        end_char: int,
   726	    ) -> bool:
   727	        """Treat temporal `within` as a deadline cue only when local context is time-like."""
   728	        return _is_temporal_duration_within_context(
   729	            normalized_text=normalized_text,
   730	            tokens=tokens,
   731	            start_char=start_char,
   732	            end_char=end_char,
   733	        )
   734	
   735	    def _is_non_temporal_following_cue(
   736	        self,
   737	        *,
   738	        normalized_text: str,
   739	        tokens: Sequence[SpaCyTokenFeature],
   740	        start_char: int,
   741	        end_char: int,
   742	    ) -> bool:
   743	        """Treat list-introducing `the following` as non-temporal context."""
   744	        preceding: Optional[SpaCyTokenFeature] = None
   745	        lookahead: List[SpaCyTokenFeature] = []
   746	        for token in tokens:
   747	            if token.end_char <= start_char:
   748	                preceding = token
   749	                continue
   750	            if token.start_char >= end_char:
   751	                lookahead.append(token)
   752	                if len(lookahead) >= 3:
   753	                    break
   754	        if preceding is None:
   755	            return False
   756	        preceding_normalized = preceding.normalized().lower()
   757	        if preceding_normalized not in _NON_TEMPORAL_FOLLOWING_PREFIX_TOKENS:
   758	            return False
   759	        if lookahead:
   760	            next_token = lookahead[0]
   761	            next_normalized = next_token.normalized().lower()
   762	            if (
   763	                next_normalized in _TEMPORAL_SCOPE_TOKENS
   764	                or next_normalized in _MONTH_NAME_TOKENS
   765	                or re.fullmatch(r"\d{1,4}", next_token.text)
   766	            ):
   767	                return False
   768	        trailing = normalized_text[end_char : end_char + 48]
   769	        if re.match(r"^\s*[:;,(\[]", trailing):
   770	            return True
   771	        if re.match(
   772	            r"^\s+(?:is|are|shall|must|may|include|includes|apply|applies|as)\b",
   773	            trailing,
   774	            re.IGNORECASE,
   775	        ):
   776	            return True
   777	        return False

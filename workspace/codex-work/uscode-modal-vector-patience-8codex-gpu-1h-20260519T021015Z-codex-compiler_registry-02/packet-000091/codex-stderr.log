   942	    def _feature_stream(self, encoding: SpaCyLegalEncoding) -> Iterable[str]:
   943	        yield f"doclen:{len(encoding.tokens)}"
   944	        for token in encoding.tokens:
   945	            if token.is_alpha and not token.is_stop:
   946	                yield f"lemma:{token.normalized()}"
   947	            if token.pos:
   948	                yield f"pos:{token.pos}"
   949	            if token.dep:
   950	                yield f"dep:{token.dep}"
   951	        for cue in encoding.cues:
   952	            yield f"cue:{cue.family}:{cue.symbol}:{cue.cue.lower()}"
   953	        for family, count in encoding.modal_family_counts().items():
   954	            yield f"family:{family}:{count}"

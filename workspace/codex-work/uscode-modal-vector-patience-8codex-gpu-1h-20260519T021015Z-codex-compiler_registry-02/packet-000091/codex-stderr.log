   601	    def _extract_cues(
   602	        self,
   603	        normalized: str,
   604	        tokens: Sequence[SpaCyTokenFeature],
   605	    ) -> List[SpaCyModalCueFeature]:
   606	        found: Dict[tuple[int, int, str, str], SpaCyModalCueFeature] = {}
   607	        token_spans = [(index, token.start_char, token.end_char) for index, token in enumerate(tokens)]
   608	        for profile in self.registry.all_profiles():
   609	            for operator in profile.operators:
   610	                for cue in sorted(operator.cue_terms, key=lambda value: (-len(value), value)):
   611	                    pattern = re.compile(rf"(?<!\w){re.escape(cue)}(?!\w)", re.IGNORECASE)
   612	                    for match in pattern.finditer(normalized):
   613	                        if self._is_calendar_month_may_cue(
   614	                            normalized_text=normalized,
   615	                            cue=cue,
   616	                            start_char=match.start(),
   617	                            end_char=match.end(),
   618	                        ):
   619	                            continue
   620	                        if profile.family == ModalLogicFamily.TEMPORAL:
   621	                            lowered_cue = cue.lower()
   622	                            if (
   623	                                lowered_cue == "by"
   624	                                and not self._is_temporal_deadline_by_cue(
   625	                                    normalized_text=normalized,
   626	                                    tokens=tokens,
   627	                                    start_char=match.start(),
   628	                                    end_char=match.end(),
   629	                                )
   630	                            ):
   631	                                continue
   632	                            if (
   633	                                lowered_cue == "within"
   634	                                and not self._is_temporal_duration_within_cue(
   635	                                    normalized_text=normalized,
   636	                                    tokens=tokens,
   637	                                    start_char=match.start(),
   638	                                    end_char=match.end(),
   639	                                )
   640	                            ):
   641	                                continue
   642	                            if (
   643	                                lowered_cue == "following"
   644	                                and self._is_non_temporal_following_cue(
   645	                                    normalized_text=normalized,
   646	                                    tokens=tokens,
   647	                                    start_char=match.start(),
   648	                                    end_char=match.end(),
   649	                                )
   650	                            ):
   651	                                continue
   652	                        token_indices = [
   653	                            index
   654	                            for index, start, end in token_spans
   655	                            if start < match.end() and end > match.start()
   656	                        ]
   657	                        key = (match.start(), match.end(), profile.family.value, operator.symbol)
   658	                        found[key] = self._cue_feature(
   659	                            profile,
   660	                            operator,
   661	                            cue,
   662	                            match.start(),
   663	                            match.end(),
   664	                            token_indices,
   665	                        )
   666	        return sorted(
   667	            found.values(),
   668	            key=lambda cue: (cue.start_char, cue.end_char, cue.family, cue.symbol, cue.cue),
   669	        )

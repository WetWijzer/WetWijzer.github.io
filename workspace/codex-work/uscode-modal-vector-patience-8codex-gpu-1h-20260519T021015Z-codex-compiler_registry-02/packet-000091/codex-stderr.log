   588	        if not logits:
   589	            return []
   590	        max_logit = max(float(value) for value in logits.values())
   591	        exp_by_family = {
   592	            family: math.exp(float(logit) - max_logit)
   593	            for family, logit in logits.items()
   594	        }
   595	        total = sum(exp_by_family.values())

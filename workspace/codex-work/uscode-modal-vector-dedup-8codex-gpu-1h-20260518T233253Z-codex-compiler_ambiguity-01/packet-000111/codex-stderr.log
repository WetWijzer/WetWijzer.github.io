        "deontic",
        "frame",
        "epistemic",
        "temporal",
    )
    assert signal_free_adaptive_ambiguity_targets("hybrid") == ("frame",)


def test_priority_signal_free_adaptive_ambiguity_pair_policy_is_directional() -> None:
    assert is_priority_signal_free_adaptive_ambiguity_pair(
        "deontic",

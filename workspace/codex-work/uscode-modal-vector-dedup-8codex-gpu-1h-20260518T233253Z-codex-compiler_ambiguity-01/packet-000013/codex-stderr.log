        if len(ranking) < 2:
            return ambiguities

        top, runner_up = ranking[0], ranking[1]
        share_margin = self._ranking_share(top) - self._ranking_share(runner_up)
        if share_margin <= self.config.modal_family_share_margin:
            ambiguities.append(

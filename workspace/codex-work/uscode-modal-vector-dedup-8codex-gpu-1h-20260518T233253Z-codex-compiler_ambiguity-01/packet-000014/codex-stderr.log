+    def _adaptive_family_shares_for_missing_targets(
+        self,
+        encoding: SpaCyLegalEncoding,
+        *,
+        family_shares: Dict[str, float],
+    ) -> Dict[str, float]:
+        """Provide adaptive softmax shares for families absent from ranking evidence."""
+        adaptive_ranking = self._adaptive_family_ranking_from_logits(encoding)
+        if not adaptive_ranking:
+            return {}
+        fallback_shares = {
+            str(candidate["family"]): self._ranking_share(candidate)
+            for candidate in adaptive_ranking
+        }
+        return {
+            family: share
+            for family, share in fallback_shares.items()
+            if family not in family_shares
+        }

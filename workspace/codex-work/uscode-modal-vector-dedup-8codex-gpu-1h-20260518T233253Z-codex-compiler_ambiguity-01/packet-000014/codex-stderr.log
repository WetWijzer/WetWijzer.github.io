from ipfs_datasets_py.optimizers.logic_theorem_optimizer.spacy_modal_codec import SpaCyLegalEncoding,SpaCyModalCueFeature
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.modal_registry import ModalLogicFamily

for d_count in [1,2,3,4,5,8]:
    cues=[SpaCyModalCueFeature(family='deontic',system='D',symbol='O',label='obligation',cue='shall',start_char=i,end_char=i+5,token_indices=[]) for i in range(d_count)]
    enc=SpaCyLegalEncoding(document_id='x',text='x',normalized_text='x',tokens=[],sentences=[],cues=cues)
    # count-based
    counts=enc.modal_family_counts(); total=sum(counts.values()); pred=counts.get('deontic',0)/total; target=counts.get('conditional_normative',0)/total
    margin_counts=target-pred
    # logits-based
    fam=[f.value for f in ModalLogicFamily]

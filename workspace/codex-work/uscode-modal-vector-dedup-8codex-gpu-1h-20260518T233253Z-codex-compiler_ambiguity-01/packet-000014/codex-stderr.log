from ipfs_datasets_py.logic.modal.compiler import DeterministicModalCompiler,ModalCompilerConfig

compiler=DeterministicModalCompiler(ModalCompilerConfig(parser_backend='regex'))
text='The agency shall provide written notice.'
enc=compiler.encoder.encode(text,document_id='x')
modal_families=[f.value for f in __import__('ipfs_datasets_py.optimizers.logic_theorem_optimizer.modal_registry',fromlist=['ModalLogicFamily']).ModalLogicFamily]
logits=compiler.decoder.family_logits(enc,modal_families=modal_families)
import math
m=max(logits.values()); ex={k:math.exp(v-m) for k,v in logits.items()}; total=sum(ex.values()); shares={k:v/total for k,v in ex.items()}
print('logits deontic',logits['deontic'],'cond',logits['conditional_normative'],'frame',logits['frame'])
print('share margin cond-deon',shares['conditional_normative']-shares['deontic'])
print('share margin frame-deon',shares['frame']-shares['deontic'])

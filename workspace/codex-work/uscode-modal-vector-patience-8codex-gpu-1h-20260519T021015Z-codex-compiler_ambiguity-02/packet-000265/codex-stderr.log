    26	def test_deontic_profile_has_expected_operators_and_serial_semantics() -> None:
    27	    profile = DEFAULT_MODAL_REGISTRY.get_profile(ModalLogicFamily.DEONTIC)
    28	    symbols = {operator.symbol for operator in profile.operators}
    29	    cue_terms = {cue for operator in profile.operators for cue in operator.cue_terms}
    30	
    31	    assert profile.system == ModalSystem.D
    32	    assert profile.semantics.serial is True
    33	    assert {"O", "P", "F"}.issubset(symbols)
    34	    assert {"shall", "must", "may", "prohibited"}.issubset(cue_terms)
    35	    assert {"has a duty to", "under an obligation to"}.issubset(cue_terms)
    36	
    37	
    38	def test_frame_profile_is_bm25_ontology_grounded() -> None:
    39	    profile = DEFAULT_MODAL_REGISTRY.get_profile("frame", "FRAME_BM25")
    40	
    41	    assert profile.family == ModalLogicFamily.FRAME
    42	    assert profile.system == ModalSystem.FRAME_BM25
    43	    assert profile.semantics.ontology_frame_grounded is True
    44	
    45	
    46	def test_conditional_profile_includes_terms_and_conditions_cues() -> None:
    47	    profile = DEFAULT_MODAL_REGISTRY.get_profile(ModalLogicFamily.CONDITIONAL_NORMATIVE)
    48	    cue_terms = {cue for operator in profile.operators for cue in operator.cue_terms}
    49	
    50	    assert "under such terms and conditions" in cue_terms
    51	    assert "subject to the terms and conditions" in cue_terms
    52	    assert "notwithstanding" in cue_terms
    53	    assert "except as provided by" in cue_terms
    54	    assert "as provided by" in cue_terms
    55	
    56	
    57	def test_temporal_profile_includes_deadline_and_calendar_scope_cues() -> None:
    58	    profile = DEFAULT_MODAL_REGISTRY.get_profile(ModalLogicFamily.TEMPORAL)
    59	    cue_terms = {cue for operator in profile.operators for cue in operator.cue_terms}
    60	

    TEMPORAL = "temporal"
    EPISTEMIC = "epistemic"
    DOXASTIC = "doxastic"
    DYNAMIC = "dynamic"
    CONDITIONAL_NORMATIVE = "conditional_normative"
    FRAME = "frame"
    HYBRID = "hybrid"


NORMATIVE_MODAL_FAMILIES: Tuple[ModalLogicFamily, ...] = (
    ModalLogicFamily.DEONTIC,
    ModalLogicFamily.CONDITIONAL_NORMATIVE,
)


    EPISTEMIC = "epistemic"
    DOXASTIC = "doxastic"
    DYNAMIC = "dynamic"
    CONDITIONAL_NORMATIVE = "conditional_normative"
    FRAME = "frame"
    HYBRID = "hybrid"



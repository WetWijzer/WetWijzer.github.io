+    )
+
+    def _mock_adaptive_family_ranking_from_logits(_encoding):
+        return [
+            {
+                "family": ModalLogicFamily.DEONTIC.value,
+                "count": 0,
+                "logit": 1.7,
+                "share_raw": 0.44,
+                "share": 0.44,
+                "source": "logit_softmax_fallback",
+            },
+            {
+                "family": ModalLogicFamily.FRAME.value,
+                "count": 0,
+                "logit": 1.5,
+                "share_raw": 0.32,
+                "share": 0.32,
+                "source": "logit_softmax_fallback",
+            },

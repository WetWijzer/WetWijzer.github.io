        metadata={
            **result.modal_ir.metadata,
            "frame_ontology_terms": {
                selected_frame: [
                    {"feature": "selected-frame-term:42 U.S.C. 1437q."},
                    {"feature": "candidate-frame-term:20 U.S.C. 1087j"},
                    {"feature_key": "slot:candidate_ontology_term:16 U.S.C. 460l-11"},

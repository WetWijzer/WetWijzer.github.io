        if scoped_target:
            raw_value = scoped_target
    if normalized_predicate.endswith("_conditional_normative"):
        _operator, separator, clause_value = raw_value.partition(":")
        if separator:
            normalized_clause_value = clause_value.strip()
            if normalized_clause_value:

    if normalized_predicate == "modal_family_count_family":
        return raw_value
    if normalized_predicate == "modal_family_count":
        family, separator, _count = raw_value.partition(":")
        if separator:
            return family.strip()
        return raw_value
    if normalized_predicate == "modal_family_count_ranked":

-    if not normalized:
-        return ""
-    canonical = _FRAME_ONTOLOGY_PREDICATE_ALIASES.get(normalized, normalized)
-    if canonical in _FRAME_ONTOLOGY_AUDIT_PREDICATES:
-        return canonical
-    return ""

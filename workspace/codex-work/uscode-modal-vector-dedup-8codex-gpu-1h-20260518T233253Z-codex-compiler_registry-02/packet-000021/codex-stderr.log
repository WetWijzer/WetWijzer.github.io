def _weighted_modal_family_counts(
    encoding: SpaCyLegalEncoding,
    *,
    signals: Optional[Mapping[str, bool]] = None,
) -> Dict[str, float]:
    counts = {
        family: float(count)
        for family, count in encoding.modal_family_counts().items()
    }
    if not counts:
        return {}
    resolved_signals: Mapping[str, bool]

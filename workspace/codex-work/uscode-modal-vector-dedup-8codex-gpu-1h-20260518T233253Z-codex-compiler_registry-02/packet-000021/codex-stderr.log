        if predicted_family not in {
            ModalLogicFamily.TEMPORAL.value,
            ModalLogicFamily.DEONTIC.value,
        }:
            return []
        predicted_share = self._ranking_share(ranking[0])
        target_family = (
            ModalLogicFamily.DEONTIC.value
            if predicted_family == ModalLogicFamily.TEMPORAL.value

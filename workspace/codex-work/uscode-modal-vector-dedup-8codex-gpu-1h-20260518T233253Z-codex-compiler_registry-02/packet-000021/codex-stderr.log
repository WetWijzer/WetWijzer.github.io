                        if profile.family == ModalLogicFamily.TEMPORAL:
                            lowered_cue = cue.lower()
                            if (
                                lowered_cue == "by"
                                and not self._is_temporal_deadline_by_cue(
                                    normalized_text=normalized,
                                    tokens=tokens,
                                    start_char=match.start(),
                                    end_char=match.end(),
                                )
                            ):
                                continue
                            if (
                                lowered_cue == "within"
                                and not self._is_temporal_duration_within_cue(
                                    normalized_text=normalized,
                                    tokens=tokens,
                                    start_char=match.start(),
                                    end_char=match.end(),

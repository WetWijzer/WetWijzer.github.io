+        cue.family == "temporal" and cue.cue.lower() == "after"
+        for cue in encoding.cues
+    )
+
+
+def test_spacy_encoder_extracts_temporal_not_later_than_cue() -> None:
+    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
+    encoding = encoder.encode(
+        "The agency shall provide notice not later than 30 days after review.",
+        document_id="sample-not-later-than-temporal",
+    )
+
+    assert any(
+        cue.family == "temporal"
+        and cue.cue.lower() == "not later than"
+        for cue in encoding.cues
+    )
+

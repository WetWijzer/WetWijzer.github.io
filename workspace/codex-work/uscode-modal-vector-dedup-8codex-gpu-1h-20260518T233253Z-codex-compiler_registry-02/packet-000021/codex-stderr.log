+def _lookbehind_tokens(
+    tokens: Sequence[SpaCyTokenFeature],
+    start_char: int,
+    *,
+    limit: int,
+) -> List[SpaCyTokenFeature]:
+    lookbehind: List[SpaCyTokenFeature] = []
+    for token in reversed(tokens):
+        if token.end_char <= start_char:
+            lookbehind.append(token)
+            if len(lookbehind) >= limit:
+                break
+    lookbehind.reverse()
+    return lookbehind

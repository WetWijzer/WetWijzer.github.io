+def test_spacy_encoder_extracts_conditional_notice_and_hearing_cue() -> None:
+    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
+    encoding = encoder.encode(
+        (
+            "After notice and opportunity for hearing, the Commission may "
+            "suspend registration."
+        ),
+        document_id="sample-notice-hearing-conditional",
+    )
+
+    assert any(
+        cue.family == "conditional_normative"
+        and cue.cue.lower() == "after notice and opportunity for hearing"
+        for cue in encoding.cues
+    )
+
+
+def test_spacy_encoder_treats_non_temporal_after_as_non_temporal_cue() -> None:
+    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
+    encoding = encoder.encode(
+        "After consultation, the Secretary shall issue the report.",
+        document_id="sample-after-consultation-non-temporal",
+    )
+
+    assert any(cue.family == "deontic" and cue.cue.lower() == "shall" for cue in encoding.cues)
+    assert not any(
+        cue.family == "temporal" and cue.cue.lower() == "after"
+        for cue in encoding.cues
+    )
+
+
+def test_spacy_encoder_extracts_temporal_not_later_than_cue() -> None:
+    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
+    encoding = encoder.encode(
+        "The agency shall provide notice not later than 30 days after review.",
+        document_id="sample-not-later-than-temporal",
+    )
+
+    assert any(
+        cue.family == "temporal"
+        and cue.cue.lower() == "not later than"
+        for cue in encoding.cues
+    )
+
+

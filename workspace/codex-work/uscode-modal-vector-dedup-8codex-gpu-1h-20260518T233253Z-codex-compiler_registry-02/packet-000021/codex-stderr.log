   396	class ModalRegistry:
   397	    """Lookup table for modal parse profiles."""
   398	
   399	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   400	        self._profiles: Dict[str, ModalParseProfile] = {
   401	            profile.profile_id: profile for profile in profiles
   402	        }
   403	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   404	            profile.family: profile for profile in profiles
   405	        }
   406	
   407	    def get_profile(
   408	        self,
   409	        family: ModalLogicFamily | str,
   410	        system: Optional[ModalSystem | str] = None,
   411	    ) -> ModalParseProfile:
   412	        """Get a profile by family, optionally constrained by system."""
   413	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   414	        if system is None:
   415	            return self._by_family[resolved_family]
   416	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   417	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   418	
   419	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   420	        """Return all profiles in deterministic order."""


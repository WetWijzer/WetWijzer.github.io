+def test_compiler_conditional_predicted_family_includes_temporal_target_signal() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    target_signals = compiler._adaptive_target_signal_by_family(
+        ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
+        signals={
+            "has_deontic_scope": False,
+            "has_deontic_cue": False,
+            "has_epistemic_cue": False,
+            "has_temporal_scope": True,
+        },

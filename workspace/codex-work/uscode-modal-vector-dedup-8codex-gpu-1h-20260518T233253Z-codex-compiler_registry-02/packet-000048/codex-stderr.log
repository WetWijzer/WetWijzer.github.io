+            "count": 1,
+            "share_raw": 0.36,
+            "share": 0.36,
+        },
+    ]
+    ambiguities = compiler._adaptive_family_margin_ambiguities(
+        encoding,
+        modal_ir=modal_ir,
+        ranking=ranking,
+        family_shares={
+            ModalLogicFamily.DEONTIC.value: 0.55,
+            ModalLogicFamily.TEMPORAL.value: 0.36,
+        },
+        frame_selections=(),
+        predicted_family_source="unit_test",
+    )
+
+    assert any(
+        ambiguity.ambiguity_type == "adaptive_deontic_deontic_contested_margin_low"
+        for ambiguity in ambiguities
+    )
+    assert any(

+        modal_ir=modal_ir,
+        ranking=ranking,
+        family_shares={
+            ModalLogicFamily.DEONTIC.value: 0.55,
+            ModalLogicFamily.TEMPORAL.value: 0.36,
+        },
+        frame_selections=(),
+        predicted_family_source="unit_test",
+    )
+

@@ -357,3 +357,71 @@ def test_compiler_emits_explicit_deontic_self_pair_for_low_family_margin() -> No
         predicted_family=ModalLogicFamily.DEONTIC.value,
         target_family=ModalLogicFamily.DEONTIC.value,
     )
+
+
+def test_compiler_conditional_predicted_family_includes_temporal_target_signal() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    target_signals = compiler._adaptive_target_signal_by_family(
+        ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
+        signals={
+            "has_deontic_scope": False,
+            "has_deontic_cue": False,
+            "has_epistemic_cue": False,
+            "has_temporal_scope": True,
+        },
+        has_frame_scope=False,
+    )
+
+    assert target_signals.get(ModalLogicFamily.TEMPORAL.value) is True
+
+
+def test_compiler_applies_deontic_self_pair_margin_floor() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    encoding = compiler.encoder.encode(
+        "The Secretary shall submit the report by June 1, 2030.",
+        document_id="compiler-ambiguity-deontic-self-margin-floor",
+    )
+    modal_ir = compiler.ir_compiler.compile(encoding)
+    ranking = [
+        {
+            "family": ModalLogicFamily.DEONTIC.value,
+            "count": 2,
+            "share_raw": 0.55,
+            "share": 0.55,
+        },
+        {
+            "family": ModalLogicFamily.TEMPORAL.value,
+            "count": 1,
+            "share_raw": 0.36,
+            "share": 0.36,
+        },
+    ]
+    ambiguities = compiler._adaptive_family_margin_ambiguities(
+        encoding,
+        modal_ir=modal_ir,
+        ranking=ranking,
+        family_shares={
+            ModalLogicFamily.DEONTIC.value: 0.55,
+            ModalLogicFamily.TEMPORAL.value: 0.36,
+        },
+        frame_selections=(),
+        predicted_family_source="unit_test",
+    )
+
+    assert any(
+        ambiguity.ambiguity_type == "adaptive_deontic_deontic_contested_margin_low"
+        for ambiguity in ambiguities
+    )
+    assert any(
+        ambiguity.metadata.get("adaptive_family_margin_threshold") == 0.2
+        and ambiguity.metadata.get("predicted_family") == ModalLogicFamily.DEONTIC.value
+        and ambiguity.metadata.get("target_family") == ModalLogicFamily.DEONTIC.value
+        for ambiguity in ambiguities
+        if ambiguity.ambiguity_type.startswith("adaptive_")
+    )

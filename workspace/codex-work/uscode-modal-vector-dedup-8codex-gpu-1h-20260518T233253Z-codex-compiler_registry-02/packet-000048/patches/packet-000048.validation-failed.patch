+def adaptive_modal_family_margin_floor(
+    predicted_family: ModalLogicFamily | str,
+    target_family: ModalLogicFamily | str,
+) -> float:
+    """Return a pair-specific lower bound for adaptive ambiguity margin thresholds."""
+    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
+    resolved_target_family = _resolve_modal_family_name(target_family)
+    return float(
+        ADAPTIVE_MODAL_FAMILY_MARGIN_FLOORS.get(
+            (resolved_predicted_family, resolved_target_family),
+            0.0,
+        )
+    )

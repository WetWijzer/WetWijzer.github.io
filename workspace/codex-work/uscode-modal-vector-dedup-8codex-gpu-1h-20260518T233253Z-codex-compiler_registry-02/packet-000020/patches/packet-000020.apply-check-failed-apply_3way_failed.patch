+def _is_generic_temporal_sequence_cue_debias_context(
+    encoding: SpaCyLegalEncoding,
+    signals: Mapping[str, bool],
+) -> bool:
+    if not (
+        bool(signals.get("has_deontic_cue"))
+        or bool(signals.get("has_deontic_scope"))
+    ):
+        return False
+    if bool(signals.get("has_calendar_date_scope")):
+        return False
+    if bool(signals.get("has_temporal_scope_phrase")):
+        return False
+    if bool(signals.get("has_temporal_within_scope")):
+        return False
+    temporal_cues = [
+        str(cue.cue).strip().lower()
+        for cue in encoding.cues
+        if cue.family == ModalLogicFamily.TEMPORAL.value
+    ]
+    if not temporal_cues:
+        return False
+    return all(cue in _GENERIC_TEMPORAL_SEQUENCE_CUE_TERMS for cue in temporal_cues)
+

+            "the Secretary shall issue notice."
+        ),
+    )
+
+    ranking = ranked_modal_families(codec.encode_sample(sample))
+
+    assert ranking[0]["family"] == "deontic"
+    deontic_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "deontic"
+    )
+    temporal_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "temporal"
+    )
+    assert deontic_share > temporal_share
+

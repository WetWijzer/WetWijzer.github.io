    enc=codec.encode_sample(s)
    sig=modal_ambiguity_signals(enc)
    logits=codec.family_logits_for_sample(s,modal_families=('deontic','frame','temporal','conditional_normative','hybrid'))
    print(name)
    print('cues',[(c.family,c.cue) for c in enc.cues])

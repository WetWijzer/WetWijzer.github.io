codec=SpaCyModalCodec(encoder=SpaCyLegalEncoder(model_name='definitely_missing_legal_model'),decoder=SpaCyModalDecoder())
texts=[
    ('frame_phrase','The Secretary shall provide administrative notice and hearing procedures under this section.'),
    ('temporal_phrase','The Administrator shall issue guidance for a period of 3 fiscal years.'),
]
for name,text in texts:

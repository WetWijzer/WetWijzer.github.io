/bin/bash -lc "python - <<'PY'
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.spacy_modal_codec import SpaCyModalCodec,SpaCyLegalEncoder,SpaCyModalDecoder,ranked_modal_families,modal_ambiguity_signals
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample
codec = SpaCyModalCodec(encoder=SpaCyLegalEncoder(model_name='definitely_missing_legal_model'),decoder=SpaCyModalDecoder())
texts=[
('cond1','Authority and jurisdiction under this chapter and authority over permits apply subject to the terms and conditions of subsection (b).'),
('temp1','Authority and jurisdiction under this chapter and authority over permits apply before each fiscal year deadline.'),
('cond2','Authority over this section and jurisdiction over lands apply in the event that the Secretary determines otherwise.'),
('temp2','Authority over this section and jurisdiction over lands apply no later than 30 days after enactment.'),
]
for sid,text in texts:
    sample=build_us_code_sample(title='99',section=sid,text=text)
    enc=codec.encode_sample(sample)
    print('\\n',sid)
    print('cues',[(c.family,c.cue) for c in enc.cues])
    print('signals', {k:v for k,v in modal_ambiguity_signals(enc).items() if v})
    print('ranking',ranked_modal_families(enc))
    print('logits',codec.family_logits_for_sample(sample,modal_families=('frame','conditional_normative','temporal','deontic')))

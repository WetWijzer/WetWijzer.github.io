  1342	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1343	        """Return deterministic ambiguity priority from policy margin settings.
  1344	
  1345	        For contested low-margin cases (positive margin below threshold), a
  1346	        smaller gap to the threshold carries higher urgency. For outvoted
  1347	        cases (zero/negative margin), severity increases with outvote depth.

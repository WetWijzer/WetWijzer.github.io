                    "outvote_margin_threshold": outvote_margin_threshold,
                    "predicted_family": predicted_family,
                    "predicted_share": round(predicted_share, 6),
                    "target_family": target_family,
                    "target_share": round(target_share, 6),
                },
            )
        ]


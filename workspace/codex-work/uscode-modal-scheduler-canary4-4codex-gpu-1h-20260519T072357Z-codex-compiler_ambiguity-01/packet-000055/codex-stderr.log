    if bool(signals.get("has_frame_editorial_scope_phrase")):
        structural_bonus += 2.2
    if structural_bonus <= 0.0:
        return 0.0
    return structural_bonus * _GENERIC_FRAME_STRUCTURAL_BONUS_DEBIAS_FACTOR



    for frame_id in _ranked_candidate_frame_ids(
        modal_ir,
        frame_terms_by_frame=frame_terms_by_frame,
        selected_frame=resolved_selected_frame,
    ):
        triples.append(
            {
                "subject": modal_ir.document_id,
                "predicate": "candidate_ontology_frame",

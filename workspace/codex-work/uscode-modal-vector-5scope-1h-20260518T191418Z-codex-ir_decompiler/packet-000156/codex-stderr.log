from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample
from ipfs_datasets_py.logic.modal import decode_modal_ir_document, decoded_modal_phrase_slot_text_map, modal_ir_to_flogic_triples

samples=[('42','1962d','The Secretary shall apply national establishment standards.'),('26','7520','The Administrator shall act in the next fiscal year.'),('51','40504.','The establishment shall provide national standards.'),('46','55101.','Provisions relating to entities apply under this section.')]
for title,section,text in samples:
    s=build_us_code_sample(title=title, section=section, citation=f\"{title} U.S.C. {section}\", text=text)
    d=decode_modal_ir_document(s.modal_ir)
    m=decoded_modal_phrase_slot_text_map(d)
    triples=modal_ir_to_flogic_triples(s.modal_ir)
    print('---',title,section,'formulas',len(s.modal_ir.formulas),'familycounts',s.modal_ir.metadata.get('modal_family_counts'))
    keys=['citation_section_style_alnum_segment_kind_positioned','source_id_section_style_alnum_segment_kind_positioned','support_span_start_char_hundreds_block','modal_operator','modal_operator_label','modal_span_coverage_percent_leading_digit','modal_family_count','modal_family_count_ranked','modal_span_char_count_trailing_two_digits','predicate_alnum_segment_positioned','citation_section_component_signature','citation_section_number_digit_count_bucket_positioned']
    for k in keys:
        if k in m:
            print('slot',k,m[k][:6])
    vals={}
    for t in triples:
        vals.setdefault(t['predicate'],[])
        if t['object'] not in vals[t['predicate']]:
            vals[t['predicate']].append(t['object'])
    for k in keys:
        if k in vals:
            print('triple',k,vals[k][:6])

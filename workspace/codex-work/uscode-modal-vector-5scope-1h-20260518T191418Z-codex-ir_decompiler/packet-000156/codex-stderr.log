def _unique_preserve_order_tuples(
    values: Iterable[tuple[str, str]],
) -> List[tuple[str, str]]:
    seen: set[tuple[str, str]] = set()
    result: List[tuple[str, str]] = []
    for value in values:
        if not value or value in seen:
            continue
        seen.add(value)
        result.append(value)
    return result


def _typed_identifier_components(
    value: str,

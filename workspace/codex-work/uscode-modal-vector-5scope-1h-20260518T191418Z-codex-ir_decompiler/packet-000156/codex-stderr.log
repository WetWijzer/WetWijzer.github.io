from ipfs_datasets_py.logic.modal import DeterministicModalCompiler, ModalCompilerConfig, decode_modal_ir_document, decoded_modal_phrase_slot_text_map

compiler=DeterministicModalCompiler(ModalCompilerConfig(parser_backend='regex'))
text='In this chapter, the Commission shall establish national standards for reporting and disclosure, and in the next quarter it shall apply compliance reviews.'
compiled=compiler.compile(text, document_id='us-code-26-7520-ad4e4c590b70c936', citation='26 U.S.C. 7520', source='us_code')
print('formulas',len(compiled.modal_ir.formulas))
for f in compiled.modal_ir.formulas:
    print(f.operator.family,f.operator.symbol,f.operator.label,f.predicate.name,f.provenance.start_char,f.provenance.end_char)
print('family counts',compiled.modal_ir.metadata.get('modal_family_counts'))


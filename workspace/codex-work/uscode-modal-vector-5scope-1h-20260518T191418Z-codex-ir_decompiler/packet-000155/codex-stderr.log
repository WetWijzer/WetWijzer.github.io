  1471	def _softmax(logits: Mapping[str, float]) -> Dict[str, float]:
  1472	    if not logits:
  1473	        return {}
  1474	    max_logit = max(float(value) for value in logits.values())
  1475	    exponentials = {
  1476	        name: math.exp(float(value) - max_logit)
  1477	        for name, value in logits.items()
  1478	    }
  1479	    total = sum(exponentials.values())
  1480	    if total == 0.0:
  1481	        uniform = 1.0 / len(exponentials)
  1482	        return {name: uniform for name in sorted(exponentials)}
  1483	    return {name: exponentials[name] / total for name in sorted(exponentials)}

from ipfs_datasets_py.optimizers.logic_theorem_optimizer.modal_ir import ModalIRDocument, ModalIRFormula, ModalIROperator, ModalIRPredicate, ModalIRProvenance
from ipfs_datasets_py.logic.modal.decompiler import decode_modal_ir_document, decoded_modal_phrase_slot_text_map
from ipfs_datasets_py.logic.modal.codec import modal_ir_to_flogic_triples

formula = ModalIRFormula(
    formula_id='f1',
    operator=ModalIROperator(family='deontic', system='kd', symbol='O|', label='conditionally obligatory'),
    predicate=ModalIRPredicate(name='grant_benefit'),
    provenance=ModalIRProvenance(source_id='us-code-42-1395c.-da5383050c7a2c5e', start_char=0, end_char=80, citation='42 U.S.C. 1395c.'),
    exceptions=['except as such a determination applies'],
    metadata={'cue':'may'}
)

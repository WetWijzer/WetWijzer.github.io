+                spans=spans,
+                provenance_only=True,
+            )
+        )
+    typed_exception = _typed_clause_slot(scoped_exception, slot="exception")
+    if typed_exception is None:
+        return phrases
+    prefix_slot_value, prefix_key, scoped_value = typed_exception

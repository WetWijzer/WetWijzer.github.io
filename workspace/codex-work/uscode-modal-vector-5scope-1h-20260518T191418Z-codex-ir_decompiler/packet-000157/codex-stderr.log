  4183	def _unique_preserve_order_tuples(
  4184	    values: Iterable[tuple[str, str]],
  4185	) -> List[tuple[str, str]]:
  4186	    seen: set[tuple[str, str]] = set()
  4187	    result: List[tuple[str, str]] = []
  4188	    for value in values:
  4189	        if not value or value in seen:
  4190	            continue
  4191	        seen.add(value)
  4192	        result.append(value)
  4193	    return result

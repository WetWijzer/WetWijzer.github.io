  3671	def _primary_terminal_suffix_relation_components(
  3672	    *,
  3673	    primary_suffix: str,
  3674	    terminal_suffix: str,
  3675	    slot_prefix: str,
  3676	    emit_when_absent: bool = False,
  3677	) -> List[tuple[str, str]]:
  3678	    normalized_slot_prefix = _clean_non_empty_string(slot_prefix)
  3679	    if not normalized_slot_prefix:
  3680	        return []
  3681	    primary = _clean_non_empty_string(primary_suffix).lower()
  3682	    terminal = _clean_non_empty_string(terminal_suffix).lower()
  3683	    if not primary and not terminal and not emit_when_absent:
  3684	        return []
  3685	    components: List[tuple[str, str]] = [
  3686	        (
  3687	            f"{normalized_slot_prefix}_pair",
  3688	            f"{primary or 'none'}|{terminal or 'none'}",
  3689	        ),
  3690	        (
  3691	            f"{normalized_slot_prefix}_match",
  3692	            "true" if primary == terminal else "false",
  3693	        ),
  3694	        (
  3695	            f"{normalized_slot_prefix}_presence_match",
  3696	            "true" if bool(primary) == bool(terminal) else "false",
  3697	        ),
  3698	    ]
  3699	    if primary and terminal:
  3700	        length_relation = _primary_terminal_number_relation(
  3701	            primary_number=str(len(primary)),
  3702	            terminal_number=str(len(terminal)),
  3703	        )
  3704	        if length_relation is not None:
  3705	            relation, span = length_relation
  3706	            components.append((f"{normalized_slot_prefix}_length_relation", relation))
  3707	            components.append((f"{normalized_slot_prefix}_length_span", span))
  3708	        alpha_relation = _primary_terminal_alpha_relation(
  3709	            primary_token=primary,
  3710	            terminal_token=terminal,
  3711	        )
  3712	        if alpha_relation is not None:
  3713	            relation, span = alpha_relation
  3714	            components.append((f"{normalized_slot_prefix}_alpha_relation", relation))
  3715	            components.append((f"{normalized_slot_prefix}_alpha_span", span))
  3716	    return components

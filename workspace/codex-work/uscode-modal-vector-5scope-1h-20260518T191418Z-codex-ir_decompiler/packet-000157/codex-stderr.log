  3735	def _alpha_token_value(value: str) -> int | None:
  3736	    cleaned = _clean_non_empty_string(value).lower()
  3737	    if not cleaned or not cleaned.isalpha():
  3738	        return None
  3739	    numeric_value = 0
  3740	    for character in cleaned:
  3741	        numeric_value = (numeric_value * 26) + (ord(character) - ord("a") + 1)
  3742	    return numeric_value

  3873	def _alpha_repeat_kind(letters: Sequence[str]) -> str:
  3874	    if not letters:
  3875	        return ""
  3876	    if len(letters) == 1:
  3877	        return "single"
  3878	    unique_count = len(set(letters))
  3879	    if unique_count == 1:
  3880	        return "uniform_repeat"
  3881	    if unique_count == len(letters):
  3882	        return "all_distinct"
  3883	    return "mixed_repeat"

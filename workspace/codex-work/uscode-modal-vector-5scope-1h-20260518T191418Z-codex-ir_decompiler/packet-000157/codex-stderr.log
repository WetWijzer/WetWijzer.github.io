  3719	def _primary_terminal_alpha_relation(
  3720	    *,
  3721	    primary_token: str,
  3722	    terminal_token: str,
  3723	) -> tuple[str, str] | None:
  3724	    primary_value = _alpha_token_value(primary_token)
  3725	    terminal_value = _alpha_token_value(terminal_token)
  3726	    if primary_value is None or terminal_value is None:
  3727	        return None
  3728	    if primary_value == terminal_value:
  3729	        return ("equal", "0")
  3730	    if primary_value < terminal_value:
  3731	        return ("ascending", str(terminal_value - primary_value))
  3732	    return ("descending", str(primary_value - terminal_value))

  3745	def _numeric_signature_components(
  3746	    value: str,
  3747	    *,
  3748	    slot_prefix: str,
  3749	) -> List[tuple[str, str]]:
  3750	    cleaned = _clean_non_empty_string(value)
  3751	    if not cleaned or not cleaned.isdigit():
  3752	        return []
  3753	    numeric_value = int(cleaned)
  3754	    last_digit = cleaned[-1]
  3755	    trailing_two_digits = cleaned[-2:] if len(cleaned) > 1 else cleaned
  3756	    parity = "even" if last_digit in {"0", "2", "4", "6", "8"} else "odd"
  3757	    zero_digit_count = cleaned.count("0")
  3758	    trailing_zero_count = len(cleaned) - len(cleaned.rstrip("0"))
  3759	    digit_count_bucket = f"{len(cleaned)}_digit"
  3760	    magnitude_bucket = _numeric_magnitude_bucket(numeric_value)
  3761	    prefix_two_digits = cleaned[:2] if len(cleaned) > 1 else cleaned
  3762	    prefix_three_digits = cleaned[:3] if len(cleaned) > 2 else cleaned
  3763	    hundreds_block = str(numeric_value // 100)
  3764	    thousands_block = str(numeric_value // 1_000)
  3765	    return [
  3766	        (f"{slot_prefix}_parity", parity),
  3767	        (f"{slot_prefix}_digit_count_bucket", digit_count_bucket),
  3768	        (f"{slot_prefix}_magnitude_bucket", magnitude_bucket),
  3769	        (f"{slot_prefix}_prefix_two_digits", prefix_two_digits),
  3770	        (f"{slot_prefix}_prefix_three_digits", prefix_three_digits),
  3771	        (f"{slot_prefix}_hundreds_block", hundreds_block),
  3772	        (f"{slot_prefix}_thousands_block", thousands_block),
  3773	        (f"{slot_prefix}_leading_digit", cleaned[0]),
  3774	        (f"{slot_prefix}_trailing_two_digits", trailing_two_digits),
  3775	        (f"{slot_prefix}_zero_digit_count", str(zero_digit_count)),
  3776	        (
  3777	            f"{slot_prefix}_has_zero_digit",
  3778	            "true" if zero_digit_count > 0 else "false",
  3779	        ),
  3780	        (f"{slot_prefix}_trailing_zero_count", str(trailing_zero_count)),
  3781	    ]
  3782	
  3783	
  3784	def _numeric_span_signature_components(
  3785	    *,
  3786	    slot_prefix: str,
  3787	    span: str,
  3788	) -> List[tuple[str, str]]:
  3789	    normalized_slot_prefix = _clean_non_empty_string(slot_prefix)
  3790	    normalized_span = _clean_non_empty_string(span)
  3791	    if not normalized_slot_prefix or not normalized_span.isdigit():
  3792	        return []
  3793	    return _numeric_signature_components(
  3794	        normalized_span,
  3795	        slot_prefix=normalized_slot_prefix,
  3796	    )

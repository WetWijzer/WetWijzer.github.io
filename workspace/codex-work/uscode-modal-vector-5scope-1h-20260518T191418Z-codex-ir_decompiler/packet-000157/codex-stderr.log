+            cues.append(derived_cue)
+    return cues
+
+
+def _derived_modal_cue(
+    formula: ModalIRFormula,
+    *,
+    explicit_cue: str,
+) -> str:
+    normalized_explicit = _clean_non_empty_string(explicit_cue)

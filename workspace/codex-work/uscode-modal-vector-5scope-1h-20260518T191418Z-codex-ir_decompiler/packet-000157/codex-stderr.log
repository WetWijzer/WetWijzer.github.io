  2822	def _statutory_scope_slots(text: str) -> List[Tuple[str, str]]:
  2823	    normalized = _clean_text(text).replace("_", " ").lower()
  2824	    if not normalized:
  2825	        return []
  2826	    result: List[Tuple[str, str]] = []
  2827	    seen: set[Tuple[str, str]] = set()
  2828	    for match in _STATUTORY_SCOPE_REFERENCE_RE.finditer(normalized):
  2829	        connector = _clean_text(match.group("connector")).lower()
  2830	        unit_surface = _clean_text(match.group("unit")).lower()
  2831	        unit = _canonical_statutory_scope_unit(unit_surface)
  2832	        determiner = _clean_text(match.group("determiner")).lower()
  2833	        has_determiner = bool(determiner)
  2834	        target = _clean_text(match.group("target")).lower()
  2835	        if (
  2836	            has_determiner
  2837	            and target
  2838	            and not target.startswith("(")
  2839	            and not any(character.isdigit() for character in target)
  2840	            and _ROMAN_NUMERAL_RE.fullmatch(target) is None
  2841	        ):
  2842	            target = ""
  2843	        reference_parts = (
  2844	            [connector, determiner, unit_surface]
  2845	            if has_determiner
  2846	            else [connector, unit_surface]
  2847	        )
  2848	        if target:
  2849	            reference_parts.append(target)
  2850	        reference = " ".join(reference_parts)
  2851	        resolved_target = (
  2852	            f"{determiner} {target}".strip() if has_determiner else target
  2853	        )
  2854	        if has_determiner and not target:
  2855	            resolved_target = determiner
  2856	        values: List[Tuple[str, str]] = [
  2857	            ("statutory_scope_reference", reference),
  2858	            ("statutory_scope_connector", connector),
  2859	            ("statutory_scope_unit", unit),
  2860	        ]
  2861	        if resolved_target:
  2862	            values.append(("statutory_scope_target", resolved_target))
  2863	        for slot in values:
  2864	            if slot in seen:
  2865	                continue
  2866	            seen.add(slot)
  2867	            result.append(slot)
  2868	    return result

  3886	def _alpha_max_run_length(letters: Sequence[str]) -> int:
  3887	    if not letters:
  3888	        return 0
  3889	    max_run_length = 1
  3890	    current_run_length = 1
  3891	    previous = letters[0]
  3892	    for character in letters[1:]:
  3893	        if character == previous:
  3894	            current_run_length += 1
  3895	        else:
  3896	            current_run_length = 1
  3897	            previous = character
  3898	        if current_run_length > max_run_length:
  3899	            max_run_length = current_run_length
  3900	    return max_run_length

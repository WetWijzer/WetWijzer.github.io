  3825	def _alpha_signature_components(
  3826	    value: str,
  3827	    *,
  3828	    slot_prefix: str,
  3829	) -> List[tuple[str, str]]:
  3830	    cleaned = _clean_non_empty_string(value).lower()
  3831	    if not cleaned:
  3832	        return []
  3833	    letters = [character for character in cleaned if character.isalpha()]
  3834	    if not letters:
  3835	        return []
  3836	    initial = letters[0]
  3837	    terminal = letters[-1]
  3838	    vowel_count = sum(1 for character in letters if character in _VOWEL_CHARS)
  3839	    consonant_count = len(letters) - vowel_count
  3840	    components: List[tuple[str, str]] = [
  3841	        (f"{slot_prefix}_initial", initial),
  3842	        (f"{slot_prefix}_terminal", terminal),
  3843	        (f"{slot_prefix}_vowel_count", str(vowel_count)),
  3844	        (f"{slot_prefix}_consonant_count", str(consonant_count)),
  3845	        (
  3846	            f"{slot_prefix}_has_vowel",
  3847	            "true" if vowel_count > 0 else "false",

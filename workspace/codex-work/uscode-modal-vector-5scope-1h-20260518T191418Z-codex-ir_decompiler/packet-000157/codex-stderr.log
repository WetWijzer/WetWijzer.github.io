  3799	def _numeric_magnitude_bucket(value: int) -> str:
  3800	    if value < 1_000:
  3801	        return "lt_1k"
  3802	    if value < 10_000:
  3803	        return "1k_to_9k"
  3804	    if value < 100_000:
  3805	        return "10k_to_99k"
  3806	    if value < 1_000_000:
  3807	        return "100k_to_999k"
  3808	    return "1m_plus"

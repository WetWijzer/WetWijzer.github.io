+def _formula_cues(formula: ModalIRFormula) -> List[str]:
+    cues: List[str] = []
+    explicit_cue = _clean_text(formula.metadata.get("cue") or "")
+    if explicit_cue:
+        cues.append(explicit_cue)
+    derived_cue = _derived_modal_cue(formula, explicit_cue=explicit_cue)
+    if derived_cue:

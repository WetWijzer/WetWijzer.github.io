+        if plural_variant in token_set:
+            return True
+    return False
+
+
+def _is_fallback_modal_cue(cue: str) -> bool:
+    normalized = _clean_text(cue).lower()
+    return normalized.startswith("__") and normalized.endswith("__")
+
+
+def _cue_alias_slot_name(slot: str) -> str:

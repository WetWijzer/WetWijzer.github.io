  3602	def _citation_section_delimiter_kind(delimiter: str) -> str:
  3603	    cleaned = _clean_non_empty_string(delimiter)
  3604	    if not cleaned:
  3605	        return ""
  3606	    if all(character == "." for character in cleaned):
  3607	        return "dot"
  3608	    if all(character == "-" for character in cleaned):

  3631	def _citation_section_component_profile(
  3632	    *,
  3633	    component_count: int,
  3634	    suffix_component_count: int,
  3635	    is_range: bool,
  3636	) -> str:
  3637	    if component_count <= 0:
  3638	        return ""
  3639	    if is_range:
  3640	        return "range"
  3641	    if component_count == 1:
  3642	        return "single_alphanumeric" if suffix_component_count else "single_numeric"
  3643	    if suffix_component_count == 0:
  3644	        return "compound_numeric"
  3645	    if suffix_component_count == component_count:
  3646	        return "compound_alphanumeric"
  3647	    return "compound_mixed"

  3650	def _primary_terminal_number_relation(
  3651	    *,
  3652	    primary_number: str,
  3653	    terminal_number: str,
  3654	) -> tuple[str, str] | None:
  3655	    primary_text = _clean_non_empty_string(primary_number)
  3656	    terminal_text = _clean_non_empty_string(terminal_number)
  3657	    if not primary_text or not terminal_text:
  3658	        return None
  3659	    try:
  3660	        primary_value = int(primary_text)
  3661	        terminal_value = int(terminal_text)
  3662	    except (TypeError, ValueError):
  3663	        return None
  3664	    if primary_value == terminal_value:
  3665	        return ("equal", "0")
  3666	    if primary_value < terminal_value:
  3667	        return ("ascending", str(terminal_value - primary_value))
  3668	    return ("descending", str(primary_value - terminal_value))

  1497	def _softmax(logits: Mapping[str, float]) -> Dict[str, float]:
  1498	    if not logits:
  1499	        return {}
  1500	    max_logit = max(float(value) for value in logits.values())
  1501	    exponentials = {
  1502	        name: math.exp(float(value) - max_logit)
  1503	        for name, value in logits.items()
  1504	    }
  1505	    total = sum(exponentials.values())
  1506	    if total == 0.0:
  1507	        uniform = 1.0 / len(exponentials)
  1508	        return {name: uniform for name in sorted(exponentials)}
  1509	    return {name: exponentials[name] / total for name in sorted(exponentials)}

  3615	def _citation_section_component_signature(
  3616	    *,
  3617	    number: str,
  3618	    suffix: str,
  3619	    suffix_kind: str,
  3620	) -> str:
  3621	    number_text = _clean_non_empty_string(number)
  3622	    suffix_text = _clean_non_empty_string(suffix)
  3623	    number_width = str(len(number_text)) if number_text else "0"
  3624	    if not suffix_text:
  3625	        return f"N{number_width}"
  3626	    kind_key = _clean_non_empty_string(suffix_kind).lower()
  3627	    kind_symbol = "R" if kind_key == "roman" else "A" if kind_key == "alpha" else "O"
  3628	    return f"N{number_width}{kind_symbol}{len(suffix_text)}"

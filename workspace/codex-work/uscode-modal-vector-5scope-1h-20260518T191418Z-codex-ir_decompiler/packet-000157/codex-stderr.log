  3811	def _relation_span_profile(
  3812	    *,
  3813	    relation: str,
  3814	    span: str,
  3815	) -> str:
  3816	    normalized_relation = _clean_non_empty_string(relation).lower()
  3817	    normalized_span = _clean_non_empty_string(span)
  3818	    if not normalized_relation:
  3819	        return ""
  3820	    if not normalized_span.isdigit():
  3821	        return normalized_relation
  3822	    return f"{normalized_relation}_{_numeric_magnitude_bucket(int(normalized_span))}"

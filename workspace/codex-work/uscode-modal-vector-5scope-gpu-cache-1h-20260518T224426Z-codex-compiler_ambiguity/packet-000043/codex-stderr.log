    ambiguities: List[ModalCompilationAmbiguity] = field(default_factory=list)
    encoding: Optional[SpaCyLegalEncoding] = None
    metadata: Dict[str, Any] = field(default_factory=dict)

    def to_dict(self) -> Dict[str, Any]:
        return {

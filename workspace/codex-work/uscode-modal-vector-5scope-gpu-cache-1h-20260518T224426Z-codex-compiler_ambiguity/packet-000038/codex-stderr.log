        )
        ambiguities.extend(
            self._temporal_scope_target_family_ambiguities(
                encoding,
                ranking=ranking,
                family_shares=family_shares,
            )
        )
        ambiguities.extend(
            self._frame_scope_target_family_ambiguities(
                encoding,
                ranking=ranking,
                family_shares=family_shares,

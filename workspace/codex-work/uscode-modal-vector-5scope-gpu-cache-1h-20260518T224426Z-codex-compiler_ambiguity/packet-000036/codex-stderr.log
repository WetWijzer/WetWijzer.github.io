        family_shares: Dict[str, float],
    ) -> List[ModalCompilationAmbiguity]:
        if not ranking:
            return []
        predicted_family = str(ranking[0]["family"])
        target_family = ModalLogicFamily.DYNAMIC.value
        if predicted_family == target_family:

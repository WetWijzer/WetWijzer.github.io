                or has_compiled_target_family_formula
            )
            supports_signal_free_pair_policy = self._supports_signal_free_adaptive_pair(
                predicted_family,
                target_family,
            )
            is_priority_policy_pair = is_priority_signal_free_adaptive_ambiguity_pair(
                predicted_family,

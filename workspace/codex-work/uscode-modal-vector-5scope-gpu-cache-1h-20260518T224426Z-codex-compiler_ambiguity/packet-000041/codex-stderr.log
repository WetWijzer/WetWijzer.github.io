                        "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
                    },
                )
            )
        return ambiguities

    def _has_frame_bm25_support(
        self,
        frame_selections: Sequence[FrameSelection],
    ) -> bool:
        if not frame_selections:

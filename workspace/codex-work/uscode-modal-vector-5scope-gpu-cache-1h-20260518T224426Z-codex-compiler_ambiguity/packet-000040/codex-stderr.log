                ModalLogicFamily.DEONTIC.value: bool(
                    signals.get("has_deontic_scope")
                ),
            }
        elif predicted_family == ModalLogicFamily.HYBRID.value:
            target_signal_by_family = {
                ModalLogicFamily.FRAME.value: has_frame_scope,

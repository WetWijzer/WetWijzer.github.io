+        normalized_text="The agency knows and shall report.",
+        tokens=[],
+        sentences=[],
+        cues=[
+            SpaCyModalCueFeature(
+                family="epistemic",
+                system="S5",
+                symbol="K",
+                label="knowledge",
+                cue="knows",
+                start_char=11,
+                end_char=16,
+                token_indices=[],
+            ),
+        ],
+    )
+    modal_ir = ModalIRDocument(
+        document_id="adaptive-contested-epistemic-deontic-doc",
+        source="us_code",

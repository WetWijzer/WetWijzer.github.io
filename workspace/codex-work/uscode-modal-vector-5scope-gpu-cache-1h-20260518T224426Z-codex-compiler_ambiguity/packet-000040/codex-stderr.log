                    signals.get("has_condition_or_exception_scope")
                ),
                ModalLogicFamily.TEMPORAL.value: bool(
                    signals.get("has_temporal_scope")
                ),
                ModalLogicFamily.ALETHIC.value: bool(
                    signals.get("has_alethic_scope")

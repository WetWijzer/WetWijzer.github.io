        return any(
            bool(selection.matched_terms) and float(selection.score) > 0.0
            for selection in frame_selections
        )

    def _adaptive_margin_explicit_type(
        self,
        predicted_family: str,
        target_family: str,
        margin_direction: str,
    ) -> str:
        return "_".join(

        self,
        predicted_family: str,
        target_family: str,
    ) -> bool:
        """Return whether this pair must surface adaptive ambiguity without lexical support."""
        return supports_signal_free_adaptive_ambiguity_pair(
            predicted_family,
            target_family,
        )


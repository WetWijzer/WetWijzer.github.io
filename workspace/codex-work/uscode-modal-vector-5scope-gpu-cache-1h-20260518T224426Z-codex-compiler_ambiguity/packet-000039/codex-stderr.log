                ambiguities.append(
                    ModalCompilationAmbiguity(
                        ambiguity_type="multi_family_same_span",
                        message="Multiple modal families were compiled from the same text span.",
                        candidate_ids=sorted(candidates),
                        metadata={"span": list(span)},


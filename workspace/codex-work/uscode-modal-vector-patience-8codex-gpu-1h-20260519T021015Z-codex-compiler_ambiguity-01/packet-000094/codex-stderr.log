   578	    def _adaptive_family_ranking_from_logits(
   579	        self,
   580	        encoding: SpaCyLegalEncoding,
   581	    ) -> List[Dict[str, float]]:
   582	        """Build fallback family ranking from deterministic decoder logits."""
   583	        modal_families = [family.value for family in ModalLogicFamily]
   584	        logits = self.decoder.family_logits(
   585	            encoding,
   586	            modal_families=modal_families,
   587	        )
   588	        if not logits:
   589	            return []
   590	        max_logit = max(float(value) for value in logits.values())
   591	        exp_by_family = {
   592	            family: math.exp(float(logit) - max_logit)
   593	            for family, logit in logits.items()
   594	        }
   595	        total = sum(exp_by_family.values())
   596	        if total <= 0.0:
   597	            return []
   598	        ranking: List[Dict[str, float]] = []
   599	        for family in sorted(
   600	            exp_by_family,
   601	            key=lambda key: (-exp_by_family[key], key),
   602	        ):
   603	            share_raw = exp_by_family[family] / total
   604	            ranking.append(
   605	                {
   606	                    "family": family,

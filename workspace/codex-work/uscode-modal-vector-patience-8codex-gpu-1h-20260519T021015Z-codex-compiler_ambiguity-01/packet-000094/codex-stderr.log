   461	class ModalRegistry:
   462	    """Lookup table for modal parse profiles."""
   463	
   464	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   465	        self._profiles: Dict[str, ModalParseProfile] = {
   466	            profile.profile_id: profile for profile in profiles
   467	        }
   468	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   469	            profile.family: profile for profile in profiles
   470	        }
   471	
   472	    def get_profile(
   473	        self,
   474	        family: ModalLogicFamily | str,
   475	        system: Optional[ModalSystem | str] = None,
   476	    ) -> ModalParseProfile:
   477	        """Get a profile by family, optionally constrained by system."""
   478	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   479	        if system is None:
   480	            return self._by_family[resolved_family]
   481	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   482	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   483	
   484	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   485	        """Return all profiles in deterministic order."""
   486	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   487	
   488	    def to_dict(self) -> Mapping[str, object]:
   489	        """Return a stable JSON-ready registry mapping."""
   490	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   491	
   492	
   493	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   494	    """Return whether a modal family encodes normative legal force."""
   495	    if isinstance(family, ModalLogicFamily):
   496	        resolved = family
   497	    else:
   498	        try:
   499	            resolved = ModalLogicFamily(str(family))
   500	        except ValueError:
   501	            return False
   502	    return resolved in NORMATIVE_MODAL_FAMILIES
   503	
   504	
   505	def supports_signal_free_adaptive_ambiguity_pair(
   506	    predicted_family: ModalLogicFamily | str,
   507	    target_family: ModalLogicFamily | str,
   508	) -> bool:
   509	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   510	    resolved_target_family = _resolve_modal_family_name(target_family)
   511	    return resolved_target_family in signal_free_adaptive_ambiguity_targets(
   512	        predicted_family
   513	    )
   514	
   515	
   516	def signal_free_adaptive_ambiguity_targets(
   517	    predicted_family: ModalLogicFamily | str,
   518	) -> Tuple[str, ...]:
   519	    """Return ordered adaptive-ambiguity targets requiring signal-free handling."""
   520	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   521	    return tuple(
   522	        target_family
   523	        for source_family, target_family in SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   524	        if source_family == resolved_predicted_family
   525	    )
   526	
   527	
   528	def is_priority_signal_free_adaptive_ambiguity_pair(
   529	    predicted_family: ModalLogicFamily | str,
   530	    target_family: ModalLogicFamily | str,
   531	) -> bool:
   532	    """Return whether a pair is part of the highest-priority adaptive ambiguity policy."""
   533	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   534	    resolved_target_family = _resolve_modal_family_name(target_family)
   535	    return (
   536	        resolved_predicted_family,
   537	        resolved_target_family,
   538	    ) in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS

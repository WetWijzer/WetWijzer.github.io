+def test_spacy_codec_prioritizes_leading_deontic_force_over_dense_temporal_scope_cues() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="20",
+        section="806",
+        text=(
+            "The Secretary shall, from time to time, on or after January 1, 2030, "
+            "exercise authority and jurisdiction under this section."
+        ),
+    )
+
+    ranking = ranked_modal_families(codec.encode_sample(sample))
+    deontic_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "deontic"
+    )
+    temporal_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "temporal"
+    )
+
+    assert ranking[0]["family"] == "deontic"
+    assert deontic_share >= temporal_share
+
+
+def test_spacy_decoder_prioritizes_leading_deontic_logits_for_temporal_and_frame_competition() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="12",
+        section="1816",
+        text=(
+            "The Board may, from time to time and until January 1, 2030, exercise "
+            "authority and jurisdiction under this chapter."
+        ),
+    )
+
+    logits = codec.family_logits_for_sample(
+        sample,
+        modal_families=("deontic", "temporal", "frame"),
+    )
+
+    assert logits["deontic"] > logits["temporal"]
+    assert logits["deontic"] > logits["frame"]
+
+

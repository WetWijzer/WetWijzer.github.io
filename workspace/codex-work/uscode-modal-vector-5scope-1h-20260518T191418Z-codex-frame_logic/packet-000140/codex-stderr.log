+    ).strip("_")
+
+
+def _should_contextualize_frame_ontology_value(
+    *,
+    predicate: str,
+    normalized_value: str,
+    include_positioned_terms: bool,
+) -> bool:
+    if _is_frame_ontology_contextual_low_signal_value(normalized_value):

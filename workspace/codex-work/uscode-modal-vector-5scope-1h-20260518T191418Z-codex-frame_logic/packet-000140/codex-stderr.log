+        keep_stopword_tokens=True,
+    )
+    if not normalized_value:
+        return ""
+    if not _should_contextualize_frame_ontology_value(
+        predicate=predicate,
+        normalized_value=normalized_value,
+        include_positioned_terms=include_positioned_terms,

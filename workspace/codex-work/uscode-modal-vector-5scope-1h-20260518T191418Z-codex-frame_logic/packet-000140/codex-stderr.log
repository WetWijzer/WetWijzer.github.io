+        include_positioned_terms=include_positioned_terms,
+    ):
+        return ""
+    return normalize_frame_ontology_term(
+        f"{predicate}_{normalized_value}",
+        max_tokens=24,
+        keep_numeric_tokens=True,
+        keep_single_char_alpha_tokens=True,
+        keep_stopword_tokens=True,
+    )

+    feature = str(feature_key or "").strip()
+    if not feature:
+        return ""
+    raw_value = _raw_frame_ontology_value_from_feature(feature)
+    if not raw_value:
+        return ""
+    predicate = _frame_ontology_contextual_predicate_from_feature(feature)

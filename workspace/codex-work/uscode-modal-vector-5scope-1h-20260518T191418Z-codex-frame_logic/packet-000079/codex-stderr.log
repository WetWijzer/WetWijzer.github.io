def _collect_frame_ontology_feature_value_candidates(
    values: Any,
    extracted: List[str],
    *,
    depth: int,
    max_depth: int,
    max_values: int,
) -> None:
    if (
        values is None
        or depth >= max(max_depth, 1)
        or len(extracted) >= max(max_values, 1)
    ):
        return

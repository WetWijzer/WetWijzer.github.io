   102	                sample_id,
   103	                action="audit_frame_logic_terms",
   104	                target_component="modal.frame_logic",
   105	                rationale="Frame-linked features influenced reconstruction or family scoring and should be audited as ontology terms.",
   106	                priority=max(0.05, float(introspection.get("reconstruction_loss") or 0.0)),
   107	                evidence={

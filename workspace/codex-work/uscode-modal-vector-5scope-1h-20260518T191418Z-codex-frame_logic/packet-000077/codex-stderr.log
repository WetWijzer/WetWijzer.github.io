   855	
   856	def _is_informative_ontology_token(
   857	    token: str,
   858	    *,
   859	    keep_numeric_tokens: bool = False,
   860	    keep_single_char_alpha_tokens: bool = False,
   861	) -> bool:
   862	    if token.isdigit():
   863	        return keep_numeric_tokens
   864	    if len(token) < 2:
   865	        return (
   866	            keep_single_char_alpha_tokens
   867	            and len(token) == 1
   868	            and token.isalpha()
   869	        )
   870	    if token in _FRAME_ONTOLOGY_STOPWORDS:
   871	        return False
   872	    return any(character.isalpha() for character in token)

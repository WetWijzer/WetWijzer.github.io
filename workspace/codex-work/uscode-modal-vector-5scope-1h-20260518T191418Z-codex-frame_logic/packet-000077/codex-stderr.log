  1619	        return False
  1620	    if _todo_target_component(existing) != _todo_target_component(candidate):
  1621	        return False
  1622	    existing_signature = str(existing.metadata.get("dedupe_signature") or "")
  1623	    candidate_signature = str(candidate.metadata.get("dedupe_signature") or "")
  1624	    if existing_signature and candidate_signature and existing_signature == candidate_signature:
  1625	        return True
  1626	    existing_samples = set(existing.sample_ids)
  1627	    candidate_samples = set(candidate.sample_ids)
  1628	    if not existing_samples or not candidate_samples:
  1629	        return False
  1630	    intersection = len(existing_samples & candidate_samples)
  1631	    union = len(existing_samples | candidate_samples)
  1632	    if union == 0:
  1633	        return False
  1634	    return (intersection / union) >= float(jaccard_threshold)

   628	def _collect_frame_ontology_feature_value_candidates(
   629	    values: Any,
   630	    extracted: List[str],
   631	    *,
   632	    depth: int,
   633	    max_depth: int,
   634	    max_values: int,
   635	) -> None:
   636	    if (
   637	        values is None
   638	        or depth >= max(max_depth, 1)
   639	        or len(extracted) >= max(max_values, 1)
   640	    ):
   641	        return
   642	    if isinstance(values, Mapping):
   643	        for key, value in values.items():
   644	            if len(extracted) >= max(max_values, 1):
   645	                return
   646	            key_text = str(key or "").strip()
   647	            if key_text and is_frame_ontology_feature_key(key_text):
   648	                extracted.append(key_text)
   649	                if len(extracted) >= max(max_values, 1):
   650	                    return
   651	            for synthetic_feature in _synthetic_frame_feature_candidates_from_key_value(
   652	                key_text,
   653	                value,
   654	            ):
   655	                extracted.append(synthetic_feature)
   656	                if len(extracted) >= max(max_values, 1):
   657	                    return
   658	            _collect_frame_ontology_feature_value_candidates(
   659	                value,
   660	                extracted,
   661	                depth=depth + 1,
   662	                max_depth=max_depth,
   663	                max_values=max_values,
   664	            )
   665	        return
   666	    if isinstance(values, Sequence) and not isinstance(values, (str, bytes)):
   667	        for value in values:
   668	            if len(extracted) >= max(max_values, 1):
   669	                return
   670	            _collect_frame_ontology_feature_value_candidates(
   671	                value,
   672	                extracted,
   673	                depth=depth + 1,
   674	                max_depth=max_depth,
   675	                max_values=max_values,
   676	            )
   677	        return
   678	    text = str(values or "").strip()
   679	    if not text:
   680	        return
   681	    parsed = _parsed_frame_ontology_feature_value(text)
   682	    if parsed is not None:
   683	        _collect_frame_ontology_feature_value_candidates(
   684	            parsed,
   685	            extracted,
   686	            depth=depth + 1,
   687	            max_depth=max_depth,
   688	            max_values=max_values,
   689	        )
   690	        return
   691	    extracted.append(text)

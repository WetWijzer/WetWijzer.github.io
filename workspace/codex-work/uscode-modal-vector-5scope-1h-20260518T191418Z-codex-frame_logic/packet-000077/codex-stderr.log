   954	def _normalized_source_id_ontology_value(raw_value: str) -> str:
   955	    text = str(raw_value or "").strip()
   956	    match = _FRAME_ONTOLOGY_SOURCE_ID_RE.match(text)
   957	    if match is None:
   958	        # Slot-value feature keys normalize punctuation to underscores, so
   959	        # source IDs often arrive as `us_code_<title>_<section>_<digest>`.
   960	        # Accept that canonicalized shape to keep source coordinates in audits.
   961	        match = _FRAME_ONTOLOGY_SOURCE_ID_SLOT_NORMALIZED_RE.match(text)
   962	    if match is None:
   963	        match = _FRAME_ONTOLOGY_SOURCE_ID_NO_DIGEST_RE.match(text)
   964	    if match is None:
   965	        match = _FRAME_ONTOLOGY_SOURCE_ID_SLOT_NORMALIZED_NO_DIGEST_RE.match(text)
   966	    if not match:
   967	        return ""
   968	    title = str(match.group("title") or "").strip()
   969	    section = str(match.group("section") or "").strip()
   970	    if not title or not section:
   971	        return ""
   972	    normalized_section = _FRAME_ONTOLOGY_SOURCE_ID_SECTION_TRAILING_PUNCT_RE.sub(
   973	        "",
   974	        section,
   975	    ).strip()
   976	    if normalized_section:
   977	        section = normalized_section
   978	    return f"{title} {section}"

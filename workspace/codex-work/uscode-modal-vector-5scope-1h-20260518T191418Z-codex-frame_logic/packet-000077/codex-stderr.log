   816	
   817	def _deduplicated_ontology_entries(
   818	    entries: Iterable[tuple[str, int]]
   819	) -> List[tuple[str, int]]:
   820	    result: List[tuple[str, int]] = []
   821	    index_by_value: Dict[str, int] = {}
   822	    for value, priority in entries:
   823	        normalized_value = str(value or "").strip()
   824	        if not normalized_value:
   825	            continue
   826	        resolved_priority = int(priority)
   827	        existing_index = index_by_value.get(normalized_value)
   828	        if existing_index is None:
   829	            index_by_value[normalized_value] = len(result)
   830	            result.append((normalized_value, resolved_priority))
   831	            continue
   832	        existing_priority = result[existing_index][1]
   833	        if resolved_priority > existing_priority:
   834	            result[existing_index] = (normalized_value, resolved_priority)
   835	    return result

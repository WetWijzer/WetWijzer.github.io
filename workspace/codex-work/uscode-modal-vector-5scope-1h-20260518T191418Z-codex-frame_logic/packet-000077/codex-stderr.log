    42	    focus = [str(value) for value in introspection.get("synthesis_focus", [])]
    43	    hints: List[ModalProgramSynthesisHint] = []
    44	
    45	    if "add_deterministic_parser_rule" in focus:
    46	        hints.append(
    47	            _hint(
    48	                sample_id,
    49	                action="add_deterministic_parser_rule",
    50	                target_component="modal.compiler",
    51	                rationale="The deterministic compiler produced no modal formulas for this sample.",
    52	                priority=1.0,
    53	                evidence={
    54	                    "target_family": introspection.get("target_family"),
    55	                    "predicted_family": introspection.get("predicted_family"),
    56	                },
    57	            )
    58	        )
    59	
    60	    if "refine_modal_family_cue_rules" in focus:
    61	        hints.append(
    62	            _hint(
    63	                sample_id,
    64	                action="refine_modal_family_cue_rules",
    65	                target_component="modal.compiler.registry",
    66	                rationale="Adaptive family evidence disagrees with, or is weak for, the typed modal family.",
    67	                priority=_priority_from_probability_gap(introspection),
    68	                evidence={
    69	                    "family_margin": introspection.get("family_margin"),
    70	                    "predicted_family": introspection.get("predicted_family"),
    71	                    "target_family": introspection.get("target_family"),
    72	                    "target_probability": introspection.get("target_probability"),
    73	                    "top_family_features": _feature_names(
    74	                        introspection.get("top_family_contributions", [])
    75	                    ),
    76	                },
    77	            )
    78	        )
    79	
    80	    if "refine_typed_ir_or_decompiler_slots" in focus:
    81	        hints.append(
    82	            _hint(
    83	                sample_id,
    84	                action="refine_typed_ir_or_decompiler_slots",
    85	                target_component="modal.ir_decompiler",
    86	                rationale="Embedding residuals point to information not well represented by the typed IR/decompiler.",
    87	                priority=float(introspection.get("reconstruction_loss") or 0.0),
    88	                evidence={
    89	                    "cosine_similarity": introspection.get("cosine_similarity"),
    90	                    "reconstruction_loss": introspection.get("reconstruction_loss"),
    91	                    "top_embedding_features": _feature_names(
    92	                        introspection.get("top_embedding_contributions", [])
    93	                    ),
    94	                },
    95	            )
    96	        )
    97	
    98	    if "audit_frame_logic_terms" in focus:
    99	        frame_features = _frame_features(introspection)
   100	        hints.append(

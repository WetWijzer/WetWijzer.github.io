  1516	) -> List[Dict[str, Any]]:
  1517	    """Select a vector-nearest program-synthesis bundle from pending candidates.
  1518	
  1519	    The first item is always the highest-priority anchor. Neighbors must remain
  1520	    in the same program_synthesis_scope so parallel Codex workers stay inside
  1521	    their AST/write lanes.
  1522	    """
  1523	    if max_items < 1:
  1524	        return []
  1525	    candidates = [
  1526	        todo
  1527	        for todo in sorted(todos, key=_todo_priority_key)
  1528	        if _coerce_vector(vectors_by_todo_id.get(todo.todo_id))
  1529	    ]
  1530	    if not candidates:
  1531	        return []
  1532	
  1533	    anchor = candidates[0]
  1534	    anchor_vector = _coerce_vector(vectors_by_todo_id.get(anchor.todo_id))
  1535	    if not anchor_vector:
  1536	        return []
  1537	
  1538	    selected: List[Dict[str, Any]] = [
  1539	        {"similarity": 1.0, "todo": anchor},
  1540	    ]
  1541	    scored: List[tuple[float, tuple[float, str, str], ModalTodo]] = []
  1542	    for todo in candidates[1:]:
  1543	        if not _program_todo_vector_bundle_compatible(anchor, todo):
  1544	            continue
  1545	        vector = _coerce_vector(vectors_by_todo_id.get(todo.todo_id))
  1546	        if not vector:
  1547	            continue
  1548	        similarity = _cosine_similarity(anchor_vector, vector)
  1549	        if similarity < float(min_similarity):
  1550	            continue
  1551	        scored.append((similarity, _todo_priority_key(todo), todo))
  1552	
  1553	    for similarity, _, todo in sorted(scored, key=lambda item: (-item[0], item[1])):
  1554	        if len(selected) >= max_items:
  1555	            break
  1556	        selected.append({"similarity": similarity, "todo": todo})
  1557	    return selected

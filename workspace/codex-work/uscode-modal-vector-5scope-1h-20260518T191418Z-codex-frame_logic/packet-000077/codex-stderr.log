  4129	def _collect_frame_ontology_metadata_values(
  4130	    values: Any,
  4131	    extracted: List[Any],
  4132	    *,
  4133	    depth: int,
  4134	) -> None:
  4135	    if (
  4136	        values is None
  4137	        or depth >= _FRAME_ONTOLOGY_METADATA_MAX_DEPTH
  4138	        or len(extracted) >= _FRAME_ONTOLOGY_METADATA_MAX_VALUES
  4139	    ):
  4140	        return
  4141	    if isinstance(values, Mapping):
  4142	        normalized_items = [
  4143	            (_frame_ontology_metadata_key(key), key, value)
  4144	            for key, value in values.items()
  4145	        ]
  4146	        preferred_values = [
  4147	            value
  4148	            for normalized_key, _original_key, value in normalized_items
  4149	            if normalized_key in _FRAME_ONTOLOGY_METADATA_VALUE_KEYS
  4150	        ]
  4151	        if preferred_values:
  4152	            for value in preferred_values:
  4153	                _collect_frame_ontology_metadata_values(
  4154	                    value,
  4155	                    extracted,
  4156	                    depth=depth + 1,
  4157	                )
  4158	                if len(extracted) >= _FRAME_ONTOLOGY_METADATA_MAX_VALUES:
  4159	                    return
  4160	            return
  4161	        for normalized_key, original_key, value in normalized_items:
  4162	            if _frame_ontology_metadata_key_is_term_like(
  4163	                normalized_key,
  4164	                original_key,
  4165	            ):
  4166	                extracted.append(original_key)
  4167	                if len(extracted) >= _FRAME_ONTOLOGY_METADATA_MAX_VALUES:
  4168	                    return
  4169	            _collect_frame_ontology_metadata_values(
  4170	                value,
  4171	                extracted,
  4172	                depth=depth + 1,
  4173	            )
  4174	            if len(extracted) >= _FRAME_ONTOLOGY_METADATA_MAX_VALUES:
  4175	                return
  4176	        return
  4177	    if isinstance(values, Sequence) and not isinstance(values, (str, bytes)):
  4178	        for value in values:
  4179	            _collect_frame_ontology_metadata_values(
  4180	                value,
  4181	                extracted,
  4182	                depth=depth + 1,
  4183	            )
  4184	            if len(extracted) >= _FRAME_ONTOLOGY_METADATA_MAX_VALUES:
  4185	                return
  4186	        return
  4187	    extracted.append(values)

   121	                target_component="modal.compiler.ambiguity",
   122	                rationale="The adaptive family margin is small, so the compiler should expose an explicit ambiguity.",
   123	                priority=0.15 - _family_margin(introspection),
   124	                evidence={
   125	                    "family_margin": introspection.get("family_margin"),
   126	                    "predicted_family": introspection.get("predicted_family"),
   127	                    "target_family": introspection.get("target_family"),
   128	                },
   129	            )
   130	        )
   131	
   132	    return sorted(hints, key=lambda hint: (-hint.priority, hint.hint_id))

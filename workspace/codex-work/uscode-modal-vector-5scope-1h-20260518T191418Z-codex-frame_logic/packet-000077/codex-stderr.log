   787	def _bounded_ontology_values(
   788	    entries: Iterable[tuple[str, int]],
   789	    *,
   790	    max_items: int,
   791	) -> List[str]:
   792	    """Return deterministic bounded values with overflow priority handling."""
   793	    if max_items <= 0:
   794	        return []
   795	    deduplicated = _deduplicated_ontology_entries(entries)
   796	    if len(deduplicated) <= max_items:
   797	        return [value for value, _priority in deduplicated]
   798	
   799	    selected: List[str] = []
   800	    seen: set[str] = set()
   801	    for priority in (
   802	        _FRAME_ONTOLOGY_TERM_PRIORITY_DIRECT,
   803	        _FRAME_ONTOLOGY_TERM_PRIORITY_CONTEXTUAL,
   804	        _FRAME_ONTOLOGY_TERM_PRIORITY_CONTEXTUAL_STRUCTURAL,
   805	        _FRAME_ONTOLOGY_TERM_PRIORITY_NONE,
   806	    ):
   807	        for value, entry_priority in deduplicated:
   808	            if entry_priority != priority or value in seen:
   809	                continue
   810	            selected.append(value)
   811	            seen.add(value)
   812	            if len(selected) >= max_items:
   813	                return selected
   814	    return selected

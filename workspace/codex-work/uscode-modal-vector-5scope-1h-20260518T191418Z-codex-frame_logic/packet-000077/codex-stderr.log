   728	def _parsed_frame_ontology_feature_value(text: str) -> Any | None:
   729	    stripped = str(text or "").strip()
   730	    if not stripped or len(stripped) > _FRAME_ONTOLOGY_FEATURE_VALUE_JSON_MAX_LENGTH:
   731	        return None
   732	    is_json_object = stripped.startswith("{") and stripped.endswith("}")
   733	    is_json_array = stripped.startswith("[") and stripped.endswith("]")
   734	    if not (is_json_object or is_json_array):
   735	        return None
   736	    try:
   737	        parsed = json.loads(stripped)
   738	    except json.JSONDecodeError:
   739	        return None
   740	    if isinstance(parsed, Mapping):
   741	        return parsed
   742	    if isinstance(parsed, Sequence) and not isinstance(parsed, (str, bytes)):
   743	        return parsed
   744	    return None

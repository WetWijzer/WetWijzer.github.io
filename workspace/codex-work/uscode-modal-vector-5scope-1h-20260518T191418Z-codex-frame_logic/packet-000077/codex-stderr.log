   694	def _synthetic_frame_feature_candidates_from_key_value(
   695	    key_text: str,
   696	    value: Any,
   697	) -> List[str]:
   698	    normalized_key = _FRAME_ONTOLOGY_PREDICATE_TOKEN_RE.sub(
   699	        "_",
   700	        str(key_text or "").strip().lower(),
   701	    ).strip("_")
   702	    if not normalized_key:
   703	        return []
   704	    prefix = _FRAME_ONTOLOGY_VALUE_KEY_FEATURE_PREFIXES.get(normalized_key)
   705	    if not prefix:
   706	        return []
   707	    candidates: List[str] = []
   708	    values: Sequence[Any]
   709	    if isinstance(value, Sequence) and not isinstance(value, (str, bytes)):
   710	        values = value
   711	    else:
   712	        values = (value,)
   713	    for item in values:
   714	        if isinstance(item, Mapping):
   715	            continue
   716	        if isinstance(item, Sequence) and not isinstance(item, (str, bytes)):
   717	            continue
   718	        text = str(item or "").strip()
   719	        if not text:
   720	            continue
   721	        if is_frame_ontology_feature_key(text):
   722	            candidates.append(text)
   723	            continue
   724	        candidates.append(f"{prefix}{text}")
   725	    return candidates

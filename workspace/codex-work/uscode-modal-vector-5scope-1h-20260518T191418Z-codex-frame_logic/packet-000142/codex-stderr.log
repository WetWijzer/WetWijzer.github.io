   868	def _deduplicated_ontology_entries(
   869	    entries: Iterable[tuple[str, int]]
   870	) -> List[tuple[str, int]]:
   871	    result: List[tuple[str, int]] = []
   872	    index_by_value: Dict[str, int] = {}
   873	    for value, priority in entries:
   874	        normalized_value = str(value or "").strip()
   875	        if not normalized_value:
   876	            continue
   877	        resolved_priority = int(priority)
   878	        existing_index = index_by_value.get(normalized_value)
   879	        if existing_index is None:
   880	            index_by_value[normalized_value] = len(result)
   881	            result.append((normalized_value, resolved_priority))
   882	            continue
   883	        existing_priority = result[existing_index][1]
   884	        if resolved_priority > existing_priority:
   885	            result[existing_index] = (normalized_value, resolved_priority)
   886	    return result

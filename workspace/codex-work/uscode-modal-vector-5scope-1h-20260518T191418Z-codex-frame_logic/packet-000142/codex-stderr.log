   747	    is_json_array = stripped.startswith("[") and stripped.endswith("]")
   748	    if not (is_json_object or is_json_array):
   749	        return None
   750	    try:
   751	        parsed = json.loads(stripped)
   752	    except json.JSONDecodeError:
   753	        return None
   754	    if isinstance(parsed, Mapping):
   755	        return parsed
   756	    if isinstance(parsed, Sequence) and not isinstance(parsed, (str, bytes)):
   757	        return parsed

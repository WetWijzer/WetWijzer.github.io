   838	def _bounded_ontology_values(
   839	    entries: Iterable[tuple[str, int]],
   840	    *,
   841	    max_items: int,
   842	) -> List[str]:
   843	    """Return deterministic bounded values with overflow priority handling."""
   844	    if max_items <= 0:
   845	        return []
   846	    deduplicated = _deduplicated_ontology_entries(entries)
   847	    if len(deduplicated) <= max_items:
   848	        return [value for value, _priority in deduplicated]

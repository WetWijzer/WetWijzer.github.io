   645	    *,
   646	    depth: int,
   647	    max_depth: int,
   648	    max_values: int,
   649	) -> None:
   650	    if (
   651	        values is None
   652	        or depth >= max(max_depth, 1)
   653	        or len(extracted) >= max(max_values, 1)
   654	    ):
   655	        return
   656	    if isinstance(values, Mapping):

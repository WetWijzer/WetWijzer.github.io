  1463	def _softmax(logits: Mapping[str, float]) -> Dict[str, float]:
  1464	    if not logits:
  1465	        return {}
  1466	    max_logit = max(float(value) for value in logits.values())
  1467	    exponentials = {
  1468	        name: math.exp(float(value) - max_logit)
  1469	        for name, value in logits.items()
  1470	    }
  1471	    total = sum(exponentials.values())
  1472	    if total == 0.0:
  1473	        uniform = 1.0 / len(exponentials)
  1474	        return {name: uniform for name in sorted(exponentials)}
  1475	    return {name: exponentials[name] / total for name in sorted(exponentials)}

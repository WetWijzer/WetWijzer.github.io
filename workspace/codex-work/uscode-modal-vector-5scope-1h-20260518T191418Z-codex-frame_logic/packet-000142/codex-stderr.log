   695	    parsed = _parsed_frame_ontology_feature_value(text)
   696	    if parsed is not None:
   697	        _collect_frame_ontology_feature_value_candidates(
   698	            parsed,
   699	            extracted,
   700	            depth=depth + 1,
   701	            max_depth=max_depth,
   702	            max_values=max_values,
   703	        )
   704	        return
   705	    extracted.append(text)

     1	"""
     2	F-logic semantic-preservation optimizer.
     3	
     4	This module provides :class:`FLogicSemanticOptimizer`, which uses F-logic
     5	consistency checking to measure and improve the semantic fidelity of the
     6	
     7	    Natural Language ──► Encoder(KG + F-logic ontology) ──► Decoder ──► NL
     8	
     9	round-trip pipeline.  Semantic preservation is scored as the cosine similarity
    10	between the embedding of the source text and the embedding of the decoded
    11	output.  When the score falls below a configurable threshold the optimizer can
    12	trigger a refinement pass.
    13	
    14	The F-logic layer (via :mod:`ipfs_datasets_py.logic.flogic`) verifies that the
    15	intermediate knowledge representation is *ontologically consistent* — i.e. that
    16	the encoded triples satisfy the class hierarchy and method signatures defined in
    17	the ontology.  Inconsistencies are reported alongside the cosine similarity
    18	score so that callers can decide how to handle them.
    19	
    20	Example::
    21	
    22	    from ipfs_datasets_py.logic.flogic_optimizer import (
    23	        FLogicSemanticOptimizer,
    24	        FLogicOptimizerConfig,
    25	    )
    26	
    27	    config = FLogicOptimizerConfig(similarity_threshold=0.85)
    28	    optimizer = FLogicSemanticOptimizer(config=config)
    29	
    30	    result = optimizer.evaluate(
    31	        source_text="The dog ran across the park.",
    32	        decoded_text="A canine sprinted through the green space.",
    33	        source_embedding=[0.1, 0.2, ...],
    34	        decoded_embedding=[0.11, 0.19, ...],
    35	    )
    36	    print(result.similarity_score)       # 0.97
    37	    print(result.ontology_consistent)    # True
    38	    print(result.passed)                 # True
    39	"""
    40	
    41	from __future__ import annotations
    42	
    43	import logging
    44	import math
    45	import json
    46	from dataclasses import dataclass, field
    47	from typing import Any, Dict, List, Mapping, Optional, Sequence
    48	
    49	from ipfs_datasets_py.optimizers.logic_theorem_optimizer.frame_bm25_selector import (
    50	    frame_ontology_contextualized_terms,
    51	    frame_ontology_feature_keys,
    52	    frame_ontology_feature_keys_from_values,
    53	    frame_ontology_high_signal_terms,
    54	    frame_ontology_terms_from_feature_keys,
    55	    frame_ontology_terms_from_triples,
    56	)
    57	
    58	logger = logging.getLogger(__name__)
    59	
    60	
    61	# ---------------------------------------------------------------------------
    62	# Configuration
    63	# ---------------------------------------------------------------------------
    64	
    65	
    66	@dataclass
    67	class FLogicOptimizerConfig:
    68	    """
    69	    Configuration for :class:`FLogicSemanticOptimizer`.
    70	
    71	    Attributes:
    72	        similarity_threshold: Minimum cosine similarity required for the
    73	            round-trip to be considered semantically preserved.  Default 0.80.
    74	        check_ontology_consistency: When ``True`` the optimizer also verifies
    75	            F-logic ontology constraints on the encoded representation.
    76	        max_refinement_rounds: Maximum number of automatic refinement passes
    77	            before giving up.  Set to ``0`` to disable automatic refinement.
    78	        ontology_name: Name used when constructing the internal
    79	            :class:`~ipfs_datasets_py.logic.flogic.FLogicOntology`.
    80	    """
    81	
    82	    similarity_threshold: float = 0.80
    83	    check_ontology_consistency: bool = True
    84	    max_refinement_rounds: int = 1
    85	    ontology_name: str = "kg_ontology"
    86	
    87	
    88	# ---------------------------------------------------------------------------
    89	# Result types
    90	# ---------------------------------------------------------------------------
    91	
    92	
    93	@dataclass
    94	class OntologyViolation:
    95	    """Describes a single F-logic constraint violation."""
    96	
    97	    frame_id: str
    98	    constraint: str
    99	    details: str
   100	
   101	
   102	@dataclass
   103	class FLogicOptimizerResult:
   104	    """
   105	    Result returned by :meth:`FLogicSemanticOptimizer.evaluate`.
   106	
   107	    Attributes:
   108	        similarity_score: Cosine similarity ∈ [-1, 1] between source and
   109	            decoded embeddings.
   110	        passed: ``True`` when similarity ≥ threshold and no blocking violations.
   111	        ontology_consistent: ``True`` when no F-logic constraints were violated.
   112	        violations: List of constraint violations (empty when consistent).
   113	        refinement_rounds: Number of refinement passes that were applied.
   114	        metadata: Additional diagnostic information.
   115	    """
   116	
   117	    similarity_score: float
   118	    passed: bool
   119	    ontology_consistent: bool
   120	    violations: List[OntologyViolation] = field(default_factory=list)
   121	    refinement_rounds: int = 0
   122	    metadata: Dict[str, Any] = field(default_factory=dict)
   123	
   124	
   125	# ---------------------------------------------------------------------------
   126	# Optimizer
   127	# ---------------------------------------------------------------------------
   128	
   129	
   130	class FLogicSemanticOptimizer:
   131	    """
   132	    Optimizer that uses F-logic to preserve semantic meaning across the
   133	    NL → Encoder(KG + formal logic) → Decoder(NL) pipeline.
   134	
   135	    The optimizer:
   136	
   137	    1. Computes the cosine similarity between source and decoded embeddings.
   138	    2. Optionally validates the knowledge-graph triples against an F-logic
   139	       ontology using :class:`~ipfs_datasets_py.logic.flogic.ErgoAIWrapper`.
   140	    3. Returns a :class:`FLogicOptimizerResult` describing whether semantic
   141	       preservation passed and listing any ontology violations.
   142	
   143	    The F-logic check is performed in *simulation mode* when the ErgoAI binary
   144	    is not installed, which means no external dependencies are required.
   145	
   146	    Args:
   147	        config: Optimizer configuration.  Defaults to :class:`FLogicOptimizerConfig`.
   148	    """
   149	
   150	    def __init__(self, config: Optional[FLogicOptimizerConfig] = None) -> None:
   151	        self.config = config or FLogicOptimizerConfig()
   152	        self._ergo: Any = None  # lazy-loaded ErgoAIWrapper
   153	
   154	    # ------------------------------------------------------------------
   155	    # Public API
   156	    # ------------------------------------------------------------------
   157	
   158	    def evaluate(
   159	        self,
   160	        source_text: str,
   161	        decoded_text: str,
   162	        source_embedding: Sequence[float],
   163	        decoded_embedding: Sequence[float],
   164	        kg_triples: Optional[List[Dict[str, str]]] = None,
   165	        *,
   166	        frame_feature_keys: Optional[Sequence[str]] = None,
   167	    ) -> FLogicOptimizerResult:
   168	        """
   169	        Evaluate semantic preservation between *source_text* and *decoded_text*.
   170	
   171	        Args:
   172	            source_text: Original natural language input.
   173	            decoded_text: Reconstructed text after KG encoding and decoding.
   174	            source_embedding: Dense vector embedding of *source_text*.
   175	            decoded_embedding: Dense vector embedding of *decoded_text*.
   176	            kg_triples: Optional list of ``{"subject": …, "predicate": …,
   177	                "object": …}`` dicts representing the encoded knowledge-graph
   178	                triples.  Used for F-logic consistency checking.
   179	            frame_feature_keys: Optional modal/frame-logic audit features from
   180	                the deterministic modal codec. These are recorded as diagnostics
   181	                and do not alter the F-logic consistency decision.
   182	
   183	        Returns:
   184	            :class:`FLogicOptimizerResult` with similarity score, pass/fail
   185	            status, and any ontology violations.
   186	        """
   187	        similarity = _cosine_similarity(
   188	            list(source_embedding), list(decoded_embedding)
   189	        )
   190	        violations: List[OntologyViolation] = []
   191	        ontology_consistent = True
   192	
   193	        if self.config.check_ontology_consistency and kg_triples:
   194	            violations = self._check_flogic_consistency(kg_triples)
   195	            ontology_consistent = len(violations) == 0
   196	
   197	        passed = (
   198	            similarity >= self.config.similarity_threshold and ontology_consistent
   199	        )
   200	
   201	        frame_metadata = _frame_ontology_metadata(
   202	            kg_triples=kg_triples or [],
   203	            frame_feature_keys=frame_feature_keys or [],
   204	        )
   205	
   206	        return FLogicOptimizerResult(
   207	            similarity_score=similarity,
   208	            passed=passed,
   209	            ontology_consistent=ontology_consistent,
   210	            violations=violations,
   211	            metadata={
   212	                "source_text": source_text,
   213	                "decoded_text": decoded_text,
   214	                "threshold": self.config.similarity_threshold,
   215	                **frame_metadata,
   216	            },
   217	        )
   218	
   219	    def add_ontology_class(
   220	        self,
   221	        class_id: str,
   222	        superclasses: Optional[List[str]] = None,
   223	        signature_methods: Optional[Dict[str, str]] = None,
   224	    ) -> None:
   225	        """
   226	        Register an F-logic class in the internal ontology.
   227	
   228	        This method is additive — call it once per class before running
   229	        :meth:`evaluate` with ``kg_triples``.
   230	
   231	        Args:
   232	            class_id: Name of the class.
   233	            superclasses: Direct parent classes.
   234	            signature_methods: ``{method_name: value_type}`` signatures.
   235	        """
   236	        from ipfs_datasets_py.logic.flogic import FLogicClass
   237	
   238	        ergo = self._get_ergo()
   239	        ergo.add_class(
   240	            FLogicClass(
   241	                class_id=class_id,
   242	                superclasses=superclasses or [],
   243	                signature_methods=signature_methods or {},
   244	            )
   245	        )
   246	
   247	    def get_statistics(self) -> Dict[str, Any]:
   248	        """Return statistics about the optimizer and its internal ErgoAI wrapper."""
   249	        stats: Dict[str, Any] = {
   250	            "similarity_threshold": self.config.similarity_threshold,
   251	            "check_ontology_consistency": self.config.check_ontology_consistency,
   252	            "max_refinement_rounds": self.config.max_refinement_rounds,
   253	        }
   254	        if self._ergo is not None:
   255	            stats["ergoai"] = self._ergo.get_statistics()
   256	        return stats
   257	
   258	    # ------------------------------------------------------------------
   259	    # Internal helpers
   260	    # ------------------------------------------------------------------
   261	
   262	    def _get_ergo(self):
   263	        """Lazily initialise the ErgoAI wrapper."""
   264	        if self._ergo is None:
   265	            from ipfs_datasets_py.logic.flogic import ErgoAIWrapper
   266	
   267	            self._ergo = ErgoAIWrapper(
   268	                ontology_name=self.config.ontology_name
   269	            )
   270	        return self._ergo
   271	
   272	    def _check_flogic_consistency(
   273	        self, kg_triples: List[Dict[str, str]]
   274	    ) -> List[OntologyViolation]:
   275	        """
   276	        Convert *kg_triples* to F-logic frames and verify class constraints.
   277	
   278	        Returns a list of :class:`OntologyViolation` objects (empty → consistent).
   279	        """
   280	        from ipfs_datasets_py.logic.flogic import FLogicFrame
   281	
   282	        ergo = self._get_ergo()
   283	        violations: List[OntologyViolation] = []
   284	
   285	        # Group triples by subject to build frames
   286	        subject_map: Dict[str, Dict[str, str]] = {}
   287	        for triple in kg_triples:
   288	            subj = triple.get("subject", "")
   289	            pred = triple.get("predicate", "")
   290	            obj = triple.get("object", "")
   291	            if not subj:
   292	                continue
   293	            if subj not in subject_map:
   294	                subject_map[subj] = {}
   295	            subject_map[subj][pred] = obj
   296	
   297	        # Add frames to ergo and query for known constraint violations
   298	        for subj, methods in subject_map.items():
   299	            frame = FLogicFrame(object_id=subj, scalar_methods=methods)
   300	            ergo.add_frame(frame)
   301	
   302	        # In simulation mode we trust the F-logic types; no violations raised
   303	        # unless a method key is blank (structural sanity check only)
   304	        for subj, methods in subject_map.items():
   305	            for pred, obj in methods.items():
   306	                if not pred:
   307	                    violations.append(
   308	                        OntologyViolation(
   309	                            frame_id=subj,
   310	                            constraint="non_empty_predicate",
   311	                            details=f"Triple ({subj!r}, '', {obj!r}) has empty predicate",
   312	                        )
   313	                    )
   314	
   315	        return violations
   316	
   317	
   318	# ---------------------------------------------------------------------------
   319	# Utility
   320	# ---------------------------------------------------------------------------
   321	
   322	
   323	def _cosine_similarity(a: List[float], b: List[float]) -> float:
   324	    """Compute cosine similarity between two vectors."""
   325	    if len(a) != len(b):
   326	        raise ValueError(
   327	            f"Embedding dimension mismatch: {len(a)} vs {len(b)}"
   328	        )
   329	    dot = sum(x * y for x, y in zip(a, b))
   330	    norm_a = math.sqrt(sum(x * x for x in a))
   331	    norm_b = math.sqrt(sum(y * y for y in b))
   332	    if norm_a == 0.0 or norm_b == 0.0:
   333	        return 0.0
   334	    return dot / (norm_a * norm_b)
   335	
   336	
   337	def _frame_ontology_metadata(
   338	    *,
   339	    kg_triples: Sequence[Mapping[str, Any]],
   340	    frame_feature_keys: Sequence[Any],
   341	) -> Dict[str, Any]:
   342	    feature_keys = _normalized_frame_feature_keys(frame_feature_keys)
   343	    audit_feature_keys = sorted(
   344	        frame_ontology_feature_keys(
   345	            feature_keys
   346	            + frame_ontology_feature_keys_from_values(frame_feature_keys)
   347	        )
   348	    )
   349	    feature_terms = sorted(
   350	        frame_ontology_terms_from_feature_keys(audit_feature_keys)
   351	    )
   352	    triple_terms = sorted(
   353	        frame_ontology_terms_from_triples(kg_triples)
   354	    )
   355	    contextualized_terms = sorted(
   356	        frame_ontology_contextualized_terms(
   357	            feature_keys=audit_feature_keys,
   358	            triples=kg_triples,
   359	        )
   360	    )


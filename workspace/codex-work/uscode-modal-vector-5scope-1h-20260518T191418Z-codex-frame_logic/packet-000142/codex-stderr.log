   850	    selected: List[str] = []
   851	    seen: set[str] = set()
   852	    for priority in (
   853	        _FRAME_ONTOLOGY_TERM_PRIORITY_DIRECT,
   854	        _FRAME_ONTOLOGY_TERM_PRIORITY_CONTEXTUAL,
   855	        _FRAME_ONTOLOGY_TERM_PRIORITY_CONTEXTUAL_STRUCTURAL,
   856	        _FRAME_ONTOLOGY_TERM_PRIORITY_NONE,
   857	    ):
   858	        for value, entry_priority in deduplicated:
   859	            if entry_priority != priority or value in seen:
   860	                continue
   861	            selected.append(value)
   862	            seen.add(value)
   863	            if len(selected) >= max_items:
   864	                return selected
   865	    return selected

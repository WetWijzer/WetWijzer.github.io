   671	                    return
   672	            _collect_frame_ontology_feature_value_candidates(
   673	                value,
   674	                extracted,
   675	                depth=depth + 1,
   676	                max_depth=max_depth,
   677	                max_values=max_values,
   678	            )
   679	        return
   680	    if isinstance(values, Sequence) and not isinstance(values, (str, bytes)):
   681	        for value in values:
   682	            if len(extracted) >= max(max_values, 1):
   683	                return
   684	            _collect_frame_ontology_feature_value_candidates(
   685	                value,
   686	                extracted,
   687	                depth=depth + 1,
   688	                max_depth=max_depth,
   689	                max_values=max_values,
   690	            )
   691	        return
   692	    text = str(values or "").strip()
   693	    if not text:

@dataclass(frozen=True)
class FrameSelection:
    """BM25 selection result with deterministic explanation fields."""

    frame: FrameCandidate
    score: float
    matched_terms: List[str]
    explanation: str

    def to_dict(self) -> Dict[str, object]:

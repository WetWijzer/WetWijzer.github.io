+                "source": "logit_softmax_fallback",
+            },
+            {
+                "family": ModalLogicFamily.DEONTIC.value,
+                "count": 0,
+                "logit": 1.4,
+                "share_raw": 0.36,
+                "share": 0.36,
+                "source": "logit_softmax_fallback",
+            },
+            {
+                "family": ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
+                "count": 0,
+                "logit": 1.35,
+                "share_raw": 0.35,
+                "share": 0.35,
+                "source": "logit_softmax_fallback",
+            },
+            {
+                "family": ModalLogicFamily.FRAME.value,
+                "count": 0,

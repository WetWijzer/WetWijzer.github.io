+def test_compiler_uses_logit_softmax_margin_for_adaptive_pair_policy() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    result = compiler.compile(
+        "As provided in section 3, this authority applies.",
+        document_id="compiler-ambiguity-adaptive-logit-margin",
+    )
+    ambiguity = _adaptive_explicit_pair(
+        result,
+        predicted_family=ModalLogicFamily.FRAME.value,
+        target_family=ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
+    )
+    assert ambiguity is not None
+    metadata = ambiguity.metadata
+    assert float(metadata.get("predicted_share") or 0.0) < 1.0
+    assert float(metadata.get("target_share") or 0.0) > 0.0
+    assert float(metadata.get("family_margin") or 0.0) > -1.0
+    ranking = metadata.get("family_ranking") or []
+    assert ranking
+    assert str(ranking[0].get("source") or "") == "logit_softmax_fallback"
+
+
+def test_compiler_uses_runner_up_gap_for_adaptive_deontic_self_pair_margin() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(
+            parser_backend="spacy",
+            modal_adaptive_family_margin=0.5,
+        )
+    )
+
+    result = compiler.compile(
+        "The Secretary shall, by June 1, 2030, submit the report and may revise it.",
+        document_id="compiler-ambiguity-adaptive-self-gap",
+    )
+    ambiguity = _adaptive_explicit_pair(
+        result,
+        predicted_family=ModalLogicFamily.DEONTIC.value,
+        target_family=ModalLogicFamily.DEONTIC.value,
+    )
+    assert ambiguity is not None
+    assert ambiguity.ambiguity_type.endswith("contested_margin_low")
+    metadata = ambiguity.metadata
+    family_margin = float(metadata.get("family_margin") or 0.0)
+    runner_up_margin = float(metadata.get("predicted_margin_to_runner_up") or 0.0)
+    assert family_margin > 0.0
+    assert family_margin == runner_up_margin

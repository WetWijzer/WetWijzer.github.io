   423	class ModalRegistry:
   424	    """Lookup table for modal parse profiles."""
   425	
   426	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   427	        self._profiles: Dict[str, ModalParseProfile] = {
   428	            profile.profile_id: profile for profile in profiles
   429	        }
   430	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   431	            profile.family: profile for profile in profiles
   432	        }
   433	
   434	    def get_profile(
   435	        self,
   436	        family: ModalLogicFamily | str,
   437	        system: Optional[ModalSystem | str] = None,
   438	    ) -> ModalParseProfile:
   439	        """Get a profile by family, optionally constrained by system."""
   440	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   441	        if system is None:
   442	            return self._by_family[resolved_family]
   443	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   444	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   445	
   446	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   447	        """Return all profiles in deterministic order."""
   448	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   449	
   450	    def to_dict(self) -> Mapping[str, object]:
   451	        """Return a stable JSON-ready registry mapping."""
   452	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   453	
   454	
   455	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   456	    """Return whether a modal family encodes normative legal force."""
   457	    if isinstance(family, ModalLogicFamily):
   458	        resolved = family
   459	    else:
   460	        try:
   461	            resolved = ModalLogicFamily(str(family))
   462	        except ValueError:
   463	            return False
   464	    return resolved in NORMATIVE_MODAL_FAMILIES
   465	
   466	
   467	def supports_signal_free_adaptive_ambiguity_pair(
   468	    predicted_family: ModalLogicFamily | str,
   469	    target_family: ModalLogicFamily | str,
   470	) -> bool:
   471	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   472	    resolved_target_family = _resolve_modal_family_name(target_family)
   473	    return resolved_target_family in signal_free_adaptive_ambiguity_targets(
   474	        predicted_family
   475	    )
   476	
   477	
   478	def signal_free_adaptive_ambiguity_targets(
   479	    predicted_family: ModalLogicFamily | str,
   480	) -> Tuple[str, ...]:
   481	    """Return ordered adaptive-ambiguity targets requiring signal-free handling."""
   482	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   483	    return tuple(
   484	        target_family
   485	        for source_family, target_family in SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   486	        if source_family == resolved_predicted_family
   487	    )
   488	
   489	
   490	def is_priority_signal_free_adaptive_ambiguity_pair(
   491	    predicted_family: ModalLogicFamily | str,
   492	    target_family: ModalLogicFamily | str,
   493	) -> bool:
   494	    """Return whether a pair is part of the highest-priority adaptive ambiguity policy."""
   495	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   496	    resolved_target_family = _resolve_modal_family_name(target_family)
   497	    return (
   498	        resolved_predicted_family,
   499	        resolved_target_family,
   500	    ) in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   501	
   502	
   503	def _resolve_modal_family_name(family: ModalLogicFamily | str) -> str:
   504	    if isinstance(family, ModalLogicFamily):
   505	        return family.value
   506	    try:
   507	        return ModalLogicFamily(str(family)).value
   508	    except ValueError:
   509	        return str(family).strip().lower()
   510	
   511	
   512	DEFAULT_MODAL_REGISTRY = ModalRegistry()
   513	
   514	

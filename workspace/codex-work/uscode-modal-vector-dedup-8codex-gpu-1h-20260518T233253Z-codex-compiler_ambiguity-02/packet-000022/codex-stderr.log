+                candidate_ids=[compiled_primary_family, competing_family],
+                severity="requires_rule" if requires_rule else "review",
+                metadata={
+                    **base_metadata,
+                    "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
+                },
+            ),
+        ]

   894	            family_margin < 0.0
   895	            or (family_margin <= 0.0 and is_priority_policy_pair)
   896	        ) else "contested"
   897	        requires_rule = margin_direction == "outvoted"
   898	        explicit_type = self._adaptive_margin_explicit_type(
   899	            compiled_primary_family,
   900	            competing_family,
   901	            margin_direction,
   902	        )
   903	        primary_share_display = round(primary_share, 6)
   904	        competing_share_display = round(competing_share, 6)
   905	        family_margin_display = round(
   906	            primary_share_display - competing_share_display,
   907	            6,
   908	        )
   909	        base_metadata = {
   910	            "adaptive_family_margin_threshold": threshold,
   911	            "adaptive_margin_direction": margin_direction,
   912	            "adaptive_predicted_family_source": "compiled_primary_family",
   913	            "explicit_ambiguity_type": explicit_type,
   914	            "family_margin_raw": family_margin,
   915	            "family_margin": family_margin_display,
   916	            "family_ranking": list(ranking),
   917	            "compiled_modal_families": sorted(compiled_modal_families),
   918	            "has_target_signal_evidence": has_target_signal_evidence,
   919	            "signal_free_pair_policy_applied": (
   920	                not has_target_signal_evidence
   921	            ),
   922	            "has_compiled_target_family_formula": has_compiled_target_family_formula,
   923	            "has_frame_bm25_support": has_frame_bm25_support,
   924	            "lexical_signals": dict(sorted(signals.items())),
   925	            "is_priority_policy_pair": is_priority_policy_pair,
   926	            "predicted_family": compiled_primary_family,
   927	            "predicted_margin_to_runner_up_raw": family_margin,
   928	            "predicted_margin_to_runner_up": round(family_margin, 6),
   929	            "runner_up_family": competing_family,
   930	            "runner_up_share_raw": competing_share,


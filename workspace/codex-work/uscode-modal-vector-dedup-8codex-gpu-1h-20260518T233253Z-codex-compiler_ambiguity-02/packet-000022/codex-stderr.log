        temporal_result,
        predicted_family=ModalLogicFamily.FRAME.value,
        target_family=ModalLogicFamily.TEMPORAL.value,
    )
    assert _has_adaptive_explicit_pair(
        temporal_result,
        predicted_family=ModalLogicFamily.FRAME.value,
        target_family=ModalLogicFamily.DEONTIC.value,
    )



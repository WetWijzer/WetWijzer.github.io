   854	    def _compiled_primary_family_adaptive_pair_ambiguities(
   855	        self,
   856	        *,
   857	        compiled_primary_family: str,
   858	        competing_family: str,
   859	        ranking: Sequence[Dict[str, Any]],
   860	        family_shares: Dict[str, float],
   861	        threshold: float,
   862	        signals: Mapping[str, bool],
   863	        has_frame_scope: bool,
   864	        has_frame_bm25_support: bool,
   865	        compiled_modal_families: Sequence[str],
   866	    ) -> List[ModalCompilationAmbiguity]:
   867	        if not self._supports_signal_free_adaptive_pair(
   868	            compiled_primary_family,
   869	            competing_family,
   870	        ):
   871	            return []
   872	        primary_share = float(family_shares.get(compiled_primary_family, 0.0))
   873	        competing_share = float(family_shares.get(competing_family, 0.0))
   874	        family_margin = primary_share - competing_share
   875	        if family_margin > threshold:
   876	            return []
   877	        target_signal_by_family = self._adaptive_target_signal_by_family(
   878	            compiled_primary_family,
   879	            signals=signals,
   880	            has_frame_scope=has_frame_scope,
   881	        )
   882	        has_signal = bool(target_signal_by_family.get(competing_family, False))
   883	        has_compiled_target_family_formula = competing_family in compiled_modal_families
   884	        has_target_signal_evidence = bool(

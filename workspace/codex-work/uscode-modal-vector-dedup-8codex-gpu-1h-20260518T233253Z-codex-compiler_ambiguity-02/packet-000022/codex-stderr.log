            ranking.append(
                {
                    "family": family,
                    "count": 0,
                    "logit": round(float(logits[family]), 6),
                    "share_raw": share_raw,
                    "share": round(share_raw, 6),
                    "source": "logit_softmax_fallback",
                }
            )
        return ranking


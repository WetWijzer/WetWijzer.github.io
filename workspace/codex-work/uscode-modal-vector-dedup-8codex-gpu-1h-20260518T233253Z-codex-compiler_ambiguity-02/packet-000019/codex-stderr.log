   107	class DeterministicModalCompiler:
   108	    """Compile legal text into modal IR with explainable frame selection."""
   109	
   110	    def __init__(
   111	        self,
   112	        config: Optional[ModalCompilerConfig] = None,
   113	        *,
   114	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
   115	        frame_selector: Optional[BM25FrameSelector] = None,
   116	    ) -> None:
   117	        self.config = config or ModalCompilerConfig()
   118	        self.registry = registry
   119	        self.parser = LegalModalParser(registry=registry)
   120	        self.encoder = SpaCyLegalEncoder(
   121	            model_name=self.config.spacy_model_name,
   122	            registry=registry,
   123	        )
   124	        self.decoder = SpaCyModalDecoder()
   125	        self.ir_compiler = SpaCyModalIRCompiler()
   126	        self.frame_selector = frame_selector or BM25FrameSelector(DEFAULT_LEGAL_FRAME_FIXTURE)
   127	
   128	    def compile(
   129	        self,
   130	        text: str,
   131	        *,
   132	        document_id: Optional[str] = None,
   133	        citation: Optional[str] = None,
   134	        source: str = "legal_text",
   135	    ) -> ModalCompilationResult:
   136	        """Compile text into modal IR using deterministic rules only."""
   137	        normalized_text = self.parser.normalize_text(text)
   138	        backend = self.config.parser_backend.lower().strip()
   139	        encoding: Optional[SpaCyLegalEncoding] = self.encoder.encode(
   140	            text,
   141	            document_id=document_id,
   142	            citation=citation,
   143	            source=source,
   144	        )
   145	        if backend in {"regex", "legal", "legal_modal_parser", "deontic", "deontic:d"}:
   146	            modal_ir = self.parser.parse(
   147	                text,
   148	                document_id=document_id or encoding.document_id,
   149	                citation=citation,
   150	                source=source,
   151	            )
   152	            parser_name = "legal_modal_parser_v1"
   153	        else:
   154	            modal_ir = self.ir_compiler.compile(encoding)
   155	            parser_name = "spacy_modal_codec_v1"
   156	
   157	        frame_selections = self.frame_selector.rank(
   158	            normalized_text,
   159	            top_k=self.config.top_k_frames,
   160	            domain=self.config.frame_domain,
   161	        )
   162	        frame_candidates = [selection.to_dict() for selection in frame_selections]
   163	        selected_frame = str(frame_candidates[0]["frame_id"]) if frame_candidates else None
   164	        ambiguities = [
   165	            *self._formula_ambiguities(modal_ir),
   166	            *self._family_ambiguities(
   167	                encoding,
   168	                modal_ir=modal_ir,
   169	                frame_selections=frame_selections,
   170	            ),
   171	            *self._frame_ambiguities(frame_selections),
   172	        ]
   173	        if normalized_text and not modal_ir.formulas:
   174	            ambiguities.append(
   175	                ModalCompilationAmbiguity(
   176	                    ambiguity_type="missing_modal_formula",
   177	                    message="No deterministic modal formula was produced for non-empty text.",
   178	                    severity="requires_rule",
   179	                )
   180	            )
   181	
   182	        modal_ir = self._attach_metadata(
   183	            modal_ir,
   184	            frame_selections,
   185	            parser_name=parser_name,
   186	            selected_frame=selected_frame,
   187	            ambiguity_count=len(ambiguities),
   188	            encoding=encoding,
   189	        )
   190	        return ModalCompilationResult(
   191	            modal_ir=modal_ir,
   192	            parser_name=parser_name,
   193	            normalized_text=normalized_text,
   194	            frame_candidates=frame_candidates,
   195	            selected_frame=selected_frame,
   196	            ambiguities=ambiguities,
   197	            encoding=encoding,
   198	            metadata={
   199	                "ambiguity_count": len(ambiguities),
   200	                "deterministic_compiler": "modal_compiler_v1",
   201	                "frame_selector": "bm25_v1",
   202	                "llm_call_count": 0,
   203	                "parser_backend": self.config.parser_backend,
   204	            },
   205	        )
   206	
   207	    def _attach_metadata(
   208	        self,
   209	        modal_ir: ModalIRDocument,
   210	        frame_selections: Sequence[FrameSelection],
   211	        *,
   212	        parser_name: str,
   213	        selected_frame: Optional[str],
   214	        ambiguity_count: int,
   215	        encoding: SpaCyLegalEncoding,
   216	    ) -> ModalIRDocument:
   217	        frame_candidates = [
   218	            ModalIRFrame(
   219	                frame_id=selection.frame.frame_id,
   220	                score=selection.score,
   221	                matched_terms=list(selection.matched_terms),
   222	                explanation=selection.explanation,
   223	            )
   224	            for selection in frame_selections
   225	        ]
   226	        metadata = {
   227	            **modal_ir.metadata,
   228	            "ambiguity_count": ambiguity_count,
   229	            "deterministic_compiler": "modal_compiler_v1",
   230	            "deterministic_parser": parser_name,
   231	            "frame_selector": "bm25_v1",
   232	            "llm_call_count": 0,
   233	            "modal_family_counts": encoding.modal_family_counts(),
   234	            "selected_frame": selected_frame,
   235	        }
   236	        return replace(modal_ir, frame_candidates=frame_candidates, metadata=metadata)
   237	
   238	    def _formula_ambiguities(
   239	        self,
   240	        modal_ir: ModalIRDocument,
   241	    ) -> List[ModalCompilationAmbiguity]:
   242	        by_span: Dict[tuple[int, int], List[str]] = {}
   243	        for formula in modal_ir.formulas:
   244	            span = (formula.provenance.start_char, formula.provenance.end_char)
   245	            candidate = (
   246	                f"{formula.formula_id}:{formula.operator.family}:"
   247	                f"{formula.operator.system}:{formula.operator.symbol}"
   248	            )
   249	            by_span.setdefault(span, []).append(candidate)
   250	
   251	        ambiguities: List[ModalCompilationAmbiguity] = []
   252	        for span, candidates in sorted(by_span.items()):
   253	            families = {candidate.split(":")[1] for candidate in candidates}
   254	            if len(candidates) > 1 and len(families) > 1:
   255	                ambiguities.append(
   256	                    ModalCompilationAmbiguity(
   257	                        ambiguity_type="multi_family_same_span",
   258	                        message="Multiple modal families were compiled from the same text span.",
   259	                        candidate_ids=sorted(candidates),
   260	                        metadata={"span": list(span)},


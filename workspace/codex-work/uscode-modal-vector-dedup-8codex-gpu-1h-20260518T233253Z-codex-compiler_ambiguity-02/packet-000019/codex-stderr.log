   365	class ModalRegistry:
   366	    """Lookup table for modal parse profiles."""
   367	
   368	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   369	        self._profiles: Dict[str, ModalParseProfile] = {
   370	            profile.profile_id: profile for profile in profiles
   371	        }
   372	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   373	            profile.family: profile for profile in profiles
   374	        }
   375	
   376	    def get_profile(
   377	        self,
   378	        family: ModalLogicFamily | str,
   379	        system: Optional[ModalSystem | str] = None,
   380	    ) -> ModalParseProfile:
   381	        """Get a profile by family, optionally constrained by system."""
   382	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   383	        if system is None:
   384	            return self._by_family[resolved_family]
   385	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   386	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   387	
   388	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   389	        """Return all profiles in deterministic order."""
   390	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   391	
   392	    def to_dict(self) -> Mapping[str, object]:
   393	        """Return a stable JSON-ready registry mapping."""
   394	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   395	
   396	
   397	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   398	    """Return whether a modal family encodes normative legal force."""
   399	    if isinstance(family, ModalLogicFamily):
   400	        resolved = family
   401	    else:
   402	        try:
   403	            resolved = ModalLogicFamily(str(family))
   404	        except ValueError:
   405	            return False
   406	    return resolved in NORMATIVE_MODAL_FAMILIES
   407	
   408	
   409	def supports_signal_free_adaptive_ambiguity_pair(
   410	    predicted_family: ModalLogicFamily | str,
   411	    target_family: ModalLogicFamily | str,
   412	) -> bool:
   413	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   414	    resolved_target_family = _resolve_modal_family_name(target_family)
   415	    return resolved_target_family in signal_free_adaptive_ambiguity_targets(
   416	        predicted_family
   417	    )
   418	
   419	
   420	def signal_free_adaptive_ambiguity_targets(
   421	    predicted_family: ModalLogicFamily | str,
   422	) -> Tuple[str, ...]:
   423	    """Return ordered adaptive-ambiguity targets requiring signal-free handling."""
   424	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   425	    return tuple(
   426	        target_family
   427	        for source_family, target_family in SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   428	        if source_family == resolved_predicted_family
   429	    )
   430	
   431	
   432	def is_priority_signal_free_adaptive_ambiguity_pair(
   433	    predicted_family: ModalLogicFamily | str,
   434	    target_family: ModalLogicFamily | str,
   435	) -> bool:
   436	    """Return whether a pair is part of the highest-priority adaptive ambiguity policy."""
   437	    resolved_predicted_family = _resolve_modal_family_name(predicted_family)
   438	    resolved_target_family = _resolve_modal_family_name(target_family)
   439	    return (
   440	        resolved_predicted_family,
   441	        resolved_target_family,
   442	    ) in PRIORITY_SIGNAL_FREE_ADAPTIVE_AMBIGUITY_FAMILY_PAIRS
   443	
   444	
   445	def _resolve_modal_family_name(family: ModalLogicFamily | str) -> str:
   446	    if isinstance(family, ModalLogicFamily):
   447	        return family.value
   448	    try:
   449	        return ModalLogicFamily(str(family)).value
   450	    except ValueError:
   451	        return str(family).strip().lower()
   452	
   453	
   454	DEFAULT_MODAL_REGISTRY = ModalRegistry()

+def test_spacy_codec_promotes_temporal_ranking_for_conditional_deadline_scope_phrase() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="49",
+        section="20116",
+        text=(
+            "The Secretary shall submit the annual report not later than the end of "
+            "fiscal year 2030 pursuant to subsection (b)."
+        ),
+    )
+    encoding = codec.encode_sample(sample)
+    ranking = ranked_modal_families(encoding)
+
+    assert not any(cue.family == "temporal" for cue in encoding.cues)
+    assert any(cue.family == "conditional_normative" for cue in encoding.cues)
+    assert ranking
+    assert ranking[0]["family"] == "temporal"
+
+

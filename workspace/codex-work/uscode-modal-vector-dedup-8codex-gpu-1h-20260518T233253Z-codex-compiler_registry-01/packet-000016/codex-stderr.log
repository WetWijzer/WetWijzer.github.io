   878	    def family_logits(
   879	        self,
   880	        encoding: SpaCyLegalEncoding,
   881	        *,
   882	        modal_families: Sequence[str],
   883	    ) -> Dict[str, float]:
   884	        logits = {family: -0.25 for family in modal_families}
   885	        signals = modal_ambiguity_signals(encoding)
   886	        generic_frame_debias_context = _is_generic_frame_cue_debias_context(

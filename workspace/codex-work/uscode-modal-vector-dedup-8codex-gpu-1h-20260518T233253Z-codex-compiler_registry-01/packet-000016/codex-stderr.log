   923	    def _feature_stream(self, encoding: SpaCyLegalEncoding) -> Iterable[str]:
   924	        yield f"doclen:{len(encoding.tokens)}"
   925	        for token in encoding.tokens:
   926	            if token.is_alpha and not token.is_stop:
   927	                yield f"lemma:{token.normalized()}"
   928	            if token.pos:
   929	                yield f"pos:{token.pos}"
   930	            if token.dep:
   931	                yield f"dep:{token.dep}"
   932	        for cue in encoding.cues:
   933	            yield f"cue:{cue.family}:{cue.symbol}:{cue.cue.lower()}"
   934	        for family, count in encoding.modal_family_counts().items():
   935	            yield f"family:{family}:{count}"

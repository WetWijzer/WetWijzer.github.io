   434	    def get_profile(
   435	        self,
   436	        family: ModalLogicFamily | str,
   437	        system: Optional[ModalSystem | str] = None,
   438	    ) -> ModalParseProfile:
   439	        """Get a profile by family, optionally constrained by system."""
   440	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   441	        if system is None:
   442	            return self._by_family[resolved_family]
   443	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   444	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]

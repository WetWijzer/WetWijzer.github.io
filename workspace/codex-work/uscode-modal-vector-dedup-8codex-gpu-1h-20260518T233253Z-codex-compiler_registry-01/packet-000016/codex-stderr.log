   668	    def _is_temporal_deadline_by_cue(
   669	        self,
   670	        *,
   671	        normalized_text: str,
   672	        tokens: Sequence[SpaCyTokenFeature],
   673	        start_char: int,
   674	        end_char: int,
   675	    ) -> bool:
   676	        """Treat temporal `by` as a deadline cue only when local context is time-like."""

   863	class SpaCyModalDecoder:
   864	    """Decode spaCy/IR features into deterministic embedding-like vectors."""
   865	
   866	    def decode_embedding(self, encoding: SpaCyLegalEncoding, *, dimensions: int = 8) -> List[float]:
   867	        if dimensions < 1:
   868	            raise ValueError("dimensions must be >= 1")
   869	        vector = [0.0 for _ in range(dimensions)]
   870	        for feature in self._feature_stream(encoding):
   871	            slot, value = _feature_hash(feature, dimensions)
   872	            vector[slot] += value
   873	        norm = math.sqrt(sum(value * value for value in vector))
   874	        if norm == 0.0:
   875	            return vector
   876	        return [round(value / norm, 6) for value in vector]

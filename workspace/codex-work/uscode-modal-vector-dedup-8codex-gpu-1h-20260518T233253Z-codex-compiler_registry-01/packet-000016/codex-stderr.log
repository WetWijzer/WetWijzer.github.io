   796	class SpaCyModalIRCompiler:
   797	    """Compile spaCy legal encodings into canonical modal IR documents."""
   798	
   799	    def __init__(self, *, parser: Optional[LegalModalParser] = None) -> None:
   800	        self._fallback_parser = parser or LegalModalParser()
   801	
   802	    def compile(self, encoding: SpaCyLegalEncoding) -> ModalIRDocument:
   803	        formulas: List[ModalIRFormula] = []
   804	        for index, cue in enumerate(encoding.cues, start=1):
   805	            sentence = _sentence_for_cue(encoding.sentences, cue)
   806	            tokens = _tokens_for_span(encoding.tokens, sentence.start_char, sentence.end_char)
   807	            predicate = _predicate_from_tokens(tokens, cue)
   808	            conditions, exceptions = _conditions_and_exceptions_from_sentence(
   809	                sentence.text
   810	            )
   811	            formulas.append(
   812	                ModalIRFormula(
   813	                    formula_id=f"{encoding.document_id}:spacy:f{index:04d}",
   814	                    operator=ModalIROperator(
   815	                        family=cue.family,
   816	                        system=cue.system,
   817	                        symbol=cue.symbol,
   818	                        label=cue.label,
   819	                    ),
   820	                    predicate=predicate,
   821	                    provenance=ModalIRProvenance(
   822	                        source_id=encoding.document_id,
   823	                        start_char=sentence.start_char,
   824	                        end_char=sentence.end_char,
   825	                        citation=encoding.citation,
   826	                    ),
   827	                    conditions=conditions,
   828	                    exceptions=exceptions,
   829	                    metadata={
   830	                        "cue": cue.cue,
   831	                        "cue_start_char": cue.start_char,
   832	                        "cue_end_char": cue.end_char,
   833	                        "encoder": "spacy_modal_codec_v1",
   834	                    },
   835	                )
   836	            )
   837	        if not formulas and encoding.normalized_text:
   838	            fallback_formula = self._fallback_parser.fallback_formula(
   839	                document_id=encoding.document_id,
   840	                text=encoding.normalized_text,
   841	                citation=encoding.citation,
   842	                start_index=1,
   843	            )
   844	            if fallback_formula is not None:
   845	                formulas.append(fallback_formula)
   846	        return ModalIRDocument(
   847	            document_id=encoding.document_id,
   848	            source=encoding.source,
   849	            normalized_text=encoding.normalized_text,
   850	            formulas=formulas,
   851	            metadata={
   852	                "citation": encoding.citation,
   853	                "deterministic_parser": "spacy_modal_codec_v1",
   854	                "llm_call_count": 0,
   855	                "model_name": encoding.model_name,
   856	                "sentence_count": len(encoding.sentences),
   857	                "token_count": len(encoding.tokens),
   858	                "used_fallback_model": encoding.used_fallback_model,
   859	            },
   860	        )

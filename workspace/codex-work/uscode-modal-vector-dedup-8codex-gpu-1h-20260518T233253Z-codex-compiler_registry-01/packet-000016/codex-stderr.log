   906	            if family not in logits:
   907	                continue
   908	            if float(raw_counts.get(family, 0.0)) > 0.0:
   909	                continue
   910	            logits[family] = max(float(logits[family]), 0.25) + float(bonus)
   911	        frame_bonus = _frame_logit_bonus(signals)
   912	        if generic_frame_debias_context:
   913	            frame_bonus = _debias_frame_bonus_for_generic_cues(signals)
   914	        if ModalLogicFamily.FRAME.value in logits and frame_bonus > 0.0:
   915	            logits[ModalLogicFamily.FRAME.value] = (
   916	                max(logits[ModalLogicFamily.FRAME.value], 0.5) + frame_bonus
   917	            )

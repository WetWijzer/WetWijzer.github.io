   691	                return True
   692	            if normalized in _TEMPORAL_BY_CONTEXT_TOKENS:
   693	                return True
   694	            if normalized in _MONTH_NAME_TOKENS:
   695	                return True
   696	            if re.fullmatch(r"\d{1,4}", token.text):
   697	                return True
   698	        return False

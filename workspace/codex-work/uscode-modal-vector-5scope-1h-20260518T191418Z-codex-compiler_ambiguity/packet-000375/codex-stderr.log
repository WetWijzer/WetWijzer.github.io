+    def _adaptive_family_ranking_from_logits(
+        self,
+        encoding: SpaCyLegalEncoding,
+    ) -> List[Dict[str, float]]:
+        """Build fallback family ranking from deterministic decoder logits."""
+        modal_families = [family.value for family in ModalLogicFamily]

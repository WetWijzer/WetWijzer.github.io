+        text="Composite interpretation applies.",
+        normalized_text="Composite interpretation applies.",
+        tokens=[],
+        sentences=[],
+        cues=[
+            SpaCyModalCueFeature(
+                family="hybrid",
+                system="HYBRID",
+                symbol="H",
+                label="hybrid",
+                cue="composite",
+                start_char=0,
+                end_char=9,
+                token_indices=[],
+            ),
+        ],
+    )
+    modal_ir = ModalIRDocument(
+        document_id="adaptive-zero-margin-hybrid-frame-doc",
+        source="us_code",

   547	    def _adaptive_family_ranking_from_logits(
   548	        self,
   549	        encoding: SpaCyLegalEncoding,
   550	    ) -> List[Dict[str, float]]:
   551	        """Build fallback family ranking from deterministic decoder logits."""
   552	        modal_families = [family.value for family in ModalLogicFamily]
   553	        logits = self.decoder.family_logits(
   554	            encoding,
   555	            modal_families=modal_families,
   556	        )
   557	        if not logits:
   558	            return []
   559	        max_logit = max(float(value) for value in logits.values())
   560	        exp_by_family = {
   561	            family: math.exp(float(logit) - max_logit)
   562	            for family, logit in logits.items()
   563	        }
   564	        total = sum(exp_by_family.values())
   565	        if total <= 0.0:
   566	            return []
   567	        ranking: List[Dict[str, float]] = []
   568	        for family in sorted(
   569	            exp_by_family,
   570	            key=lambda key: (-exp_by_family[key], key),
   571	        ):
   572	            ranking.append(
   573	                {
   574	                    "family": family,
   575	                    "count": 0,
   576	                    "logit": round(float(logits[family]), 6),
   577	                    "share": round(exp_by_family[family] / total, 6),
   578	                    "source": "logit_softmax_fallback",
   579	                }
   580	            )
   581	        return ranking

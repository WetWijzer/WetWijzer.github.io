    96	            "ambiguities": [ambiguity.to_dict() for ambiguity in self.ambiguities],
    97	            "encoding": self.encoding.to_dict() if self.encoding is not None else None,
    98	            "frame_candidates": list(self.frame_candidates),
    99	            "metadata": dict(sorted(self.metadata.items())),
   100	            "modal_ir": self.modal_ir.to_dict(),

   135	def synthesis_hints_from_autoencoder_introspections(
   136	    introspections: Iterable[Mapping[str, Any]],
   137	) -> List[ModalProgramSynthesisHint]:
   138	    """Convert multiple introspection records into deterministic hints."""
   139	    hints: Dict[str, ModalProgramSynthesisHint] = {}
   140	    for introspection in introspections:
   141	        for hint in synthesis_hints_from_autoencoder_introspection(introspection):
   142	            hints[hint.hint_id] = hint
   143	    return sorted(hints.values(), key=lambda hint: (-hint.priority, hint.hint_id))
   144	
   145	
   146	def _hint(
   147	    sample_id: str,
   148	    *,
   149	    action: str,
   150	    target_component: str,
   151	    rationale: str,
   152	    priority: float,
   153	    evidence: Mapping[str, Any],
   154	) -> ModalProgramSynthesisHint:
   155	    evidence_dict = dict(evidence)
   156	    evidence_dict.setdefault("sample_id", sample_id)
   157	    payload = {
   158	        "action": action,
   159	        "evidence": evidence_dict,
   160	        "sample_id": sample_id,
   161	        "target_component": target_component,
   162	    }
   163	    digest = hashlib.sha256(
   164	        json.dumps(payload, ensure_ascii=True, sort_keys=True).encode("utf-8")
   165	    ).hexdigest()[:16]
   166	    return ModalProgramSynthesisHint(
   167	        hint_id=f"modal-synthesis-{digest}",
   168	        action=action,
   169	        target_component=target_component,
   170	        rationale=rationale,
   171	        priority=round(max(0.0, float(priority)), 12),
   172	        evidence=evidence_dict,
   173	    )
   174	
   175	
   176	def _feature_names(contributions: Any) -> List[str]:
   177	    if not isinstance(contributions, Sequence) or isinstance(contributions, (str, bytes)):
   178	        return []
   179	    names: List[str] = []
   180	    for contribution in contributions:
   181	        if not isinstance(contribution, Mapping):
   182	            continue
   183	        feature = str(contribution.get("feature") or "").strip()
   184	        if feature and feature not in names:
   185	            names.append(feature)
   186	    return names
   187	
   188	
   189	def _frame_features(introspection: Mapping[str, Any]) -> List[str]:
   190	    features: List[str] = []
   191	    for key in ("top_family_contributions", "top_embedding_contributions"):
   192	        for feature in _feature_names(introspection.get(key, [])):
   193	            if feature and feature not in features:
   194	                features.append(feature)
   195	    return frame_ontology_feature_keys(features)
   196	
   197	
   198	def _priority_from_probability_gap(introspection: Mapping[str, Any]) -> float:
   199	    target_probability = float(introspection.get("target_probability") or 0.0)
   200	    predicted_probability = float(introspection.get("predicted_probability") or 0.0)
   201	    return max(0.0, predicted_probability - target_probability, 1.0 - target_probability)
   202	
   203	
   204	def _family_margin(introspection: Mapping[str, Any]) -> float:
   205	    try:
   206	        return float(introspection.get("family_margin") or 0.0)
   207	    except (TypeError, ValueError):
   208	        return 0.0
   209	

   771	def ranked_modal_families(encoding: SpaCyLegalEncoding) -> List[Dict[str, float]]:
   772	    """Rank modal families by deterministic cue count and normalized share."""
   773	    counts = encoding.modal_family_counts()
   774	    total = sum(counts.values())
   775	    if total <= 0:
   776	        return []
   777	    ranking: List[Dict[str, float]] = []
   778	    for family, count in sorted(counts.items(), key=lambda item: (-item[1], item[0])):
   779	        ranking.append(
   780	            {
   781	                "family": family,
   782	                "count": int(count),
   783	                "share": round(float(count) / float(total), 6),
   784	            }
   785	        )
   786	    return ranking

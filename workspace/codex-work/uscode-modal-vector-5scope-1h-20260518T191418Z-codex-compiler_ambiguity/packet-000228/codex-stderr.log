   888	def _unique_preserve_order(features: Iterable[str]) -> List[str]:
   889	    seen: set[str] = set()
   890	    result: List[str] = []
   891	    for feature in features:
   892	        if feature in seen:
   893	            continue
   894	        seen.add(feature)
   895	        result.append(feature)
   896	    return result

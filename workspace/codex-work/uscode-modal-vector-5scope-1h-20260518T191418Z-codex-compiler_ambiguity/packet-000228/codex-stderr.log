   143	                citation=citation,
   144	                source=source,
   145	            )
   146	            parser_name = "legal_modal_parser_v1"
   147	        else:
   148	            modal_ir = self.ir_compiler.compile(encoding)
   149	            parser_name = "spacy_modal_codec_v1"
   150	
   151	        frame_selections = self.frame_selector.rank(
   152	            normalized_text,
   153	            top_k=self.config.top_k_frames,
   154	            domain=self.config.frame_domain,
   155	        )
   156	        frame_candidates = [selection.to_dict() for selection in frame_selections]
   157	        selected_frame = str(frame_candidates[0]["frame_id"]) if frame_candidates else None
   158	        ambiguities = [

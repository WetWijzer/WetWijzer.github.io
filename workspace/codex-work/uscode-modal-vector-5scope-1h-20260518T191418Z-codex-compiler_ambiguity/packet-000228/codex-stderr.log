   899	def _sentence_for_cue(
   900	    sentences: Sequence[SpaCySentenceFeature],
   901	    cue: SpaCyModalCueFeature,
   902	) -> SpaCySentenceFeature:
   903	    for sentence in sentences:
   904	        if sentence.start_char <= cue.start_char < sentence.end_char:
   905	            return sentence
   906	    return SpaCySentenceFeature(text="", start_char=cue.start_char, end_char=cue.end_char)
   907	
   908	
   909	def _tokens_for_span(
   910	    tokens: Sequence[SpaCyTokenFeature],
   911	    start_char: int,
   912	    end_char: int,
   913	) -> List[SpaCyTokenFeature]:
   914	    return [
   915	        token
   916	        for token in tokens
   917	        if token.start_char < end_char and token.end_char > start_char
   918	    ]
   919	
   920	
   921	def _predicate_from_tokens(
   922	    tokens: Sequence[SpaCyTokenFeature],
   923	    cue: SpaCyModalCueFeature,
   924	) -> ModalIRPredicate:
   925	    after_cue = [
   926	        token.normalized()
   927	        for token in tokens
   928	        if token.start_char >= cue.end_char and token.is_alpha and not token.is_stop
   929	    ]
   930	    before_cue = [
   931	        token.normalized()
   932	        for token in tokens
   933	        if token.end_char <= cue.start_char and token.is_alpha and not token.is_stop
   934	    ]
   935	    predicate_terms = after_cue[:6] or before_cue[-6:] or [cue.label]
   936	    arguments = []
   937	    if before_cue:
   938	        arguments.append(f"actor:{'_'.join(before_cue[-4:])}")
   939	    if after_cue:
   940	        arguments.append(f"scope:{'_'.join(after_cue[:4])}")
   941	    return ModalIRPredicate(
   942	        name="_".join(predicate_terms),
   943	        arguments=arguments,
   944	        role=_role_for_cue(cue),
   945	    )
   946	
   947	
   948	def _role_for_cue(cue: SpaCyModalCueFeature) -> str:
   949	    if cue.family == ModalLogicFamily.CONDITIONAL_NORMATIVE.value:
   950	        return "condition"
   951	    if cue.family == ModalLogicFamily.TEMPORAL.value:
   952	        return "temporal_scope"
   953	    if cue.family == ModalLogicFamily.FRAME.value:
   954	        return "frame"
   955	    return "clause"
   956	
   957	
   958	def _conditions_and_exceptions_from_sentence(sentence_text: str) -> tuple[List[str], List[str]]:
   959	    return (
   960	        _prefixed_clause_phrases(sentence_text, _CONDITION_PREFIXES),
   961	        _prefixed_clause_phrases(sentence_text, _EXCEPTION_PREFIXES),
   962	    )
   963	
   964	
   965	def _prefixed_clause_phrases(segment_text: str, prefixes: Sequence[str]) -> List[str]:
   966	    normalized = _normalize(segment_text)
   967	    phrases: List[str] = []
   968	    for prefix in sorted(prefixes, key=lambda value: (-len(value), value)):
   969	        pattern = re.compile(rf"(?<!\w){re.escape(prefix)}(?!\w)", re.IGNORECASE)
   970	        for match in pattern.finditer(normalized):
   971	            fragment = normalized[match.start() :]
   972	            fragment = _CLAUSE_DELIMITER_RE.split(fragment, maxsplit=1)[0]
   973	            phrase = _normalized_clause_phrase(fragment)
   974	            if phrase and phrase not in phrases:
   975	                phrases.append(phrase)
   976	    return phrases
   977	
   978	
   979	def _normalized_clause_phrase(text: str) -> str:
   980	    tokens = _CLAUSE_TOKEN_RE.findall(text.lower())
   981	    return " ".join(tokens[:18]).strip()

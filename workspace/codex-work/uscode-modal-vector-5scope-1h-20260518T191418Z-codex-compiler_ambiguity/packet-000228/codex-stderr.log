   245	class ModalRegistry:
   246	    """Lookup table for modal parse profiles."""
   247	
   248	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   249	        self._profiles: Dict[str, ModalParseProfile] = {
   250	            profile.profile_id: profile for profile in profiles
   251	        }
   252	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   253	            profile.family: profile for profile in profiles
   254	        }
   255	
   256	    def get_profile(
   257	        self,
   258	        family: ModalLogicFamily | str,
   259	        system: Optional[ModalSystem | str] = None,
   260	    ) -> ModalParseProfile:
   261	        """Get a profile by family, optionally constrained by system."""
   262	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   263	        if system is None:
   264	            return self._by_family[resolved_family]
   265	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   266	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   267	
   268	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   269	        """Return all profiles in deterministic order."""
   270	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   271	
   272	    def to_dict(self) -> Mapping[str, object]:
   273	        """Return a stable JSON-ready registry mapping."""
   274	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   275	
   276	
   277	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   278	    """Return whether a modal family encodes normative legal force."""
   279	    if isinstance(family, ModalLogicFamily):
   280	        resolved = family
   281	    else:
   282	        try:
   283	            resolved = ModalLogicFamily(str(family))
   284	        except ValueError:
   285	            return False
   286	    return resolved in NORMATIVE_MODAL_FAMILIES
   287	
   288	
   289	DEFAULT_MODAL_REGISTRY = ModalRegistry()

   804	    }
   805	    normalized_text = encoding.normalized_text.lower()
   806	    cue_families = {cue.family for cue in encoding.cues}
   807	    conditional_scope_phrase = _contains_scope_phrase(
   808	        normalized_text, _CONDITIONAL_SCOPE_PHRASES
   809	    )
   810	    statutory_scope_reference = _contains_scope_phrase(
   811	        normalized_text, _STATUTORY_SCOPE_REFERENCE_PHRASES
   812	    )
   813	    conditional_scope_token = bool(token_terms & _CONDITIONAL_SCOPE_TOKENS)
   814	    alethic_scope_phrase = _contains_scope_phrase(
   815	        normalized_text, _ALETHIC_SCOPE_PHRASES
   816	    )
   817	    deontic_scope_phrase = _contains_scope_phrase(
   818	        normalized_text, _DEONTIC_SCOPE_PHRASES
   819	    )
   820	    temporal_scope_phrase = _contains_scope_phrase(
   821	        normalized_text, _TEMPORAL_SCOPE_PHRASES
   822	    )
   823	    dynamic_scope_phrase = _contains_scope_phrase(
   824	        normalized_text, _DYNAMIC_SCOPE_PHRASES
   825	    )
   826	    calendar_date_scope = bool(_CALENDAR_DATE_RE.search(normalized_text))
   827	    alethic_scope = (
   828	        bool(token_terms & _ALETHIC_SCOPE_TOKENS)
   829	        or bool(alethic_scope_phrase)
   830	    )
   831	    temporal_scope = (
   832	        bool(token_terms & _TEMPORAL_SCOPE_TOKENS)
   833	        or bool(temporal_scope_phrase)
   834	        or calendar_date_scope
   835	    )
   836	    deontic_scope = (
   837	        bool(token_terms & _DEONTIC_SCOPE_TOKENS)
   838	        or bool(deontic_scope_phrase)
   839	        or ModalLogicFamily.DEONTIC.value in cue_families
   840	    )
   841	    dynamic_scope = (
   842	        bool(token_terms & _DYNAMIC_SCOPE_TOKENS)
   843	        or bool(dynamic_scope_phrase)
   844	        or ModalLogicFamily.DYNAMIC.value in cue_families
   845	    )
   846	    frame_scope_phrase = _contains_scope_phrase(
   847	        normalized_text, _FRAME_SCOPE_PHRASES
   848	    )
   849	    frame_context = bool(token_terms & _FRAME_CONTEXT_TOKENS) or bool(frame_scope_phrase)
   850	    return {
   851	        "has_alethic_cue": ModalLogicFamily.ALETHIC.value in cue_families,
   852	        "has_alethic_scope": alethic_scope or ModalLogicFamily.ALETHIC.value in cue_families,
   853	        "has_alethic_scope_phrase": bool(alethic_scope_phrase),
   854	        "has_condition_clause": condition_clauses,
   855	        "has_conditional_scope_token": conditional_scope_token,
   856	        "has_conditional_scope_phrase": conditional_scope_phrase,
   857	        "has_statutory_scope_reference": statutory_scope_reference,
   858	        "has_exception_clause": exception_clauses,
   859	        "has_condition_or_exception_scope": (

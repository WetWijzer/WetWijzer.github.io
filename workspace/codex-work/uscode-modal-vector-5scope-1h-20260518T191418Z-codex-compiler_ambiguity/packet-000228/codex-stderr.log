   763	def _feature_hash(feature: str, dimensions: int) -> tuple[int, float]:
   764	    digest = hashlib.sha256(feature.encode("utf-8")).digest()
   765	    slot = int.from_bytes(digest[:4], "big") % dimensions
   766	    sign = 1.0 if digest[4] % 2 == 0 else -1.0
   767	    magnitude = 0.5 + (digest[5] / 255.0)
   768	    return slot, sign * magnitude

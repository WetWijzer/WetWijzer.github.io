   789	def modal_ambiguity_signals(encoding: SpaCyLegalEncoding) -> Dict[str, bool]:
   790	    """Return deterministic lexical/contextual flags used by ambiguity policy."""
   791	    condition_clauses = False
   792	    exception_clauses = False

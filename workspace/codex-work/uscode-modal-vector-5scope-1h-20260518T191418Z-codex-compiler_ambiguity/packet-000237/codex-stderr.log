            for operator in profile.operators:
                for cue in sorted(operator.cue_terms, key=lambda value: (-len(value), value)):
                    pattern = re.compile(rf"(?<!\w){re.escape(cue)}(?!\w)", re.IGNORECASE)
                    for match in pattern.finditer(normalized):

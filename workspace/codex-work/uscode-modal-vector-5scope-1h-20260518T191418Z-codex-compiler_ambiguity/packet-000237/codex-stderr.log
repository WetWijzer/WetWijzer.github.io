                            profile,
                            operator,
                            cue,
                            match.start(),
                            match.end(),
                            token_indices,
                        )
        return sorted(
            found.values(),
            key=lambda cue: (cue.start_char, cue.end_char, cue.family, cue.symbol, cue.cue),
        )


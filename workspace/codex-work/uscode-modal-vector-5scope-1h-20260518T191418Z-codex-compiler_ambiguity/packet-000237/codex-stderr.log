+def supports_signal_free_adaptive_ambiguity_pair(
+    predicted_family: ModalLogicFamily | str,
+    target_family: ModalLogicFamily | str,
+) -> bool:
+    """Return whether an adaptive pair should emit ambiguity without target cues."""
+    return (

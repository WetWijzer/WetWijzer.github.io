+def test_spacy_encoder_extracts_temporal_scope_cues_from_enactment_phrases() -> None:
+    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
+    encoding = encoder.encode(
+        (
+            "This section is effective upon enactment and applies after the date "
+            "of enactment."
+        ),
+        document_id="sample-temporal-enactment-phrases",
+    )
+
+    assert any(
+        cue.family == "temporal"
+        and cue.cue.lower() == "effective upon enactment"
+        for cue in encoding.cues
+    )
+    assert any(
+        cue.family == "temporal"
+        and cue.cue.lower() == "after the date of enactment"
+        for cue in encoding.cues
+    )
+    signals = modal_ambiguity_signals(encoding)
+    assert signals["has_temporal_scope"] is True
+
+

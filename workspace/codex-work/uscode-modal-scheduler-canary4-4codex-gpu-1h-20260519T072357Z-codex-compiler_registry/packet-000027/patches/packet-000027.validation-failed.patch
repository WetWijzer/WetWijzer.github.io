+def test_spacy_decoder_debiases_generic_frame_logits_for_dynamic_scope_phrase() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="10",
+        section="7542",
+        text="Authority under this section applies upon transfer.",
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+
+    logits = codec.family_logits_for_sample(
+        sample,
+        modal_families=("frame", "dynamic", "deontic"),
+    )
+
+    assert signals["has_dynamic_scope"] is True
+    assert signals["has_dynamic_scope_phrase"] is True
+    assert logits["dynamic"] > logits["frame"]
+

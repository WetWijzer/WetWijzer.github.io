+    second = lookahead[1].normalized().lower() if len(lookahead) > 1 else ""
+    if (
+        first in _NON_TEMPORAL_WITHIN_PREFIX_TOKENS
+        and second in _NON_TEMPORAL_WITHIN_CONTEXT_TOKENS
+    ):

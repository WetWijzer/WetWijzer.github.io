+    def _is_temporal_within_cue(
+        self,
+        *,
+        normalized_text: str,
+        tokens: Sequence[SpaCyTokenFeature],
+        start_char: int,
+        end_char: int,
+    ) -> bool:
+        """Treat temporal `within` as time-scoped, not structural or jurisdictional."""
+        trailing = normalized_text[end_char : end_char + 96]
+        if _CALENDAR_DATE_RE.search(trailing):
+            return True
+        if re.match(r"^\s+\d{1,4}\b", trailing):
+            return True
+        lookahead: List[SpaCyTokenFeature] = []
+        for token in tokens:
+            if token.start_char >= end_char:
+                lookahead.append(token)
+                if len(lookahead) >= 6:
+                    break
+        if not lookahead:
+            return False
+        head_terms = [token.normalized().lower() for token in lookahead[:2]]
+        if head_terms:
+            first = head_terms[0]
+            if first in _NON_TEMPORAL_WITHIN_TARGET_TOKENS:
+                return False
+            if first in {"the", "this", "that", "these", "those", "such"}:
+                if len(head_terms) > 1 and head_terms[1] in _NON_TEMPORAL_WITHIN_TARGET_TOKENS:
+                    return False
+        for token in lookahead:
+            normalized = token.normalized().lower()
+            if normalized in _TEMPORAL_SCOPE_TOKENS:
+                return True
+            if normalized in _TEMPORAL_BY_CONTEXT_TOKENS:
+                return True
+            if normalized in _MONTH_NAME_TOKENS:
+                return True
+            if re.fullmatch(r"\d{1,4}", token.text):
+                return True
+        return False
+
+    def _inject_editorial_frame_cues(
+        self,
+        *,
+        normalized_text: str,
+        tokens: Sequence[SpaCyTokenFeature],
+        token_spans: Sequence[tuple[int, int, int]],
+        found: Dict[tuple[int, int, str, str], SpaCyModalCueFeature],
+    ) -> None:
+        """Add high-precision frame cues for U.S. Code editorial/codification notes."""
+        profile = self.registry.get_profile(ModalLogicFamily.FRAME)
+        if not profile.operators:
+            return
+        operator = profile.operators[0]
+        lowered_text = normalized_text.lower()
+        for cue in _FRAME_EDITORIAL_CUE_TERMS:
+            pattern = re.compile(rf"(?<!\w){re.escape(cue)}(?!\w)", re.IGNORECASE)
+            for match in pattern.finditer(normalized_text):
+                if not self._is_editorial_frame_cue_context(
+                    lowered_text=lowered_text,
+                    cue=cue,
+                    start_char=match.start(),
+                    end_char=match.end(),
+                ):
+                    continue
+                token_indices = [
+                    index
+                    for index, start, end in token_spans
+                    if start < match.end() and end > match.start()
+                ]
+                key = (match.start(), match.end(), profile.family.value, operator.symbol)
+                found[key] = self._cue_feature(
+                    profile,
+                    operator,
+                    cue,
+                    match.start(),
+                    match.end(),
+                    token_indices,
+                )
+
+    def _is_editorial_frame_cue_context(
+        self,
+        *,
+        lowered_text: str,
+        cue: str,
+        start_char: int,
+        end_char: int,
+    ) -> bool:
+        if cue in {"editorially reclassified", "formerly classified"}:
+            return True
+        window_start = max(0, start_char - 160)
+        window_end = min(len(lowered_text), end_char + 160)
+        window = lowered_text[window_start:window_end]
+        if any(phrase in window for phrase in _FRAME_EDITORIAL_CONTEXT_PHRASES):
+            return True
+        if cue in {"transferred", "repealed", "reserved", "omitted", "vacant"}:
+            head_window = lowered_text[:220]
+            if re.search(r"\bsec\.?\s*[0-9a-z.\-–—]+\s*[-–—]\s*$", lowered_text[:start_char]):
+                return True
+            if re.search(
+                r"^\s*(?:§\s*[0-9a-z.\-–—]+\s*)?(?:transferred|repealed|reserved|omitted|vacant)\b",
+                head_window,
+                re.IGNORECASE,
+            ):
+                return True
+        return False

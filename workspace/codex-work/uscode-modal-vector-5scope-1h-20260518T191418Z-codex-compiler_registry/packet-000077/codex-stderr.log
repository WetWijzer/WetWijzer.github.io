import pyarrow.parquet as pq
import pyarrow.compute as pc
path='/home/barberb/.ipfs_datasets/federal_register/federal_register_parquet/laws.parquet'
t=pq.read_table(path, columns=['citation_text','normalized_citation','text','title_number','section_number'])
for cite in ['12 U.S.C. 59','46 U.S.C. 30525.','46 U.S.C. 30525','48 U.S.C. 1422b.','48 U.S.C. 1422b']:
    m = pc.equal(t['normalized_citation'], cite)
    f=t.filter(m)
    print('===',cite,'rows',f.num_rows)
    if f.num_rows:
        row=f.slice(0,1).to_pylist()[0]
        txt=row.get('text','')

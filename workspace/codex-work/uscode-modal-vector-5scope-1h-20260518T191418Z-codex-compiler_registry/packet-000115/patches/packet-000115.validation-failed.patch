+def test_spacy_encoder_does_not_double_count_within_after_temporal_deadline() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    result = compiler.compile(
+        "The agency shall submit the report within 90 days after enactment."
+    )
+
+    cues = [(cue.family, cue.cue.lower()) for cue in result.encoding.cues]
+    assert (ModalLogicFamily.DEONTIC.value, "shall") in cues
+    assert (ModalLogicFamily.TEMPORAL.value, "within") in cues
+    assert (ModalLogicFamily.TEMPORAL.value, "after") not in cues
+    ranking = ranked_modal_families(result.encoding)
+    assert ranking[0]["family"] == ModalLogicFamily.DEONTIC.value
+
+
+def test_spacy_encoder_keeps_standalone_temporal_after_cue() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    result = compiler.compile("The report is effective after enactment.")
+
+    cues = [(cue.family, cue.cue.lower()) for cue in result.encoding.cues]
+    assert (ModalLogicFamily.TEMPORAL.value, "after") in cues

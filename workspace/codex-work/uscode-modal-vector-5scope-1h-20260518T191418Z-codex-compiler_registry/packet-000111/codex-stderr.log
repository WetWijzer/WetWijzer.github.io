   365	@dataclass(frozen=True)
   366	class SpaCyLegalEncoding:
   367	    """Serializable spaCy-derived intermediate encoding for one legal text."""
   368	
   369	    document_id: str
   370	    text: str
   371	    normalized_text: str
   372	    tokens: List[SpaCyTokenFeature]
   373	    sentences: List[SpaCySentenceFeature]
   374	    cues: List[SpaCyModalCueFeature]
   375	    citation: Optional[str] = None
   376	    source: str = "legal_text"
   377	    model_name: str = ""
   378	    used_fallback_model: bool = False
   379	
   380	    def modal_family_counts(self) -> Dict[str, int]:
   381	        counts: Dict[str, int] = {}
   382	        for cue in self.cues:
   383	            counts[cue.family] = counts.get(cue.family, 0) + 1
   384	        return dict(sorted(counts.items()))
   385	
   386	    def ranked_modal_families(self) -> List[Dict[str, float]]:
   387	        """Return cue-count ranking with stable ordering and share ratios."""
   388	        return ranked_modal_families(self)
   389	
   390	    def to_dict(self) -> Dict[str, Any]:
   391	        return {
   392	            "citation": self.citation,
   393	            "cues": [cue.to_dict() for cue in self.cues],
   394	            "document_id": self.document_id,
   395	            "modal_family_counts": self.modal_family_counts(),
   396	            "model_name": self.model_name,
   397	            "normalized_text": self.normalized_text,
   398	            "sentences": [sentence.to_dict() for sentence in self.sentences],
   399	            "source": self.source,
   400	            "text": self.text,
   401	            "tokens": [token.to_dict() for token in self.tokens],
   402	            "used_fallback_model": self.used_fallback_model,
   403	        }

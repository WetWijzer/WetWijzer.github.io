+        if re.match(r"^\s*[:;,(\[]", trailing):
+            return True
+        if re.match(
+            r"^\s+(?:is|are|shall|must|may|include|includes|apply|applies|as)\b",
+            trailing,
+            re.IGNORECASE,
+        ):
+            return True
+        return False
+

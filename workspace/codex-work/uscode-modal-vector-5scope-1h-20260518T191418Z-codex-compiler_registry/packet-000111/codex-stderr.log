   406	class SpaCyLegalEncoder:
   407	    """Encode legal text using spaCy tokens plus deterministic modal cues."""
   408	
   409	    def __init__(
   410	        self,
   411	        *,
   412	        model_name: str = "en_core_web_sm",
   413	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
   414	    ) -> None:
   415	        self.model_name = model_name
   416	        self.registry = registry
   417	        self.nlp, self.used_fallback_model = self._load_nlp(model_name)
   418	
   419	    def encode(
   420	        self,
   421	        text: str,
   422	        *,
   423	        document_id: Optional[str] = None,
   424	        citation: Optional[str] = None,
   425	        source: str = "legal_text",
   426	    ) -> SpaCyLegalEncoding:
   427	        normalized = _normalize(text)
   428	        resolved_document_id = document_id or _document_id(normalized)
   429	        doc = self.nlp(normalized)
   430	        tokens = [
   431	            SpaCyTokenFeature(
   432	                text=token.text,
   433	                lemma=(token.lemma_ or token.lower_).lower(),
   434	                lower=token.lower_,
   435	                pos=token.pos_,
   436	                dep=token.dep_,
   437	                start_char=token.idx,
   438	                end_char=token.idx + len(token.text),
   439	                is_stop=bool(token.is_stop),
   440	                is_alpha=bool(token.is_alpha),
   441	            )
   442	            for token in doc
   443	        ]
   444	        sentences = [
   445	            SpaCySentenceFeature(
   446	                text=sent.text,
   447	                start_char=sent.start_char,
   448	                end_char=sent.end_char,
   449	            )
   450	            for sent in doc.sents
   451	        ]
   452	        if not sentences and normalized:
   453	            sentences = [SpaCySentenceFeature(text=normalized, start_char=0, end_char=len(normalized))]
   454	        return SpaCyLegalEncoding(
   455	            document_id=resolved_document_id,
   456	            text=text,
   457	            normalized_text=normalized,
   458	            tokens=tokens,
   459	            sentences=sentences,
   460	            cues=self._extract_cues(normalized, tokens),
   461	            citation=citation,
   462	            source=source,
   463	            model_name=self.model_name,
   464	            used_fallback_model=self.used_fallback_model,
   465	        )
   466	
   467	    def _extract_cues(
   468	        self,
   469	        normalized: str,
   470	        tokens: Sequence[SpaCyTokenFeature],
   471	    ) -> List[SpaCyModalCueFeature]:
   472	        found: Dict[tuple[int, int, str, str], SpaCyModalCueFeature] = {}
   473	        token_spans = [(index, token.start_char, token.end_char) for index, token in enumerate(tokens)]
   474	        for profile in self.registry.all_profiles():
   475	            for operator in profile.operators:
   476	                for cue in sorted(operator.cue_terms, key=lambda value: (-len(value), value)):
   477	                    pattern = re.compile(rf"(?<!\w){re.escape(cue)}(?!\w)", re.IGNORECASE)
   478	                    for match in pattern.finditer(normalized):
   479	                        if self._is_calendar_month_may_cue(
   480	                            normalized_text=normalized,
   481	                            cue=cue,
   482	                            start_char=match.start(),
   483	                            end_char=match.end(),
   484	                        ):
   485	                            continue
   486	                        if profile.family == ModalLogicFamily.TEMPORAL:
   487	                            lowered_cue = cue.lower()
   488	                            if (
   489	                                lowered_cue == "by"
   490	                                and not self._is_temporal_deadline_by_cue(
   491	                                    normalized_text=normalized,
   492	                                    tokens=tokens,
   493	                                    start_char=match.start(),
   494	                                    end_char=match.end(),
   495	                                )
   496	                            ):
   497	                                continue
   498	                            if (
   499	                                lowered_cue == "following"
   500	                                and self._is_non_temporal_following_cue(
   501	                                    normalized_text=normalized,
   502	                                    tokens=tokens,
   503	                                    start_char=match.start(),
   504	                                    end_char=match.end(),
   505	                                )
   506	                            ):
   507	                                continue
   508	                        token_indices = [
   509	                            index
   510	                            for index, start, end in token_spans
   511	                            if start < match.end() and end > match.start()
   512	                        ]
   513	                        key = (match.start(), match.end(), profile.family.value, operator.symbol)
   514	                        found[key] = self._cue_feature(
   515	                            profile,
   516	                            operator,
   517	                            cue,
   518	                            match.start(),
   519	                            match.end(),
   520	                            token_indices,
   521	                        )
   522	        return sorted(
   523	            found.values(),
   524	            key=lambda cue: (cue.start_char, cue.end_char, cue.family, cue.symbol, cue.cue),
   525	        )
   526	
   527	    def _is_calendar_month_may_cue(
   528	        self,
   529	        *,
   530	        normalized_text: str,
   531	        cue: str,
   532	        start_char: int,
   533	        end_char: int,
   534	    ) -> bool:
   535	        """Treat `May 13, 2002` date literals as temporal context, not deontic permission."""
   536	        if cue.lower() != "may":
   537	            return False
   538	        if start_char > 0 and normalized_text[start_char - 1].isalnum():
   539	            return False
   540	        trailing = normalized_text[end_char:]
   541	        return bool(re.match(r"^\s+\d{1,2}(?:,\s*|\s+)\d{4}\b", trailing))
   542	
   543	    def _is_temporal_deadline_by_cue(
   544	        self,
   545	        *,
   546	        normalized_text: str,
   547	        tokens: Sequence[SpaCyTokenFeature],
   548	        start_char: int,
   549	        end_char: int,
   550	    ) -> bool:
   551	        """Treat temporal `by` as a deadline cue only when local context is time-like."""
   552	        trailing = normalized_text[end_char : end_char + 64]
   553	        if _TEMPORAL_BY_PHRASE_RE.match(trailing):
   554	            return True
   555	        if _CALENDAR_DATE_RE.search(trailing):
   556	            return True
   557	        lookahead: List[SpaCyTokenFeature] = []
   558	        for token in tokens:
   559	            if token.start_char >= end_char:
   560	                lookahead.append(token)
   561	                if len(lookahead) >= 4:
   562	                    break
   563	        for token in lookahead:
   564	            normalized = token.normalized().lower()
   565	            if normalized in _TEMPORAL_SCOPE_TOKENS:
   566	                return True
   567	            if normalized in _TEMPORAL_BY_CONTEXT_TOKENS:
   568	                return True
   569	            if normalized in _MONTH_NAME_TOKENS:
   570	                return True
   571	            if re.fullmatch(r"\d{1,4}", token.text):
   572	                return True
   573	        return False
   574	
   575	    def _is_non_temporal_following_cue(
   576	        self,
   577	        *,
   578	        normalized_text: str,
   579	        tokens: Sequence[SpaCyTokenFeature],
   580	        start_char: int,
   581	        end_char: int,
   582	    ) -> bool:
   583	        """Treat list-introducing `the following` as non-temporal context."""
   584	        preceding: Optional[SpaCyTokenFeature] = None
   585	        lookahead: List[SpaCyTokenFeature] = []
   586	        for token in tokens:
   587	            if token.end_char <= start_char:
   588	                preceding = token
   589	                continue
   590	            if token.start_char >= end_char:
   591	                lookahead.append(token)
   592	                if len(lookahead) >= 3:
   593	                    break
   594	        if preceding is None:
   595	            return False
   596	        preceding_normalized = preceding.normalized().lower()
   597	        if preceding_normalized not in _NON_TEMPORAL_FOLLOWING_PREFIX_TOKENS:
   598	            return False
   599	        if lookahead:
   600	            next_token = lookahead[0]
   601	            next_normalized = next_token.normalized().lower()
   602	            if (
   603	                next_normalized in _TEMPORAL_SCOPE_TOKENS
   604	                or next_normalized in _MONTH_NAME_TOKENS
   605	                or re.fullmatch(r"\d{1,4}", next_token.text)
   606	            ):
   607	                return False
   608	        trailing = normalized_text[end_char : end_char + 48]
   609	        if re.match(r"^\s*[:;,(\[]", trailing):
   610	            return True
   611	        if re.match(
   612	            r"^\s+(?:is|are|shall|must|may|include|includes|apply|applies|as)\b",
   613	            trailing,
   614	            re.IGNORECASE,
   615	        ):
   616	            return True
   617	        return False
   618	
   619	    def _cue_feature(
   620	        self,
   621	        profile: ModalParseProfile,
   622	        operator: ModalOperatorSpec,
   623	        cue: str,
   624	        start_char: int,
   625	        end_char: int,
   626	        token_indices: Sequence[int],
   627	    ) -> SpaCyModalCueFeature:
   628	        return SpaCyModalCueFeature(
   629	            family=profile.family.value,
   630	            system=profile.system.value,
   631	            symbol=operator.symbol,
   632	            label=operator.aliases[0] if operator.aliases else operator.symbol,
   633	            cue=cue,
   634	            start_char=start_char,
   635	            end_char=end_char,
   636	            token_indices=list(token_indices),
   637	        )
   638	
   639	    def _load_nlp(self, model_name: str):
   640	        try:
   641	            import spacy
   642	        except ImportError as exc:  # pragma: no cover - dependency is present in supported envs
   643	            raise RuntimeError("spaCy is required for SpaCyLegalEncoder") from exc
   644	        try:
   645	            nlp = spacy.load(model_name)
   646	            used_fallback = False
   647	        except OSError:
   648	            nlp = spacy.blank("en")
   649	            used_fallback = True
   650	        if "sentencizer" not in nlp.pipe_names:
   651	            nlp.add_pipe("sentencizer")
   652	        return nlp, used_fallback

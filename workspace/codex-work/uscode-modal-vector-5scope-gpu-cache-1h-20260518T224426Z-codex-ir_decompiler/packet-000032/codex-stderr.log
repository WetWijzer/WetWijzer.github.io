+    assert slot_map["cue_modal_canonical_signature"] == ["temporal:G:until"]
+    assert slot_map["cue_modal_operator"] == ["F"]
+    assert slot_map["cue_modal_canonical_operator"] == ["G"]
+    assert slot_map["cue_modal_operator_alignment"] == ["divergent"]
+

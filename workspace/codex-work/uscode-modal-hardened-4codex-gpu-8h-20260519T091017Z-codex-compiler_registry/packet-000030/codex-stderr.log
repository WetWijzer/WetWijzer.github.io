  1588	    @staticmethod
  1589	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1590	        """Return deterministic ambiguity priority from policy margin settings.
  1591	
  1592	        For contested low-margin cases (positive margin below threshold), a
  1593	        smaller gap to the threshold carries higher urgency. For outvoted
  1594	        cases (zero/negative margin), severity increases with outvote depth.
  1595	        """
  1596	        resolved_margin = float(family_margin)
  1597	        resolved_threshold = max(0.0, float(threshold))
  1598	        if resolved_margin > 0.0:
  1599	            return max(0.0, resolved_threshold - resolved_margin)
  1600	        return abs(resolved_margin) + resolved_threshold

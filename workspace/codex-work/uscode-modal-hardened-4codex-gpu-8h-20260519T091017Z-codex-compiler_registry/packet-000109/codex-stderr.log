  1439	        runner_up_family = str(runner_up["family"])
  1440	        runner_up_share = self._ranking_share(runner_up)
  1441	        family_margin = primary_share - runner_up_share
  1442	        if not self._adaptive_margin_within_threshold(
  1443	            family_margin=family_margin,
  1444	            threshold=threshold,
  1445	        ):
  1446	            return []
  1447	        runner_up_is_priority_policy_pair = is_priority_signal_free_adaptive_ambiguity_pair(

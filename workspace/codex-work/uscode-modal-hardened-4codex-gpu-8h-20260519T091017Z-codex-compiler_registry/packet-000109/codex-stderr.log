  1525	            "is_priority_policy_pair": is_priority_policy_pair,
  1526	            "runner_up_is_priority_policy_pair": runner_up_is_priority_policy_pair,
  1527	            "predicted_family": compiled_primary_family,
  1528	            "predicted_margin_to_runner_up_raw": family_margin,

  1553	                message=(
  1554	                    "Explicit adaptive low-margin ambiguity for the predicted modal "
  1555	                    "family against close competing families."
  1556	                ),
  1557	                candidate_ids=[compiled_primary_family],
  1558	                severity="requires_rule" if requires_rule else "review",
  1559	                metadata={
  1560	                    **base_metadata,
  1561	                    "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
  1562	                },
  1563	            ),
  1564	        ]
  1565	
  1566	    def _has_frame_bm25_support(
  1567	        self,
  1568	        frame_selections: Sequence[FrameSelection],
  1569	    ) -> bool:
  1570	        if not frame_selections:
  1571	            return False
  1572	        return any(
  1573	            bool(selection.matched_terms) and float(selection.score) > 0.0
  1574	            for selection in frame_selections
  1575	        )
  1576	
  1577	    def _adaptive_margin_explicit_type(
  1578	        self,
  1579	        predicted_family: str,
  1580	        target_family: str,
  1581	        margin_direction: str,
  1582	    ) -> str:
  1583	        return "_".join(
  1584	            (
  1585	                "adaptive",
  1586	                predicted_family,
  1587	                target_family,
  1588	                margin_direction,
  1589	                "margin_low",
  1590	            )
  1591	        )
  1592	
  1593	    @staticmethod
  1594	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1595	        """Return deterministic ambiguity priority from policy margin settings.
  1596	
  1597	        For contested low-margin cases (positive margin below threshold), a
  1598	        smaller gap to the threshold carries higher urgency. For outvoted
  1599	        cases (zero/negative margin), severity increases with outvote depth.
  1600	        """
  1601	        resolved_margin = float(family_margin)
  1602	        resolved_threshold = max(0.0, float(threshold))
  1603	        if resolved_margin > 0.0:
  1604	            return max(0.0, resolved_threshold - resolved_margin)
  1605	        return abs(resolved_margin) + resolved_threshold
  1606	
  1607	    @staticmethod
  1608	    def _adaptive_margin_within_threshold(
  1609	        *,
  1610	        family_margin: float,
  1611	        threshold: float,
  1612	        epsilon: float = 1e-12,
  1613	    ) -> bool:
  1614	        """Return whether the margin is at or below threshold with float tolerance."""
  1615	        resolved_margin = float(family_margin)
  1616	        resolved_threshold = float(threshold)
  1617	        resolved_epsilon = max(0.0, float(epsilon))
  1618	        return resolved_margin <= (resolved_threshold + resolved_epsilon)
  1619	
  1620	    def _supports_signal_free_adaptive_pair(
  1621	        self,
  1622	        predicted_family: str,
  1623	        target_family: str,
  1624	    ) -> bool:
  1625	        """Return whether this pair must surface adaptive ambiguity without lexical support."""
  1626	        return supports_signal_free_adaptive_ambiguity_pair(
  1627	            predicted_family,
  1628	            target_family,
  1629	        )
  1630	
  1631	    def _temporal_target_family_ambiguities(
  1632	        self,
  1633	        encoding: SpaCyLegalEncoding,
  1634	        *,
  1635	        ranking: Sequence[Dict[str, Any]],
  1636	        family_shares: Dict[str, float],
  1637	    ) -> List[ModalCompilationAmbiguity]:
  1638	        if not ranking:
  1639	            return []
  1640	        top_family = str(ranking[0]["family"])
  1641	        if top_family != ModalLogicFamily.TEMPORAL.value:
  1642	            return []
  1643	        temporal_share = self._ranking_share(ranking[0])
  1644	        signals = modal_ambiguity_signals(encoding)
  1645	        target_specs = (
  1646	            (
  1647	                ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
  1648	                bool(signals.get("has_condition_or_exception_scope")),
  1649	                "temporal_conditional_normative_family_outvoted",
  1650	                (
  1651	                    "Conditional or exception scope markers are present, but temporal cues "
  1652	                    "outvote conditional-normative family evidence."
  1653	                ),
  1654	            ),
  1655	            (
  1656	                ModalLogicFamily.FRAME.value,
  1657	                bool(signals.get("has_frame_context") or signals.get("has_frame_cue")),
  1658	                "temporal_frame_family_outvoted",
  1659	                (
  1660	                    "Frame-context markers are present, but temporal cues outvote frame-family "
  1661	                    "evidence."
  1662	                ),
  1663	            ),
  1664	        )
  1665	        ambiguities: List[ModalCompilationAmbiguity] = []
  1666	        for target_family, has_signal, ambiguity_type, message in target_specs:
  1667	            target_share = float(family_shares.get(target_family, 0.0))
  1668	            family_margin = target_share - temporal_share
  1669	            if not has_signal and target_share <= 0.0:
  1670	                continue
  1671	            if family_margin >= self.config.modal_temporal_target_family_outvote_margin:
  1672	                continue
  1673	            ambiguities.append(
  1674	                ModalCompilationAmbiguity(
  1675	                    ambiguity_type=ambiguity_type,
  1676	                    message=message,
  1677	                    candidate_ids=[ModalLogicFamily.TEMPORAL.value, target_family],
  1678	                    severity="requires_rule",
  1679	                    metadata={
  1680	                        "family_margin": round(family_margin, 6),
  1681	                        "family_ranking": list(ranking),
  1682	                        "lexical_signals": dict(sorted(signals.items())),
  1683	                        "outvote_margin_threshold": self.config.modal_temporal_target_family_outvote_margin,
  1684	                        "predicted_family": ModalLogicFamily.TEMPORAL.value,
  1685	                        "target_family": target_family,
  1686	                        "target_share": round(target_share, 6),
  1687	                        "temporal_share": round(temporal_share, 6),
  1688	                    },
  1689	                )
  1690	            )
  1691	        return ambiguities
  1692	
  1693	    def _temporal_scope_target_family_ambiguities(
  1694	        self,
  1695	        encoding: SpaCyLegalEncoding,
  1696	        *,
  1697	        ranking: Sequence[Dict[str, Any]],
  1698	        family_shares: Dict[str, float],
  1699	    ) -> List[ModalCompilationAmbiguity]:
  1700	        if not ranking:
  1701	            return []
  1702	        predicted_family = str(ranking[0]["family"])
  1703	        if predicted_family == ModalLogicFamily.TEMPORAL.value:
  1704	            return []
  1705	        predicted_share = self._ranking_share(ranking[0])
  1706	        target_family = ModalLogicFamily.TEMPORAL.value

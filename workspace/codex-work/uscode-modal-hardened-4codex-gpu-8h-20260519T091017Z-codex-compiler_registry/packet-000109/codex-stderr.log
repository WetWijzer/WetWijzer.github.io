  1201	    def _compiled_primary_family_adaptive_pair_ambiguities(
  1202	        self,
  1203	        *,
  1204	        compiled_primary_family: str,
  1205	        competing_family: str,
  1206	        ranking: Sequence[Dict[str, Any]],
  1207	        family_shares: Dict[str, float],
  1208	        threshold: float,
  1209	        signals: Mapping[str, bool],
  1210	        has_frame_scope: bool,
  1211	        has_frame_bm25_support: bool,
  1212	        compiled_modal_families: Sequence[str],
  1213	    ) -> List[ModalCompilationAmbiguity]:
  1214	        supports_signal_free_pair_policy = self._supports_signal_free_adaptive_pair(
  1215	            compiled_primary_family,
  1216	            competing_family,
  1217	        )
  1218	        is_self_pair = compiled_primary_family == competing_family
  1219	        primary_share = float(family_shares.get(compiled_primary_family, 0.0))
  1220	        competing_share = float(family_shares.get(competing_family, 0.0))
  1221	        runner_up_family: Optional[str] = competing_family
  1222	        runner_up_share: Optional[float] = competing_share
  1223	        if is_self_pair:
  1224	            runner_up_family = None
  1225	            runner_up_share = None
  1226	            for candidate in ranking:
  1227	                candidate_family = str(candidate.get("family", ""))
  1228	                if candidate_family == compiled_primary_family:
  1229	                    continue
  1230	                runner_up_family = candidate_family
  1231	                runner_up_share = self._ranking_share(candidate)
  1232	                break
  1233	        family_margin = (
  1234	            primary_share - runner_up_share
  1235	            if is_self_pair and runner_up_share is not None
  1236	            else primary_share - competing_share
  1237	        )
  1238	        if not self._adaptive_margin_within_threshold(
  1239	            family_margin=family_margin,
  1240	            threshold=threshold,
  1241	        ):
  1242	            return []
  1243	        target_signal_by_family = self._adaptive_target_signal_by_family(
  1244	            compiled_primary_family,
  1245	            signals=signals,
  1246	            has_frame_scope=has_frame_scope,
  1247	        )
  1248	        has_signal = bool(target_signal_by_family.get(competing_family, False))
  1249	        has_compiled_target_family_formula = competing_family in compiled_modal_families
  1250	        has_target_signal_evidence = bool(
  1251	            has_signal
  1252	            or competing_share > 0.0
  1253	            or has_compiled_target_family_formula
  1254	        )
  1255	        if not has_target_signal_evidence and not supports_signal_free_pair_policy:
  1256	            return []
  1257	        runner_up_is_priority_policy_pair = bool(
  1258	            is_self_pair
  1259	            and runner_up_family is not None
  1260	            and is_priority_signal_free_adaptive_ambiguity_pair(
  1261	                compiled_primary_family,
  1262	                runner_up_family,
  1263	            )
  1264	        )
  1265	        runner_up_is_compiler_required_policy_pair = bool(
  1266	            is_self_pair
  1267	            and runner_up_family is not None
  1268	            and is_compiler_required_adaptive_ambiguity_pair(
  1269	                compiled_primary_family,
  1270	                runner_up_family,
  1271	            )
  1272	        )
  1273	        is_priority_policy_pair = is_priority_signal_free_adaptive_ambiguity_pair(
  1274	            compiled_primary_family,
  1275	            competing_family,
  1276	        ) or runner_up_is_priority_policy_pair
  1277	        is_compiler_required_policy_pair = (
  1278	            is_compiler_required_adaptive_ambiguity_pair(
  1279	                compiled_primary_family,
  1280	                competing_family,
  1281	            )
  1282	            or runner_up_is_compiler_required_policy_pair

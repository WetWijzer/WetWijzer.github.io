  1481	            compiled_primary_family,
  1482	            margin_direction,
  1483	        )
  1484	        primary_share_display = round(primary_share, 6)
  1485	        runner_up_share_display = round(runner_up_share, 6)
  1486	        family_margin_display = round(family_margin, 6)
  1487	        has_compiled_target_family_formula = (
  1488	            compiled_primary_family in compiled_modal_families
  1489	        )
  1490	        has_target_signal_evidence = bool(

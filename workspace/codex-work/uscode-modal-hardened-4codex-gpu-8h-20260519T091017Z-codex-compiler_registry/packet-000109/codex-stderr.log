 12508	    for scenario in policy_scenarios:
 12509	        compiled_primary_family = str(scenario["compiled_primary_family"])
 12510	        family_shares = {
 12511	            str(family): float(share)
 12512	            for family, share in dict(scenario["family_shares"]).items()
 12513	        }
 12514	        ranking = [
 12515	            {"family": family, "count": 1, "share": share}
 12516	            for family, share in sorted(
 12517	                family_shares.items(),
 12518	                key=lambda item: (-item[1], item[0]),
 12519	            )
 12520	        ]
 12521	        encoding = SpaCyLegalEncoding(
 12522	            document_id=f"compiled-primary-policy-{compiled_primary_family}-doc",
 12523	            text=f"{compiled_primary_family} scope test text.",
 12524	            normalized_text=f"{compiled_primary_family} scope test text.",
 12525	            tokens=[],
 12526	            sentences=[],
 12527	            cues=[],
 12528	        )
 12529	        modal_ir = ModalIRDocument(
 12530	            document_id=f"compiled-primary-policy-{compiled_primary_family}-doc",
 12531	            source="us_code",
 12532	            normalized_text=encoding.normalized_text,
 12533	            formulas=[
 12534	                ModalIRFormula(
 12535	                    formula_id=f"f-{compiled_primary_family}-1",
 12536	                    operator=ModalIROperator(
 12537	                        family=compiled_primary_family,
 12538	                        system="D",
 12539	                        symbol="O",
 12540	                        label=compiled_primary_family,
 12541	                    ),
 12542	                    predicate=ModalIRPredicate(
 12543	                        name=f"{compiled_primary_family}_policy_scope",
 12544	                        arguments=["scope:test"],
 12545	                        role="clause",
 12546	                    ),
 12547	                    provenance=ModalIRProvenance(
 12548	                        source_id=f"compiled-primary-policy-{compiled_primary_family}-doc",
 12549	                        start_char=0,
 12550	                        end_char=len(encoding.normalized_text),
 12551	                    ),
 12552	                )
 12553	            ],
 12554	        )
 12555	
 12556	        ambiguities = compiler._adaptive_family_margin_ambiguities(
 12557	            encoding,
 12558	            modal_ir=modal_ir,
 12559	            ranking=ranking,
 12560	            family_shares=family_shares,
 12561	        )
 12562	
 12563	        explicit_ambiguity = next(
 12564	            ambiguity
 12565	            for ambiguity in ambiguities
 12566	            if ambiguity.ambiguity_type == scenario["expected_explicit_type"]
 12567	            and ambiguity.metadata["adaptive_predicted_family_source"]
 12568	            == "compiled_primary_family"
 12569	            and ambiguity.metadata["adaptive_policy_pair"] == scenario["expected_pair"]
 12570	        )
 12571	        assert explicit_ambiguity.metadata["adaptive_base_ambiguity_type"] == (
 12572	            "adaptive_family_margin_low"
 12573	        )

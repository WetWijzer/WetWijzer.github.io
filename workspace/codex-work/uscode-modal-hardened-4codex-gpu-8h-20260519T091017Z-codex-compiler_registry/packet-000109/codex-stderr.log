  1289	                    is_priority_policy_pair
  1290	                    or is_compiler_required_policy_pair
  1291	                )
  1292	            )
  1293	        ) else "contested"
  1294	        requires_rule = margin_direction == "outvoted"
  1295	        explicit_type = self._adaptive_margin_explicit_type(
  1296	            compiled_primary_family,
  1297	            competing_family,
  1298	            margin_direction,
  1299	        )

  1187	                    or signals.get("has_epistemic_cue")
  1188	                ),
  1189	                ModalLogicFamily.TEMPORAL.value: bool(
  1190	                    signals.get("has_temporal_scope")
  1191	                ),
  1192	                ModalLogicFamily.DYNAMIC.value: bool(
  1193	                    signals.get("has_dynamic_scope")
  1194	                    or signals.get("has_dynamic_cue")
  1195	                ),
  1196	            }
  1197	        else:
  1198	            target_signal_by_family = {}
  1199	        return target_signal_by_family

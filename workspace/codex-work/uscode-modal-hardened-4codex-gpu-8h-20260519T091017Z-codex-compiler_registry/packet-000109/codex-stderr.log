  1473	                    is_priority_policy_pair
  1474	                    or is_compiler_required_policy_pair
  1475	                )
  1476	            )
  1477	        ) else "contested"
  1478	        requires_rule = margin_direction == "outvoted"
  1479	        explicit_type = self._adaptive_margin_explicit_type(

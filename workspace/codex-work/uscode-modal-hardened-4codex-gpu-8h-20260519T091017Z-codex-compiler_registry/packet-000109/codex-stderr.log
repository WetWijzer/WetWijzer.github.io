  1311	                primary_share_display - competing_share_display,
  1312	                6,
  1313	            )
  1314	        )
  1315	        candidate_ids = (
  1316	            [compiled_primary_family]
  1317	            if is_self_pair
  1318	            else [compiled_primary_family, competing_family]
  1319	        )
  1320	        adaptive_priority = self._adaptive_margin_priority(
  1321	            family_margin=family_margin,
  1322	            threshold=threshold,
  1323	        )
  1324	        base_metadata = {
  1325	            "adaptive_family_margin_threshold": threshold,
  1326	            "adaptive_margin_direction": margin_direction,
  1327	            "adaptive_margin_abs": abs(family_margin),
  1328	            "adaptive_priority": adaptive_priority,
  1329	            "priority": adaptive_priority,
  1330	            "adaptive_predicted_family_source": "compiled_primary_family",
  1331	            "adaptive_policy_pair": f"{compiled_primary_family}->{competing_family}",
  1332	            "adaptive_runner_up_policy_pair": (
  1333	                f"{compiled_primary_family}->{runner_up_family}"
  1334	                if runner_up_family is not None
  1335	                else None
  1336	            ),
  1337	            "explicit_ambiguity_type": explicit_type,
  1338	            "family_margin_raw": family_margin,
  1339	            "family_margin": family_margin_display,
  1340	            "family_ranking": list(ranking),
  1341	            "compiled_modal_families": sorted(compiled_modal_families),
  1342	            "has_target_signal_evidence": has_target_signal_evidence,
  1343	            "signal_free_pair_policy_applied": (
  1344	                not has_target_signal_evidence
  1345	                and supports_signal_free_pair_policy
  1346	            ),
  1347	            "has_compiled_target_family_formula": has_compiled_target_family_formula,
  1348	            "has_frame_bm25_support": has_frame_bm25_support,
  1349	            "lexical_signals": dict(sorted(signals.items())),
  1350	            "is_compiler_required_policy_pair": is_compiler_required_policy_pair,
  1351	            "runner_up_is_compiler_required_policy_pair": (
  1352	                runner_up_is_compiler_required_policy_pair
  1353	            ),
  1354	            "is_priority_policy_pair": is_priority_policy_pair,
  1355	            "runner_up_is_priority_policy_pair": runner_up_is_priority_policy_pair,
  1356	            "predicted_family": compiled_primary_family,
  1357	            "predicted_margin_to_runner_up_raw": family_margin,
  1358	            "predicted_margin_to_runner_up": round(family_margin, 6),
  1359	            "runner_up_family": runner_up_family,
  1360	            "runner_up_share_raw": runner_up_share,
  1361	            "runner_up_share": runner_up_share_display,
  1362	            "predicted_share_raw": primary_share,
  1363	            "predicted_share": primary_share_display,
  1364	            "target_family": competing_family,
  1365	            "target_share_raw": competing_share,
  1366	            "target_share": competing_share_display,
  1367	            "is_self_pair": is_self_pair,
  1368	        }
  1369	        base_message = (
  1370	            "The compiled primary modal family has a low lead over competing "
  1371	            "cue evidence; family selection is ambiguous."
  1372	            if is_self_pair
  1373	            else (
  1374	                "The compiled primary modal family is outvoted by competing "
  1375	                "cue evidence; family selection is ambiguous."
  1376	            )
  1377	        )
  1378	        explicit_message = (
  1379	            "Explicit adaptive low-margin ambiguity for the compiled primary "
  1380	            "modal family against close competing families."
  1381	            if is_self_pair
  1382	            else (
  1383	                "Explicit adaptive modal-family conflict between the "
  1384	                "compiled primary family and a competing cue-dominant "
  1385	                "family."
  1386	            )
  1387	        )
  1388	        return [
  1389	            ModalCompilationAmbiguity(
  1390	                ambiguity_type="adaptive_family_margin_low",
  1391	                message=base_message,
  1392	                candidate_ids=candidate_ids,
  1393	                severity="requires_rule" if requires_rule else "review",
  1394	                metadata=dict(base_metadata),
  1395	            ),
  1396	            ModalCompilationAmbiguity(
  1397	                ambiguity_type=explicit_type,
  1398	                message=explicit_message,
  1399	                candidate_ids=candidate_ids,
  1400	                severity="requires_rule" if requires_rule else "review",
  1401	                metadata={
  1402	                    **base_metadata,
  1403	                    "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
  1404	                },
  1405	            ),

  1418	    ) -> List[ModalCompilationAmbiguity]:
  1419	        if not self._supports_signal_free_adaptive_pair(
  1420	            compiled_primary_family,
  1421	            compiled_primary_family,
  1422	        ):
  1423	            return []
  1424	        runner_up = max(
  1425	            (
  1426	                candidate
  1427	                for candidate in ranking
  1428	                if str(candidate["family"]) != compiled_primary_family
  1429	            ),
  1430	            key=lambda candidate: (
  1431	                self._ranking_share(candidate),
  1432	                str(candidate["family"]),
  1433	            ),

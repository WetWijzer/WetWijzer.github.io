  1323	def _overlap_aware_modal_family_counts(
  1324	    encoding: SpaCyLegalEncoding,
  1325	) -> Dict[str, float]:
  1326	    """Count family cues while collapsing nested same-family cue spans."""
  1327	    spans_by_family: Dict[str, List[tuple[int, int]]] = {}
  1328	    for cue in encoding.cues:
  1329	        start = int(cue.start_char)
  1330	        end = int(cue.end_char)
  1331	        if start < 0 or end <= start:
  1332	            continue
  1333	        spans_by_family.setdefault(cue.family, []).append((start, end))
  1334	
  1335	    counts: Dict[str, float] = {}
  1336	    for family, spans in spans_by_family.items():
  1337	        if not spans:
  1338	            continue
  1339	        unique_spans = sorted(set(spans))
  1340	        effective_spans: List[tuple[int, int]] = []
  1341	        for start, end in unique_spans:
  1342	            span_len = end - start
  1343	            covered_by_larger_span = False
  1344	            for other_start, other_end in unique_spans:
  1345	                if other_start == start and other_end == end:
  1346	                    continue
  1347	                other_len = other_end - other_start
  1348	                if (
  1349	                    other_start <= start
  1350	                    and other_end >= end
  1351	                    and other_len > span_len
  1352	                ):
  1353	                    covered_by_larger_span = True
  1354	                    break
  1355	            if not covered_by_larger_span:
  1356	                effective_spans.append((start, end))
  1357	        counts[family] = float(len(effective_spans))
  1358	    return counts

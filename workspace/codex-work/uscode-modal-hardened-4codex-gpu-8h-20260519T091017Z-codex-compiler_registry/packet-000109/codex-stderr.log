  1301	        competing_share_display = round(competing_share, 6)
  1302	        runner_up_share_display = (
  1303	            round(runner_up_share, 6)
  1304	            if runner_up_share is not None
  1305	            else None
  1306	        )
  1307	        family_margin_display = (
  1308	            round(family_margin, 6)

  1501	            "adaptive_margin_abs": abs(family_margin),
  1502	            "adaptive_priority": adaptive_priority,
  1503	            "priority": adaptive_priority,
  1504	            "adaptive_predicted_family_source": "compiled_primary_family",
  1505	            "adaptive_policy_pair": f"{compiled_primary_family}->{compiled_primary_family}",
  1506	            "adaptive_runner_up_policy_pair": (
  1507	                f"{compiled_primary_family}->{runner_up_family}"
  1508	            ),
  1509	            "explicit_ambiguity_type": explicit_type,
  1510	            "family_margin_raw": family_margin,
  1511	            "family_margin": family_margin_display,

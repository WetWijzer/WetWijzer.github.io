  1284	    total = sum(float(value) for value in weighted_counts.values())
  1285	    if total <= 0:
  1286	        return []
  1287	    ranking: List[Dict[str, float]] = []
  1288	    for family in sorted(
  1289	        weighted_counts,
  1290	        key=lambda item: (
  1291	            -float(weighted_counts.get(item, 0.0)),
  1292	            item,
  1293	        ),
  1294	    ):
  1295	        share_raw = float(weighted_counts.get(family, 0.0)) / float(total)
  1296	        ranking.append(
  1297	            {
  1298	                "family": family,
  1299	                "count": int(counts.get(family, 0)),
  1300	                "share_raw": share_raw,
  1301	                "share": round(share_raw, 6),
  1302	            }
  1303	        )
  1304	    return ranking

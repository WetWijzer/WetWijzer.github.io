   307	def _ordered_unique_adaptive_ambiguity_family_pairs(
   308	    pairs: Iterable[Tuple[str, str]],
   309	) -> Tuple[Tuple[str, str], ...]:
   310	    """Return a stable pair table with duplicates removed and order preserved."""
   311	    unique_pairs: list[Tuple[str, str]] = []
   312	    seen_pairs: set[Tuple[str, str]] = set()
   313	    for pair in pairs:
   314	        if pair in seen_pairs:
   315	            continue
   316	        seen_pairs.add(pair)
   317	        unique_pairs.append(pair)
   318	    return tuple(unique_pairs)

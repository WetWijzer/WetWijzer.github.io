  1646	    @staticmethod
  1647	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1648	        """Return deterministic ambiguity priority from policy margin settings.
  1649	
  1650	        For contested low-margin cases (positive margin below threshold), a
  1651	        smaller gap to the threshold carries higher urgency. For outvoted
  1652	        cases (zero/negative margin), severity increases with outvote depth.
  1653	        """
  1654	        resolved_margin = float(family_margin)
  1655	        resolved_threshold = max(0.0, float(threshold))
  1656	        if resolved_margin > 0.0:
  1657	            return max(0.0, resolved_threshold - resolved_margin)
  1658	        return abs(resolved_margin) + resolved_threshold
  1659	
  1660	    @staticmethod
  1661	    def _adaptive_margin_within_threshold(
  1662	        *,
  1663	        family_margin: float,
  1664	        threshold: float,
  1665	        epsilon: float = 1e-12,
  1666	    ) -> bool:
  1667	        """Return whether the margin is at or below threshold with float tolerance."""
  1668	        resolved_margin = float(family_margin)
  1669	        resolved_threshold = float(threshold)
  1670	        resolved_epsilon = max(0.0, float(epsilon))
  1671	        return resolved_margin <= (resolved_threshold + resolved_epsilon)

   352	                                "family_margin": round(family_margin, 6),
   353	                                "family_ranking": ranking,
   354	                                "outvote_margin_threshold": self.config.modal_primary_family_outvote_margin,
   355	                                "primary_family": primary_family,
   356	                                "primary_share": round(primary_share, 6),
   357	                            },
   358	                        )
   359	                    )
   360	                if family_margin <= self.config.modal_primary_family_margin:
   361	                    ambiguities.append(
   362	                        ModalCompilationAmbiguity(
   363	                            ambiguity_type="low_primary_modal_family_margin",
   364	                            message=(
   365	                                "The primary compiled modal family has a low margin "

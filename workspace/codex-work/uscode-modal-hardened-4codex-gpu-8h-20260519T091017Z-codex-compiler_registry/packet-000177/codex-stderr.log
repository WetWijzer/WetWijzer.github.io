  1621	        target_family: str,
  1622	        is_priority_policy_pair: bool,
  1623	        is_compiler_required_policy_pair: bool,
  1624	        epsilon: float = 1e-12,
  1625	    ) -> str:
  1626	        """Classify adaptive low-margin conflicts as contested vs. outvoted."""
  1627	        resolved_margin = float(family_margin)
  1628	        resolved_epsilon = max(0.0, float(epsilon))
  1629	        if (
  1630	            abs(resolved_margin) <= resolved_epsilon
  1631	            and prefers_contested_zero_margin_adaptive_ambiguity_pair(
  1632	                predicted_family,
  1633	                target_family,
  1634	            )
  1635	        ):
  1636	            return "contested"
  1637	        if resolved_margin < -resolved_epsilon:
  1638	            return "outvoted"
  1639	        if resolved_margin <= resolved_epsilon and (
  1640	            is_priority_policy_pair
  1641	            or is_compiler_required_policy_pair
  1642	        ):

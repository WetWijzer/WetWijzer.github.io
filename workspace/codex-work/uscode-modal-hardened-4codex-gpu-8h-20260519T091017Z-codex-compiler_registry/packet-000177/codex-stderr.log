   332	                ),
   333	                default=None,
   334	            )
   335	            if best_other is not None:
   336	                best_other_family = str(best_other["family"])
   337	                best_other_share = self._ranking_share(best_other)
   338	                family_margin = primary_share - best_other_share
   339	                if family_margin < self.config.modal_primary_family_outvote_margin:
   340	                    ambiguities.append(
   341	                        ModalCompilationAmbiguity(
   342	                            ambiguity_type="primary_modal_family_outvoted",
   343	                            message=(
   344	                                "Cue evidence favors a competing modal family over the primary "

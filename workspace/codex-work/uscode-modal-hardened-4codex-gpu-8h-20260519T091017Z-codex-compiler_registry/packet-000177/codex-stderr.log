  1410	def _apply_generic_frame_normative_scope_soft_cap(
  1411	    counts: Dict[str, float],
  1412	    signals: Mapping[str, bool],
  1413	) -> None:
  1414	    """Limit repeated generic frame cues when competing scope evidence is present."""
  1415	    frame_family = ModalLogicFamily.FRAME.value
  1416	    frame_count = float(counts.get(frame_family, 0.0))
  1417	    if frame_count <= _GENERIC_FRAME_NORMATIVE_SCOPE_SOFT_CAP:
  1418	        return
  1419	    has_competing_scope = (
  1420	        bool(signals.get("has_deontic_scope"))
  1421	        or bool(signals.get("has_condition_or_exception_scope"))
  1422	        or bool(signals.get("has_temporal_scope"))
  1423	        or bool(signals.get("has_epistemic_scope"))
  1424	    )
  1425	    if not has_competing_scope:
  1426	        return
  1427	    counts[frame_family] = _GENERIC_FRAME_NORMATIVE_SCOPE_SOFT_CAP
  1428	

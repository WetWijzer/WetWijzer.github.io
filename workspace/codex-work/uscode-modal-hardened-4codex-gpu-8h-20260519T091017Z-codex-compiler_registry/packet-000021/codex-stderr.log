+def test_spacy_codec_backfills_temporal_share_for_moderate_deontic_scope_with_temporal_phrase() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="12",
+        section="4406",
+        text="The Secretary shall provide notice while pending review.",
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+    ranking = ranked_modal_families(encoding)
+
+    assert any(cue.family == "deontic" for cue in encoding.cues)
+    assert not any(cue.family == "temporal" for cue in encoding.cues)
+    assert signals["has_temporal_scope"] is True
+    temporal_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "temporal"
+    )
+    assert temporal_share > 0.0
+
+
+def test_spacy_codec_backfills_conditional_share_for_moderate_deontic_scope_with_statutory_reference() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="12",
+        section="4407",
+        text="The Secretary shall provide notice under section 102 of this title.",
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+    ranking = ranked_modal_families(encoding)
+
+    assert any(cue.family == "deontic" for cue in encoding.cues)
+    assert not any(cue.family == "conditional_normative" for cue in encoding.cues)
+    assert signals["has_statutory_scope_reference"] is True
+    conditional_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "conditional_normative"
+    )
+    assert conditional_share > 0.0
+
+
+def test_spacy_codec_backfills_deontic_share_for_moderate_temporal_scope_with_deontic_scope_phrase() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="12",
+        section="4408",
+        text="Within 30 days after review, the person is guilty of an offense.",
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+    ranking = ranked_modal_families(encoding)
+
+    assert any(cue.family == "temporal" for cue in encoding.cues)
+    assert not any(cue.family == "deontic" for cue in encoding.cues)
+    assert signals["has_deontic_scope"] is True
+    deontic_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "deontic"
+    )
+    assert deontic_share > 0.0
+
+

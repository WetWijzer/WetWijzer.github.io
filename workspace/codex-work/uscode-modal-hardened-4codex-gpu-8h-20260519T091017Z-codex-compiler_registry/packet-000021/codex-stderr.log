            else round(
                primary_share_display - competing_share_display,
                6,
            )
        )
        candidate_ids = (
            [compiled_primary_family]
            if is_self_pair
            else [compiled_primary_family, competing_family]
        )
        adaptive_priority = self._adaptive_margin_priority(
            family_margin=family_margin,
            threshold=threshold,
        )

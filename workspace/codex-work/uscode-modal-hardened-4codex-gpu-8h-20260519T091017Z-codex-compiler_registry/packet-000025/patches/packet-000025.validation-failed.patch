+def test_spacy_decoder_strengthens_temporal_scope_boost_for_statutory_frame_context() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    baseline = build_us_code_sample(
+        title="42",
+        section="8321a",
+        text="Not later than January 1, 2030, notice applies.",
+    )
+    competing = build_us_code_sample(
+        title="42",
+        section="8321b",
+        text="Authority under this section applies not later than January 1, 2030.",
+    )
+
+    baseline_logits = codec.family_logits_for_sample(
+        baseline,
+        modal_families=("temporal", "frame", "deontic"),
+    )
+    competing_logits = codec.family_logits_for_sample(
+        competing,
+        modal_families=("temporal", "frame", "deontic"),
+    )
+
+    assert competing_logits["temporal"] > baseline_logits["temporal"]
+
+
+def test_spacy_decoder_reduces_statutory_frame_bias_when_deontic_cue_is_explicit() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    baseline = build_us_code_sample(
+        title="20",
+        section="1161b",
+        text="Authority under this section imposes liability for noncompliance.",
+    )
+    competing = build_us_code_sample(
+        title="20",
+        section="1161c",
+        text="Authority under this section shall impose liability for noncompliance.",
+    )
+
+    baseline_logits = codec.family_logits_for_sample(
+        baseline,
+        modal_families=("frame", "deontic", "temporal"),
+    )
+    competing_logits = codec.family_logits_for_sample(
+        competing,
+        modal_families=("frame", "deontic", "temporal"),
+    )
+
+    assert competing_logits["frame"] <= baseline_logits["frame"]
+    assert competing_logits["deontic"] > competing_logits["frame"]
+
+
+def test_spacy_decoder_prefers_conditional_scope_over_frame_in_statutory_as_provided_clause() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="42",
+        section="5161",
+        text="Authority under this section applies as provided in subsection (b).",
+    )
+
+    logits = codec.family_logits_for_sample(
+        sample,
+        modal_families=("conditional_normative", "frame", "deontic"),
+    )
+
+    assert logits["conditional_normative"] > logits["frame"]
+
+

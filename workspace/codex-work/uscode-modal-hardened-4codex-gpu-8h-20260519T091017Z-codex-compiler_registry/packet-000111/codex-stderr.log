+def test_compiler_treats_cannot_as_deontic_prohibition_cue() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    result = compiler.compile(
+        "A person cannot disclose the record unless authorized by law.",
+        document_id="compiler-cue-cannot-deontic",
+    )
+    assert result.encoding is not None
+    cannot_families = [
+        cue.family
+        for cue in result.encoding.cues
+        if cue.cue.lower() == "cannot"
+    ]
+    assert cannot_families
+    assert all(
+        family == ModalLogicFamily.DEONTIC.value
+        for family in cannot_families
+    )
+
+
+def test_compiler_captures_deontic_penalty_scope_phrase_as_cue() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    result = compiler.compile(
+        "A violator is subject to civil penalties under section 5 of this title.",
+        document_id="compiler-cue-deontic-penalty-scope",
+    )
+    assert result.encoding is not None
+    assert any(
+        cue.family == ModalLogicFamily.DEONTIC.value
+        and cue.cue.lower() == "subject to civil penalties"
+        for cue in result.encoding.cues
+    )
+
+
+def test_compiler_captures_epistemic_deemed_phrases_as_cues() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    result = compiler.compile(
+        "A person is deemed to have knowledge of the filing.",
+        document_id="compiler-cue-epistemic-deemed",
+    )
+    assert result.encoding is not None
+    deemed_cues = {
+        cue.cue.lower()
+        for cue in result.encoding.cues
+        if cue.family == ModalLogicFamily.EPISTEMIC.value
+    }
+    assert {"deemed", "deemed to", "is deemed"} & deemed_cues


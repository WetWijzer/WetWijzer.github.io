def _apply_competing_scope_backfill(
    counts: Dict[str, float],
    signals: Mapping[str, bool],
) -> None:
    """Inject small competing-family support in dense scope-heavy clauses."""
    deontic_family = ModalLogicFamily.DEONTIC.value

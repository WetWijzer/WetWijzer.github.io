+def test_spacy_codec_detects_conditional_necessity_cues_with_alethic_overlap() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="28",
+        section="376",
+        text=(
+            "This authority, as may be necessary to carry out duties under this section, "
+            "shall be exercised by the Secretary."
+        ),
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+    ranking = ranked_modal_families(encoding)
+
+    assert signals["has_condition_or_exception_scope"] is True
+    assert any(
+        cue.family == "conditional_normative"
+        and cue.cue.lower() in {"as may be necessary", "as may be necessary to"}
+        for cue in encoding.cues
+    )
+    conditional_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "conditional_normative"
+    )
+    alethic_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "alethic"
+    )
+    assert conditional_share > 0.0
+    assert alethic_share > 0.0
+
+

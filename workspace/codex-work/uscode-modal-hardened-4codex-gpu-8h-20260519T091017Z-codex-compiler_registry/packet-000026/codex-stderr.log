    epistemic_count = float(counts.get(epistemic_family, 0.0))
    alethic_count = float(counts.get(alethic_family, 0.0))
    has_moderate_frame_competition = (
        frame_count >= _FRAME_MODERATE_COMPETING_SCOPE_BACKFILL_TRIGGER
    )

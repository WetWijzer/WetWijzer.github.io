+def test_spacy_decoder_boosts_temporal_logits_for_date_heavy_frame_scope_without_frame_cues() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="33",
+        section="466",
+        text="Section 466 was repealed on June 12, 1960, and effective on January 1, 1961.",

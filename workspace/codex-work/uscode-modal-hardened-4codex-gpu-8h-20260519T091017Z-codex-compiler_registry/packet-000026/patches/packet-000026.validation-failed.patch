+def test_spacy_codec_detects_conditional_necessity_cues_with_alethic_overlap() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="28",
+        section="376",
+        text=(
+            "This authority, as may be necessary to carry out duties under this section, "
+            "shall be exercised by the Secretary."
+        ),
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+    ranking = ranked_modal_families(encoding)
+
+    assert signals["has_condition_or_exception_scope"] is True
+    assert any(
+        cue.family == "conditional_normative"
+        and cue.cue.lower() in {"as may be necessary", "as may be necessary to"}
+        for cue in encoding.cues
+    )
+    conditional_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "conditional_normative"
+    )
+    alethic_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "alethic"
+    )
+    assert conditional_share > 0.0
+    assert alethic_share > 0.0
+
+
+def test_spacy_codec_backfills_frame_share_for_deontic_scope_with_structural_frame_phrase() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="10",
+        section="2350p",
+        text="The Secretary shall carry out duties in this former section.",
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+    ranking = ranked_modal_families(encoding)
+
+    assert not any(cue.family == "frame" for cue in encoding.cues)
+    assert signals["has_frame_scope_phrase"] is True
+    assert signals["has_deontic_scope"] is True
+    frame_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "frame"
+    )
+    assert frame_share > 0.0
+
+
+def test_spacy_codec_backfills_temporal_share_for_single_deontic_deadline_date_scope() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="20",
+        section="9706",
+        text="The Secretary shall submit the report on June 1, 2030.",
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+    ranking = ranked_modal_families(encoding)
+
+    assert not any(cue.family == "temporal" for cue in encoding.cues)
+    assert signals["has_deontic_scope"] is True
+    assert signals["has_temporal_scope"] is True
+    temporal_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "temporal"
+    )
+    assert temporal_share > 0.0
+
+
+def test_spacy_codec_backfills_deontic_share_for_temporal_scope_with_deontic_phrase() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="29",
+        section="1085b",
+        text="Within 30 days after review, liability for noncompliance applies.",
+    )
+    encoding = codec.encode_sample(sample)
+    signals = modal_ambiguity_signals(encoding)
+    ranking = ranked_modal_families(encoding)
+
+    assert not any(cue.family == "deontic" for cue in encoding.cues)
+    assert signals["has_temporal_scope"] is True
+    assert signals["has_deontic_scope"] is True
+    assert signals["has_deontic_scope_phrase"] is True
+    deontic_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "deontic"
+    )
+    assert deontic_share > 0.0
+

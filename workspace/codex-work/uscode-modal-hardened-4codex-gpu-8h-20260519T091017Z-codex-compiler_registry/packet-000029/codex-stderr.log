/bin/bash -lc "python - <<'PY'
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.spacy_modal_codec import SpaCyModalCodec,SpaCyLegalEncoder,SpaCyModalDecoder,ranked_modal_families,modal_ambiguity_signals

codec = SpaCyModalCodec(encoder=SpaCyLegalEncoder(model_name='definitely_missing_legal_model'),decoder=SpaCyModalDecoder())
cases = {
'deontic_frame_compete':\"The Secretary shall and must issue notice in this former section.\",
'frame_alethic_compete':\"Authority and jurisdiction and authority and jurisdiction in this former section apply while the agency is unable to comply.\",
'frame_conditional_compete':\"Authority and jurisdiction and authority and jurisdiction under this section apply subject to subsection (b).\",
'temporal_deontic_compete':\"Within 30 days and by January 1, 2030, liability for violations applies under this section.\",
'temporal_self_statutory':\"For the period beginning on January 1, 2030 and ending on December 31, 2030, authority under this section applies.\",
}
for name,text in cases.items():
    sample = build_us_code_sample(title='99',section=name,text=text)
    enc = codec.encode_sample(sample)
    ranking = ranked_modal_families(enc)
    shares = {r['family']: r['share'] for r in ranking}
    logits = codec.family_logits_for_sample(sample, modal_families=('frame','deontic','conditional_normative','alethic','temporal'))
    print('\\n',name)
    print('shares',shares)
    print('logits',logits)
    print('signals', {k:v for k,v in modal_ambiguity_signals(enc).items() if v and k in {'has_frame_context','has_frame_scope_phrase','has_statutory_scope_reference','has_deontic_scope','has_deontic_cue','has_condition_or_exception_scope','has_alethic_scope','has_temporal_scope','has_temporal_scope_phrase','has_calendar_date_scope'}})

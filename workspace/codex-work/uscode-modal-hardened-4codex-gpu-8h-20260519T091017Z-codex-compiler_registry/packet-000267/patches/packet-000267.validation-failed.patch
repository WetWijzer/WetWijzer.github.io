+def test_compiler_backfills_conditional_family_for_when_clause_under_deontic_scope() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    encoding = compiler.encoder.encode(
+        "The Secretary shall submit the report when the committee approves.",
+        document_id="compiler-conditional-when-backfill",
+    )
+    ranking = encoding.ranked_modal_families()
+
+    conditional_candidate = next(
+        (
+            candidate
+            for candidate in ranking
+            if candidate["family"] == ModalLogicFamily.CONDITIONAL_NORMATIVE.value
+        ),
+        None,
+    )
+    deontic_candidate = next(
+        (
+            candidate
+            for candidate in ranking
+            if candidate["family"] == ModalLogicFamily.DEONTIC.value
+        ),
+        None,
+    )
+
+    assert deontic_candidate is not None
+    assert conditional_candidate is not None
+    assert float(conditional_candidate["share_raw"]) > 0.0
+    assert float(conditional_candidate["share_raw"]) < float(deontic_candidate["share_raw"])
+
+
+def test_compiler_adaptive_logits_debias_context_only_frame_scope_for_statutory_reference() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    encoding = compiler.encoder.encode(
+        "As provided in section 3, the Secretary acts.",
+        document_id="compiler-frame-context-debias",
+    )
+    ranking = compiler._adaptive_family_ranking_from_logits(encoding)
+
+    assert ranking
+    assert ranking[0]["family"] == ModalLogicFamily.CONDITIONAL_NORMATIVE.value
+    frame_candidate = next(
+        (
+            candidate
+            for candidate in ranking
+            if candidate["family"] == ModalLogicFamily.FRAME.value
+        ),
+        None,
+    )
+    assert frame_candidate is not None
+    assert float(ranking[0]["share_raw"]) > float(frame_candidate["share_raw"])
+

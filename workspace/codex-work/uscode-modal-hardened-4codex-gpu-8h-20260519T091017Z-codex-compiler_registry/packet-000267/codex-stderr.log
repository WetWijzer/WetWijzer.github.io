   701	    used_fallback_model: bool = False
   702	
   703	    def modal_family_counts(self) -> Dict[str, int]:
   704	        counts: Dict[str, int] = {}
   705	        for cue in self.cues:
   706	            counts[cue.family] = counts.get(cue.family, 0) + 1
   707	        return dict(sorted(counts.items()))
   708	
   709	    def ranked_modal_families(self) -> List[Dict[str, float]]:
   710	        """Return cue-count ranking with stable ordering and share ratios."""
   711	        return ranked_modal_families(self)

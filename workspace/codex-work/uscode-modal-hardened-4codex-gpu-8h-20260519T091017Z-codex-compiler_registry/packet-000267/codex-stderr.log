   804	class ModalRegistry:
   805	    """Lookup table for modal parse profiles."""
   806	
   807	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   808	        self._profiles: Dict[str, ModalParseProfile] = {
   809	            profile.profile_id: profile for profile in profiles
   810	        }
   811	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   812	            profile.family: profile for profile in profiles
   813	        }
   814	
   815	    def get_profile(
   816	        self,
   817	        family: ModalLogicFamily | str,
   818	        system: Optional[ModalSystem | str] = None,
   819	    ) -> ModalParseProfile:
   820	        """Get a profile by family, optionally constrained by system."""
   821	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   822	        if system is None:
   823	            return self._by_family[resolved_family]
   824	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   825	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]

   691	
   692	    document_id: str
   693	    text: str
   694	    normalized_text: str
   695	    tokens: List[SpaCyTokenFeature]
   696	    sentences: List[SpaCySentenceFeature]
   697	    cues: List[SpaCyModalCueFeature]

+def test_compiler_backfills_frame_share_for_statutory_deontic_scope() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    result = compiler.compile(
+        (
+            "An entity shall submit a report under section 1301 and shall maintain "
+            "records."
+        ),
+        document_id="compiler-ambiguity-deontic-frame-statutory-backfill",
+    )
+    metadata = _adaptive_pair_metadata(
+        result,
+        predicted_family=ModalLogicFamily.DEONTIC.value,
+        target_family=ModalLogicFamily.FRAME.value,
+    )
+    assert metadata is not None
+    assert float(metadata.get("target_share", 0.0)) > 0.0
+
+
+def test_compiler_recognizes_as_otherwise_provided_in_conditional_scope() -> None:
+    compiler = DeterministicModalCompiler(
+        config=ModalCompilerConfig(parser_backend="spacy")
+    )
+
+    result = compiler.compile(
+        (
+            "The authority is administered by the Secretary as otherwise provided in "
+            "section 585 of this title."
+        ),
+        document_id="compiler-ambiguity-frame-conditional-as-otherwise-provided-in",
+    )
+    metadata = _adaptive_pair_metadata(
+        result,
+        predicted_family=ModalLogicFamily.FRAME.value,
+        target_family=ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
+    )
+    assert metadata is not None
+    assert float(metadata.get("target_share", 0.0)) > 0.0
+

from ipfs_datasets_py.optimizers.logic_theorem_optimizer.spacy_modal_codec import SpaCyModalCodec, SpaCyLegalEncoder, SpaCyModalDecoder, ranked_modal_families, modal_ambiguity_signals
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample

codec = SpaCyModalCodec(encoder=SpaCyLegalEncoder(model_name='definitely_missing_legal_model'), decoder=SpaCyModalDecoder())
texts = {
    'frame_deontic_token_only': 'Authority under this section applies, and civil penalties apply for violations.',
    'frame_conditional_scope': 'Authority under this section applies pursuant to subsection (b).',
    'frame_temporal_scope': 'Authority under this section applies during each fiscal year.',
    'alethic_conditional_scope': 'It is possible and necessary that authority applies, except as provided in subsection (b).',
    'temporal_conditional_competition': 'Within 30 days and no later than January 1, 2030, if the application is incomplete, notice is withheld.',
    'frame_deontic_without_cue': 'Authority under this section imposes liability for noncompliance.'
}
for name,text in texts.items():
    sample = build_us_code_sample(title='99', section=name, text=text)
    enc = codec.encode_sample(sample)
    ranking = ranked_modal_families(enc)
    shares = {i['family']: float(i['share']) for i in ranking}
    logits = codec.family_logits_for_sample(sample, modal_families=('frame','deontic','conditional_normative','temporal','alethic'))
    print('\\n',name)
    print('signals:', {k:v for k,v in modal_ambiguity_signals(enc).items() if v and ('frame' in k or 'deontic' in k or 'condition' in k or 'temporal' in k or 'alethic' in k or 'statutory' in k)})
    print('ranking:', [(i['family'], i['share']) for i in ranking[:5]])
    print('logits:', logits)

        or bool(signals.get("has_temporal_scope"))
        or bool(signals.get("has_epistemic_scope"))
    )
    if not has_competing_scope:
        return
    counts[frame_family] = _GENERIC_FRAME_NORMATIVE_SCOPE_SOFT_CAP



def test_signal_free_adaptive_ambiguity_targets_do_not_repeat_pairs() -> None:
    for family in (
        "alethic",
        "conditional_normative",
        "deontic",
        "epistemic",
        "frame",
        "hybrid",
        "temporal",
    ):
        targets = signal_free_adaptive_ambiguity_targets(family)
        assert len(targets) == len(set(targets))



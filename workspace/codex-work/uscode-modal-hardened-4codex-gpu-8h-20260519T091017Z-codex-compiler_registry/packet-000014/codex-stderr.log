+def _apply_deontic_scope_competing_backfill(
+    counts: Dict[str, float],
+    signals: Mapping[str, bool],
+) -> None:
+    """Backfill competing families when deontic force appears with other strong scopes."""
+    deontic_family = ModalLogicFamily.DEONTIC.value
+    deontic_count = float(counts.get(deontic_family, 0.0))
+    if deontic_count < _DEONTIC_SCOPE_COMPETING_BACKFILL_TRIGGER:
+        return
+    frame_family = ModalLogicFamily.FRAME.value
+    temporal_family = ModalLogicFamily.TEMPORAL.value
+    conditional_family = ModalLogicFamily.CONDITIONAL_NORMATIVE.value
+    frame_count = float(counts.get(frame_family, 0.0))
+    temporal_count = float(counts.get(temporal_family, 0.0))
+    conditional_count = float(counts.get(conditional_family, 0.0))
+    has_strong_frame_scope = bool(
+        signals.get("has_statutory_scope_reference")
+        or signals.get("has_frame_scope_phrase")
+        or signals.get("has_frame_editorial_scope_phrase")
+    )
+    has_any_frame_scope = bool(
+        signals.get("has_frame_context")
+        or signals.get("has_frame_scope_phrase")
+        or signals.get("has_frame_editorial_scope_phrase")
+        or signals.get("has_statutory_scope_reference")
+    )
+    has_strong_temporal_scope = bool(
+        signals.get("has_calendar_date_scope")
+        or signals.get("has_temporal_scope_phrase")
+        or signals.get("has_temporal_within_scope")
+    )
+    has_temporal_scope = bool(signals.get("has_temporal_scope"))
+    has_strong_conditional_scope = bool(
+        signals.get("has_conditional_scope_phrase")
+        or signals.get("has_conditional_scope_token")
+        or signals.get("has_condition_clause")
+        or signals.get("has_exception_clause")
+    )
+    has_conditional_scope = bool(signals.get("has_condition_or_exception_scope"))
+    if frame_count <= 0.0 and has_any_frame_scope:
+        frame_backfill = _DEONTIC_SCOPE_COMPETING_BACKFILL_WEIGHT
+        if has_strong_frame_scope:
+            frame_backfill = max(
+                frame_backfill,
+                _DEONTIC_SCOPE_STRONG_FRAME_BACKFILL_WEIGHT,
+            )
+        counts[frame_family] = max(frame_count, frame_backfill)
+    if temporal_count <= 0.0 and has_temporal_scope:
+        temporal_backfill = _DEONTIC_SCOPE_COMPETING_BACKFILL_WEIGHT
+        if has_strong_temporal_scope:
+            temporal_backfill = max(
+                temporal_backfill,
+                _DEONTIC_SCOPE_STRONG_TEMPORAL_BACKFILL_WEIGHT,
+            )
+        counts[temporal_family] = max(temporal_count, temporal_backfill)
+    if conditional_count <= 0.0 and has_conditional_scope:
+        conditional_backfill = _DEONTIC_SCOPE_COMPETING_BACKFILL_WEIGHT
+        if has_strong_conditional_scope:
+            conditional_backfill = max(
+                conditional_backfill,
+                _DEONTIC_SCOPE_STRONG_CONDITIONAL_BACKFILL_WEIGHT,
+            )
+        counts[conditional_family] = max(conditional_count, conditional_backfill)
+
+

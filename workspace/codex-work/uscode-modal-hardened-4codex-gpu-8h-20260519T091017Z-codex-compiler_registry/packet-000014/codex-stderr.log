+def test_spacy_codec_strengthens_deontic_share_for_frame_scope_with_deontic_scope_phrase() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    token_sample = build_us_code_sample(
+        title="12",
+        section="1822b",
+        text=(
+            "Authority and jurisdiction in this former section are mandatory for "
+            "reporting."
+        ),
+    )
+    phrase_sample = build_us_code_sample(
+        title="12",
+        section="1822c",
+        text=(
+            "Authority and jurisdiction in this former section provide liability "
+            "for reporting violations."
+        ),
+    )
+    token_encoding = codec.encode_sample(token_sample)
+    phrase_encoding = codec.encode_sample(phrase_sample)
+    token_signals = modal_ambiguity_signals(token_encoding)
+    phrase_signals = modal_ambiguity_signals(phrase_encoding)
+    token_ranking = ranked_modal_families(token_encoding)
+    phrase_ranking = ranked_modal_families(phrase_encoding)
+
+    token_deontic_share = next(
+        float(item["share"])
+        for item in token_ranking
+        if item["family"] == "deontic"
+    )
+    phrase_deontic_share = next(
+        float(item["share"])
+        for item in phrase_ranking
+        if item["family"] == "deontic"
+    )
+
+    assert not any(cue.family == "deontic" for cue in token_encoding.cues)
+    assert not any(cue.family == "deontic" for cue in phrase_encoding.cues)
+    assert token_signals["has_deontic_scope_phrase"] is False
+    assert phrase_signals["has_deontic_scope_phrase"] is True
+    assert phrase_deontic_share > token_deontic_share
+
+

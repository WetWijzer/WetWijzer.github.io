+def test_spacy_encoder_extracts_epistemic_cues_for_certification_and_determination() -> None:
+    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
+    encoding = encoder.encode(
+        "The Secretary certifies that the determination that a violation occurred is final.",
+        document_id="sample-certification-determination",
+    )
+
+    assert any(
+        cue.family == "epistemic"
+        and cue.cue.lower() in {"certifies", "certifies that"}
+        for cue in encoding.cues
+    )
+    assert any(
+        cue.family == "epistemic"
+        and cue.cue.lower() == "determination that"
+        for cue in encoding.cues
+    )
+

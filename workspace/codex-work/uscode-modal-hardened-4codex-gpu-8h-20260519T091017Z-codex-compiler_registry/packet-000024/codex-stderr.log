    if (
        frame_count >= _FRAME_DEONTIC_SCOPE_BACKFILL_TRIGGER
        and deontic_count <= _COMPETING_SCOPE_BACKFILL_WEIGHT
        and bool(signals.get("has_deontic_scope"))
    ):
        counts[deontic_family] = max(
            float(counts.get(deontic_family, 0.0)),

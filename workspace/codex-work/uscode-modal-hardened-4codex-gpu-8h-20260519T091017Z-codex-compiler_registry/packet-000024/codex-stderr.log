        )
    if (
        frame_count >= _FRAME_TEMPORAL_SCOPE_BACKFILL_TRIGGER
        and temporal_count <= _COMPETING_SCOPE_BACKFILL_WEIGHT
        and bool(signals.get("has_temporal_scope"))
    ):
        temporal_backfill = _FRAME_COMPETING_SCOPE_BACKFILL_WEIGHT
        if (

   668	class ModalRegistry:
   669	    """Lookup table for modal parse profiles."""
   670	
   671	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   672	        self._profiles: Dict[str, ModalParseProfile] = {
   673	            profile.profile_id: profile for profile in profiles
   674	        }
   675	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   676	            profile.family: profile for profile in profiles
   677	        }
   678	
   679	    def get_profile(
   680	        self,
   681	        family: ModalLogicFamily | str,
   682	        system: Optional[ModalSystem | str] = None,
   683	    ) -> ModalParseProfile:
   684	        """Get a profile by family, optionally constrained by system."""
   685	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   686	        if system is None:
   687	            return self._by_family[resolved_family]
   688	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   689	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   690	
   691	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   692	        """Return all profiles in deterministic order."""
   693	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   694	
   695	    def to_dict(self) -> Mapping[str, object]:
   696	        """Return a stable JSON-ready registry mapping."""
   697	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   698	

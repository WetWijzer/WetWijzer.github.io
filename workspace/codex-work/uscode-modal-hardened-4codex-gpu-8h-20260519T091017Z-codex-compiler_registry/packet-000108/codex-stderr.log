   700	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   701	    """Return whether a modal family encodes normative legal force."""
   702	    if isinstance(family, ModalLogicFamily):
   703	        resolved = family
   704	    else:
   705	        try:
   706	            resolved = ModalLogicFamily(str(family))
   707	        except ValueError:
   708	            return False
   709	    return resolved in NORMATIVE_MODAL_FAMILIES

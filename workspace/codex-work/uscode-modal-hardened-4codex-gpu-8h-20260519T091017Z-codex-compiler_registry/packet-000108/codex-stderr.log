    30	def test_deontic_profile_has_expected_operators_and_serial_semantics() -> None:
    31	    profile = DEFAULT_MODAL_REGISTRY.get_profile(ModalLogicFamily.DEONTIC)
    32	    symbols = {operator.symbol for operator in profile.operators}
    33	    cue_terms = {cue for operator in profile.operators for cue in operator.cue_terms}

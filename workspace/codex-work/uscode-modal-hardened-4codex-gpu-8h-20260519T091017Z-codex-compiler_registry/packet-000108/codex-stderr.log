  2293	    if bool(signals.get("has_alethic_scope")):
  2294	        alethic_bonus = (
  2295	            0.7
  2296	            if bool(signals.get("has_alethic_scope_phrase"))
  2297	            else 0.45
  2298	        )
  2299	        boosts[ModalLogicFamily.ALETHIC.value] = alethic_bonus

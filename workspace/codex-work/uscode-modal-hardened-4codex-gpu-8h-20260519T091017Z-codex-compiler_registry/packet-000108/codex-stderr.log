  1593	    @staticmethod
  1594	    def _adaptive_margin_priority(*, family_margin: float, threshold: float) -> float:
  1595	        """Return deterministic ambiguity priority from policy margin settings.
  1596	
  1597	        For contested low-margin cases (positive margin below threshold), a
  1598	        smaller gap to the threshold carries higher urgency. For outvoted
  1599	        cases (zero/negative margin), severity increases with outvote depth.
  1600	        """
  1601	        resolved_margin = float(family_margin)
  1602	        resolved_threshold = max(0.0, float(threshold))
  1603	        if resolved_margin > 0.0:
  1604	            return max(0.0, resolved_threshold - resolved_margin)
  1605	        return abs(resolved_margin) + resolved_threshold
  1606	
  1607	    @staticmethod
  1608	    def _adaptive_margin_within_threshold(
  1609	        *,
  1610	        family_margin: float,
  1611	        threshold: float,
  1612	        epsilon: float = 1e-12,
  1613	    ) -> bool:
  1614	        """Return whether the margin is at or below threshold with float tolerance."""
  1615	        resolved_margin = float(family_margin)
  1616	        resolved_threshold = float(threshold)
  1617	        resolved_epsilon = max(0.0, float(epsilon))
  1618	        return resolved_margin <= (resolved_threshold + resolved_epsilon)

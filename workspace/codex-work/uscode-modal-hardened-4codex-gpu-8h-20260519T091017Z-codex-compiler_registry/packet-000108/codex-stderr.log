  1321	def _overlap_aware_modal_family_counts(
  1322	    encoding: SpaCyLegalEncoding,
  1323	) -> Dict[str, float]:
  1324	    """Count family cues while collapsing nested same-family cue spans."""
  1325	    spans_by_family: Dict[str, List[tuple[int, int]]] = {}
  1326	    for cue in encoding.cues:
  1327	        start = int(cue.start_char)
  1328	        end = int(cue.end_char)
  1329	        if start < 0 or end <= start:
  1330	            continue
  1331	        spans_by_family.setdefault(cue.family, []).append((start, end))
  1332	
  1333	    counts: Dict[str, float] = {}
  1334	    for family, spans in spans_by_family.items():
  1335	        if not spans:
  1336	            continue
  1337	        unique_spans = sorted(set(spans))
  1338	        effective_spans: List[tuple[int, int]] = []
  1339	        for start, end in unique_spans:
  1340	            span_len = end - start
  1341	            covered_by_larger_span = False
  1342	            for other_start, other_end in unique_spans:
  1343	                if other_start == start and other_end == end:
  1344	                    continue
  1345	                other_len = other_end - other_start
  1346	                if (
  1347	                    other_start <= start
  1348	                    and other_end >= end
  1349	                    and other_len > span_len
  1350	                ):
  1351	                    covered_by_larger_span = True
  1352	                    break
  1353	            if not covered_by_larger_span:
  1354	                effective_spans.append((start, end))
  1355	        counts[family] = float(len(effective_spans))
  1356	    return counts

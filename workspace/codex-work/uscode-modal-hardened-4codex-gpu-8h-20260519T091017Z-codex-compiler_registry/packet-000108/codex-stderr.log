  1577	    def _adaptive_margin_explicit_type(
  1578	        self,
  1579	        predicted_family: str,
  1580	        target_family: str,
  1581	        margin_direction: str,
  1582	    ) -> str:
  1583	        return "_".join(
  1584	            (
